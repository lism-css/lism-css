{
  "name": "lism-css-projects",
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.0",
  "description": "",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "scripts": {
    "dev:docs": "cd apps/docs && pnpm run dev",
    "dev:catalog": "pnpm --filter @lism-css/catalog storybook",
    "test": "turbo run test",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "turbo run format",
    "format:core": "turbo run format --filter=./packages/lism-css",
    "format:ui": "turbo run format --filter=./packages/lism-ui",
    "format:docs": "turbo run format --filter=./apps/docs",
    "clean": "turbo run clean",
    "build": "turbo run build",
    "build:core": "turbo run build --filter=./packages/lism-css",
    "build:core:css": "turbo run build:css --filter=./packages/lism-css",
    "check:docs": "pnpm --filter lism-docs exec astro check",
    "build:ui": "turbo run build --filter=./packages/lism-ui",
    "build:mcp": "turbo run build --filter=./packages/mcp",
    "merge:dev": "git checkout main && git merge dev",
    "merge:m2d": "git checkout dev && git merge main",
    "deploy": "sh -c 'echo \"本当に main にマージしてデプロイしますか？ (yes/no)\"; read ans; if [ \"$ans\" = \"yes\" ]; then echo \"memo: mainブランチにdevをマージしてpushし、devに戻る\"; git checkout main && git merge dev && git push origin main && git checkout dev; else echo \"デプロイを中止しました\"; fi'",
    "publish:core": "pnpm --filter lism-css publish",
    "publish:ui": "pnpm --filter @lism-css/ui publish --access public",
    "publish:mcp": "pnpm --filter @lism-css/mcp publish --access public",
    "publish:cli": "pnpm --filter @lism-css/cli publish --access public",
    "sync:cdn-versions": "node scripts/sync-cdn-versions.mjs",
    "prepare": "husky"
  },
  "keywords": [],
  "private": true,
  "author": {
    "name": "ddryo",
    "url": "https://github.com/ddryo"
  },
  "homepage": "https://...",
  "license": "MIT",
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "cross-env": "^7.0.3",
    "cssnano": "^7.1.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-storybook": "^10.3.3",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-check-updates": "^18.3.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "react-icons": "^5.6.0",
    "sass": "^1.98.0",
    "stylelint": "^17.4.0",
    "stylelint-config-recommended-scss": "^17.0.0",
    "stylelint-prettier": "^5.0.3",
    "turbo": "^2.8.17",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  }
}
