---
import { getCollection } from 'astro:content';
import { Cluster } from 'lism-css/astro';
import Tag from '@/components/Tag.astro';

const posts = await getCollection('posts');
const tagSet = new Set<string>();
for (const post of posts) {
  for (const tag of post.data.tags) tagSet.add(tag);
}
const tags = Array.from(tagSet).sort();

const { tagBgc = 'base-2' } = Astro.props;
---

<Cluster as="nav" aria-label="タグ一覧" g="5">
  <span class="-fz:2xs -c:text-2" aria-hidden="true">#</span>
  {
    tags.map((tag) => (
      <Tag href={`/tag/${tag}/`} bgc={tagBgc}>
        {tag}
      </Tag>
    ))
  }
</Cluster>
