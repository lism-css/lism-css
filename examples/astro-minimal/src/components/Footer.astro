---
import { Lism, Stack, Flex, Text, Link, Divider } from 'lism-css/astro';
---

<Lism as="footer" pt="50" pb="30" px="50">
  <Stack g="50">
    <Flex jc="between">
      <Stack g="20" style={{ width: '300px' }}>
        <Link href="/" ff="accent" fz="2xl" fw="700" fs="italic" c="text" td="none"> Lism CSS </Link>
        <Text fz="s" c="text-2" lh="s">
          Lightweight CSS layout framework.<br />
          Open source. MIT License.
        </Text>
      </Stack>
      <Flex g="50">
        <Stack g="20">
          <Text fz="xs" fw="600">Resources</Text>
          <Link href="https://lism-css.com/" fz="xs" c="text-2" td="none">Documentation</Link>
          <Link href="https://github.com/lism-css/lism-css" fz="xs" c="text-2" td="none">GitHub</Link>
          <Link href="https://www.npmjs.com/package/lism-css" fz="xs" c="text-2" td="none">npm</Link>
        </Stack>
        <Stack g="20">
          <Text fz="xs" fw="600">Community</Text>
          <Link href="https://github.com/lism-css/lism-css/issues" fz="xs" c="text-2" td="none">Issues</Link>
          <Link href="https://github.com/lism-css/lism-css/discussions" fz="xs" c="text-2" td="none">Discussions</Link>
        </Stack>
      </Flex>
    </Flex>

    <Divider />

    <Flex jc="between" ai="center">
      <Text fz="2xs" style={{ color: '#ccc' }}>© 2026 Lism CSS.</Text>
      <Flex g="30" ai="center">
        <Link href="https://github.com/lism-css/lism-css/blob/main/LICENSE" fz="2xs" c="text-2" td="none">MIT License</Link>
      </Flex>
    </Flex>
  </Stack>
</Lism>
