---
import { Lism, Flex, Link, Divider } from 'lism-css/astro';
---

<Lism as="header">
  <Flex ai="center" jc="between" py="20" px="50">
    <Link href="/" ff="accent" fz="2xl" fw="700" fs="italic" c="text" td="none"> Lism CSS </Link>
    <Flex as="nav" g="30" ai="center">
      <Link href="https://lism-css.com/" c="text-2" fz="s" td="none">Docs</Link>
      <Link href="https://github.com/lism-css/lism-css" c="text-2" fz="s" td="none">GitHub</Link>
      <Link href="https://www.npmjs.com/package/lism-css" c="text-2" fz="s" td="none">npm</Link>
    </Flex>
    <Flex ai="center" g="20">
      <Link href="https://lism-css.com/" bgc="text" c="base" fz="s" fw="500" px="30" py="10" bdrs="99" td="none"> Get Started </Link>
    </Flex>
  </Flex>
  <Divider />
</Lism>
