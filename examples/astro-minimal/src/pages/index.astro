---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import { Lism, Stack, Center, Heading, Link, Text } from 'lism-css/astro';
---

<Layout title="Lism CSS - Lightweight Layout Framework">
  <Stack min-h="100svh">
    <Header />
    <Center as="section" isContainer hasGutter fxg="1" g="40">
      <Heading level="1" ff="accent" fw="normal" ta="center" fz="5xl">Get started</Heading>
      <Stack ai="center">
        <Text ta="center" c="text-2" fz="xs">Install Lism CSS Skills for AI agents:</Text>
        <Text as="pre" ff="mono" fz="s" bgc="base-2" bdrs="20" bxsh="10" px="30" py="15" my-s="10">npx skills add lism-css/lism-css</Text>
      </Stack>
      <Link
        href="https://lism-css.com/en/docs/"
        set="plain"
        hasTransition
        bgc="text"
        c="base"
        bd
        bdc="text"
        px="30"
        py="20"
        lh="xs"
        bdrs="10"
        hov={{ bxsh: '40', c: 'text', bgc: 'transparent' }}>Documentation</Link
      >
    </Center>
    <Lism as="footer" isContainer hasGutter py="40">
      <Center>
        <Text ta="center" c="text-2" fz="xs">Minimal Astro example for <Link href="https://lism-css.com/">Lism CSS</Link></Text>
      </Center>
    </Lism>
  </Stack>
</Layout>
