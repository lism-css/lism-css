---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Stack, Flex, Grid, Text, Heading, Link, Divider, Frame, Container, Inline } from 'lism-css/astro';

const cards = [
  {
    icon: '<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>',
    title: 'Layout Modules',
    desc: 'Stack, Flex, Grid, Center, and more. Build any page structure with composable layout primitives.',
  },
  {
    icon: '<circle cx="13.5" cy="6.5" r="2.5"/><circle cx="6" cy="12" r="2.5"/><circle cx="18" cy="18" r="2.5"/><line x1="9" y1="6.5" x2="11" y2="6.5"/><line x1="8.5" y1="12" x2="15.5" y2="12"/><line x1="3" y1="18" x2="15.5" y2="18"/>',
    title: 'Design Tokens',
    desc: 'Consistent sizing, spacing, colors, and typography through CSS custom properties.',
  },
  {
    icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
    title: 'Utility Props',
    desc: 'Apply styles intuitively via component props — no class name memorization needed.',
  },
  {
    icon: '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>',
    title: 'CSS Layers',
    desc: 'Organized with @layer for predictable cascade. No more specificity wars.',
  },
  {
    icon: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
    title: 'Lightweight',
    desc: 'No JavaScript runtime for styles. Pure CSS core with tree-shakeable components.',
  },
  {
    icon: '<rect width="7" height="7" x="14" y="3" rx="1"/><path d="M10 21V8a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-5a1 1 0 0 0-1-1H3"/>',
    title: 'Multi-Framework',
    desc: 'Works with plain HTML, React, Next.js, and Astro. Choose your stack freely.',
  },
];
---

<Layout title="Lism CSS - Lightweight Layout Framework">
  <Header />
  <Container as="main">
    <!-- Hero Section -->
    <Stack as="section" ai="center" g="40" pt="60" pb="50" px="50">
      <Stack ai="center" g="30">
        <Heading level={1} ff="accent" fs="italic" fw="normal" ta="center" lh="xs" lts="s" fz="72px" style={{ maxWidth: '900px' }}>
          Hello, Lism CSS
        </Heading>
        <Text ta="center" c="text-2" fz="l" lh="base" style={{ maxWidth: '680px' }}>
          Lism CSS is a lightweight CSS framework providing layout modules, design tokens, and utility classes — all organized in a clean CSS Layer
          structure.
        </Text>
      </Stack>
      <Flex g="20">
        <Link href="https://lism-css.com/" bgc="text" c="base" fw="500" px="40" py="20" bdrs="99" td="none"> Documentation </Link>
        <Link href="https://github.com/lism-css/lism-css" bd c="text" fw="500" px="40" py="20" bdrs="99" td="none">
          View on GitHub <Inline c="text-2">→</Inline>
        </Link>
      </Flex>
    </Stack>

    <!-- Trust Section -->
    <Stack as="section" ai="center" g="30" py="40" px="50">
      <Text fz="2xs" fw="500" tt="upper" lts="0.15em" style={{ color: '#ccc' }}> Works with </Text>
      <Flex g="50" ai="center">
        <Text fw="600" style={{ color: '#ccc' }}>HTML</Text>
        <Text fw="600" style={{ color: '#ccc' }}>React</Text>
        <Text fw="600" style={{ color: '#ccc' }}>Next.js</Text>
        <Text fw="600" style={{ color: '#ccc' }}>Astro</Text>
      </Flex>
    </Stack>

    <Divider />

    <!-- Card Grid Section -->
    <Stack as="section" ai="center" g="50" py="60" px="50">
      <Stack ai="center" g="20">
        <Text fz="2xs" fw="500" c="text-2" tt="upper" lts="0.15em"> FEATURES </Text>
        <Heading level={2} ff="accent" fs="italic" fw="normal" ta="center" fz="48px" lts="s"> Everything you need, nothing you don't. </Heading>
      </Stack>

      <Grid gtc="repeat(3, 1fr)" g="30" w="100%" style={{ maxWidth: '1100px' }}>
        {
          cards.map((card) => (
            <Stack g="20" p="30" bd>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={card.icon}
              />
              <Text fw="600">{card.title}</Text>
              <Text fz="s" c="text-2" lh="s">
                {card.desc}
              </Text>
            </Stack>
          ))
        }
      </Grid>
    </Stack>

    <Divider />
  </Container>
  <Footer />
</Layout>
