---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import { Stack, Heading, Wrapper, Lism } from 'lism-css/astro';
import Layout from '@/layouts/Layout.astro';
import CategoryTabs from '@/components/CategoryTabs.astro';
import PostList from '@/components/PostList.astro';
import Pager from '@/components/Pager.astro';
import { siteConfig } from '@/config/site';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = (await getCollection('posts')).sort((a, b) => b.data.date.localeCompare(a.data.date));
  return paginate(posts, { pageSize: siteConfig.pagination.postsPerPage });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<Layout title={`${siteConfig.name} — ${siteConfig.tagline}`}>
  <Wrapper contentSize="s" hasGutter>
    <Stack g="50">
      {/* ページタイトル */}
      <Stack g="15">
        <Lism class="c--eyebrow">BLOGS</Lism>
        <Heading level="1" fz={['2xl', null, '3xl']} fw="500" ff="base" lts="s" lh="s" m="0">
          {siteConfig.tagline}
        </Heading>
      </Stack>

      {/* カテゴリータブ */}
      <CategoryTabs current="all" />

      {/* 記事リスト */}
      <PostList posts={page.data} />

      {/* ページャー */}
      <Pager currentPage={page.currentPage} lastPage={page.lastPage} />
    </Stack>
  </Wrapper>
</Layout>
