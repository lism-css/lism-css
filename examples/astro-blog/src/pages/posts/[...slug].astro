---
import { getCollection, render } from 'astro:content';
import { Lism, Stack, Flex, Heading, Text, Wrapper, Inline } from 'lism-css/astro';
import Layout from '@/layouts/Layout.astro';
import TableOfContents from '@/components/TableOfContents.astro';
import ArticleNav from '@/components/ArticleNav.astro';
import { generateToc } from '@/lib/generateToc';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).sort((a, b) => b.data.date.localeCompare(a.data.date));
  return posts.map((post, index) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: posts[index - 1], // 表示順で「新しい記事」が prev に来る
      next: posts[index + 1],
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content, headings } = await render(post);
const toc = generateToc(headings);
---

<Layout title={`${post.data.title} — lism.journal`} description={post.data.excerpt}>
  <Wrapper contentSize="1100px" hasGutter>
    {/* breadcrumb */}
    <Lism class="c--eyebrow" mb="30" d="block">
      HOME ／ {post.data.category.toUpperCase()} ／ {post.data.title}
    </Lism>

    {/* 記事グリッド: md未満は1カラム（header → toc → body → nav）、md以上は2カラム */}
    <div class="c--articleGrid">
      {/* 記事ヘッダー */}
      <header class="c--articleGrid_header">
        <Stack g="20" pb="30" bd-b>
          <Flex g="20" ai="center" fxw="wrap">
            <Inline class="c--tag is--solid">{post.data.category}</Inline>
            <Inline class="c--date">{post.data.date}</Inline>
            <Inline class="c--date">·　READING TIME {post.data.readtime.toUpperCase()}</Inline>
          </Flex>
          <Heading level="1" fz={['2xl', null, '3xl']} fw="500" ff="base" lh="s" lts="s" m="0">
            {post.data.title}
          </Heading>
          <Text fz="m" c="text-2" lh="l" m="0">
            {post.data.excerpt}
          </Text>
        </Stack>
      </header>

      {/* TOC（md未満は記事ヘッダー直下、md以上は右サイド sticky） */}
      <aside class="c--articleGrid_toc c--tocAside">
        <TableOfContents toc={toc} />
      </aside>

      {/* 本文 */}
      <article class="c--articleGrid_body c--articleBody">
        <Content />
      </article>

      {/* 前後の記事 */}
      <nav class="c--articleGrid_nav">
        <ArticleNav
          prev={prev ? { title: prev.data.title, slug: prev.id } : undefined}
          next={next ? { title: next.data.title, slug: next.id } : undefined}
        />
      </nav>
    </div>
  </Wrapper>
</Layout>
