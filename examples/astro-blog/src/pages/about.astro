---
import PageLayout from '@/layouts/PageLayout.astro';
import { Group, Stack, Container, Frame, WithSide, Media, Layer, Heading, Divider } from 'lism-css/astro';
import { DummyText } from '@lism-css/ui/astro';
---

<PageLayout title="About" description="lism.blog について">
  <p>
    このサイトは <a href="https://astro.build/">Astro</a> と
    <a href="https://lism-css.com/">Lism CSS</a> を使って構築されたブログテンプレートです。<br />
    <a href="https://github.com/lism-css/lism-css">リポジトリ</a>の
    <code>examples/astro-blog/</code> 配下で全文を公開しています。
  </p>

  <p>
    このテンプレートサイトの構成については、<a href="/dev/astro-blog-overview">examples/astro-blog の構成</a>を参照してください。
  </p>

  <Divider my="60" />
  <DummyText lang="ja" />

  <Group as="section" pos="relative" max-sz="full" my="60">
    <Layer>
      <Frame h="100%">
        <Media src="https://cdn.lism-css.com/img/a-2.jpg" alt="" width="960" height="640" />
        <Layer bgc="black:40%" />
      </Frame>
    </Layer>
    <Container isWrapper gr="1" gc="1" hasGutter pos="relative" z="1">
      <!-- <Grid gtc={['auto', null, 'auto 1fr']} c="white" g="50" py="50"> -->
      <WithSide sideW="auto" mainW="xs" c="white" g="50" py="50">
        <Heading level="2" isSide class="u--trim" fz="3xl" fw="bold" hl="l">ロレム・イプサム</Heading>
        <Stack class="u--trimAll" g="40">
          <DummyText lang="ja" />
          <DummyText lang="ja" length="xl" />
        </Stack>
        <!-- </Grid> -->
      </WithSide>
    </Container>
  </Group>

  <DummyText lang="ja" length="l" />
</PageLayout>
