---
import { Group, Text, Inline, Heading, Link, Center } from 'lism-css/astro';
import Layout from '@/layouts/Layout.astro';
import { siteConfig } from '@/config/site';
---

<Layout title={`404 Not Found — ${siteConfig.name}`} description="お探しのページは見つかりませんでした。">
  <Center isContainer hasGutter fxg="1" g="40" ta="center">
    {/* title */}
    <Heading level="1" layout="stack" fz="m" g="5">
      <Inline as="span" fz="5xl" fw="bold" ff="accent">404</Inline>
      <Inline as="span" fz="l" fw="normal" c="text-2">ページが見つかりません</Inline>
    </Heading>

    {/* description */}
    <Text>お探しのページは削除されたか、URL が変更された可能性があります。</Text>

    {/* back to home */}
    <Group my-s="20">
      <Link href="/" set="plain" ff="accent" fz="xs" tt="upper" c="brand" hov="underline">Back to Home</Link>
    </Group>
  </Center>
</Layout>
