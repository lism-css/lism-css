---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import { Stack, Heading, Text } from 'lism-css/astro';
import ArchiveLayout from '@/layouts/ArchiveLayout.astro';
import CategoryTabs from '@/components/CategoryTabs.astro';
import PostList from '@/components/PostList.astro';
import Pager from '@/components/Pager.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import Eyebrow from '@/components/Eyebrow.astro';
import { CATEGORIES, CATEGORY_KEYS, parsePostId } from '@/lib/categories';
import { siteConfig } from '@/config/site';

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection('posts');
  return CATEGORY_KEYS.flatMap((category) => {
    const posts = allPosts.filter((p) => parsePostId(p.id).category === category).sort((a, b) => b.data.date.localeCompare(a.data.date));
    return paginate(posts, {
      params: { category },
      props: { category },
      pageSize: siteConfig.pagination.postsPerPage,
    });
  });
}) satisfies GetStaticPaths;

const { category, page } = Astro.props;
const meta = CATEGORIES[category];

const getPageHref = (n: number) => (n === 1 ? `/${category}/` : `/${category}/${n}/`);
---

<ArchiveLayout title={`${meta.label} — ${siteConfig.name}`} description={meta.description}>
  {/* パンくず */}
  <Breadcrumb items={[{ label: 'HOME', href: '/' }, { label: meta.label }]} />

  {/* ページタイトル */}
  <Stack g="15">
    <Eyebrow>CATEGORY</Eyebrow>
    <Heading level="1" fz={['2xl', null, '3xl']} fw="500" ff="base" lts="s" lh="s" m="0">
      {meta.label}
    </Heading>
    <Text fz="s" c="text-2" m="0">{meta.description}（{page.total} 件）</Text>
  </Stack>

  {/* カテゴリータブ */}
  <CategoryTabs current={category} />

  {/* 記事リスト */}
  <PostList posts={page.data} showCategory={false} />

  {/* ページャー */}
  <Pager currentPage={page.currentPage} lastPage={page.lastPage} getPageHref={getPageHref} />
</ArchiveLayout>
