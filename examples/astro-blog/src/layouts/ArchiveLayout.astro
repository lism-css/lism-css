---
import { Stack } from 'lism-css/astro';
import Layout from './Layout.astro';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description?: string;
  breadcrumb?: BreadcrumbItem[];
}

const { title, description, breadcrumb } = Astro.props;
---

<Layout title={title} description={description} breadcrumb={breadcrumb}>
  <Stack isWrapper="s" isContainer hasGutter g="50">
    <slot />
  </Stack>
</Layout>
