---
import { Lism, Grid, Link, Stack } from 'lism-css/astro';
import Eyebrow from '@/components/Eyebrow.astro';

interface NavItem {
  title: string;
  id: string;
}
interface Props {
  prev?: NavItem;
  next?: NavItem;
}

const { prev, next } = Astro.props;
---

<Lism bd-t pt="30" my-s="40" ff="accent">
  <Grid gtc="1fr 1fr" g="30">
    {
      prev ? (
        <Link href={`/${prev.id}/`} td="none" c="inherit" hov={{ c: 'brand' }} d="block">
          <Stack g="10">
            <Eyebrow>← PREVIOUS</Eyebrow>
            <Lism ff="base" fz="s" fw="500" lh="s">
              {prev.title}
            </Lism>
          </Stack>
        </Link>
      ) : (
        <span />
      )
    }
    {
      next ? (
        <Link href={`/${next.id}/`} td="none" c="inherit" hov={{ c: 'brand' }} d="block" ta="right">
          <Stack g="10">
            <Eyebrow>NEXT →</Eyebrow>
            <Lism ff="base" fz="s" fw="500" lh="s">
              {next.title}
            </Lism>
          </Stack>
        </Link>
      ) : (
        <span />
      )
    }
  </Grid>
</Lism>
