---
import { Lism, Flex, Inline, Link } from 'lism-css/astro';

interface Props {
  currentPage: number;
  lastPage: number;
  getPageHref?: (n: number) => string;
}

const { currentPage, lastPage, getPageHref = (n: number) => (n === 1 ? '/' : `/${n}/`) } = Astro.props;

function buildPages(current: number, last: number): (number | 'gap')[] {
  if (last <= 7) return Array.from({ length: last }, (_, i) => i + 1);
  const result: (number | 'gap')[] = [1];
  if (current > 3) result.push('gap');
  for (let i = Math.max(2, current - 1); i <= Math.min(last - 1, current + 1); i++) {
    result.push(i);
  }
  if (current < last - 2) result.push('gap');
  result.push(last);
  return result;
}

const pages = buildPages(currentPage, lastPage);
const prevHref = currentPage > 1 ? getPageHref(currentPage - 1) : null;
const nextHref = currentPage < lastPage ? getPageHref(currentPage + 1) : null;
---

{
  lastPage > 1 && (
    <Lism as="nav" class="c--pager" ff="accent" fz="xs" lts=":xl" my-s="20" aria-label="ページネーション">
      <Flex jc="center" ai="center" g="10">
        {prevHref ? (
          <Link href={prevHref} class="c--pager_nav" c="text" td="none" py="10" px="15" tt="upper" hasTransition rel="prev">
            ← Prev
          </Link>
        ) : (
          <Inline class="c--pager_nav" c="text" py="10" px="15" tt="upper" aria-disabled="true" aria-hidden="true">
            ← Prev
          </Inline>
        )}

        <Flex g="5" ai="center">
          {pages.map((p) =>
            p === 'gap' ? (
              <Inline class="c--pager_gap" c="text-2" px="5">
                …
              </Inline>
            ) : p === currentPage ? (
              <Inline class="c--pager_num" d="inline-flex" ai="center" jc="center" px="5" c="text-2" hasTransition aria-current="page">
                {p}
              </Inline>
            ) : (
              <Link href={getPageHref(p)} class="c--pager_num" d="inline-flex" ai="center" jc="center" px="5" c="text-2" td="none" hasTransition>
                {p}
              </Link>
            )
          )}
        </Flex>

        {nextHref ? (
          <Link href={nextHref} class="c--pager_nav" c="text" td="none" py="10" px="15" tt="upper" hasTransition rel="next">
            Next →
          </Link>
        ) : (
          <Inline class="c--pager_nav" c="text" py="10" px="15" tt="upper" aria-disabled="true" aria-hidden="true">
            Next →
          </Inline>
        )}
      </Flex>
    </Lism>
  )
}
<style>
  @layer lism-component {
    /* === ページャー === */
    .c--pager_nav {
      &:hover {
        color: var(--brand);
      }

      &[aria-disabled='true'] {
        color: var(--text-2);
        opacity: 0.4;
        pointer-events: none;
      }
    }

    /* 28px はトークン外の固定値（数字バッジの最小サイズ）+ 視覚補正 */
    .c--pager_num {
      min-width: 28px;
      height: 28px;
      border-block-end: 1px solid transparent;
      margin-block-end: -1px;

      &:hover {
        color: var(--brand);
      }

      &[aria-current] {
        color: var(--text);
        border-block-end-color: var(--brand);
      }
    }
  }
</style>
