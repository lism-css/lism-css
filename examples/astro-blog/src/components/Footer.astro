---
import { Lism, Center } from 'lism-css/astro';
import Eyebrow from '@/components/Eyebrow.astro';
import { siteConfig } from '@/config/site';
---

<Lism as="footer" bd-t py="40" px="30" {...Astro.props}>
  <Center>
    <Eyebrow ta="center" o="0.7">
      {siteConfig.footer.copyright}
    </Eyebrow>
  </Center>
</Lism>
