---
import { Link } from 'lism-css/astro';

interface Props {
  href: string;
  solid?: boolean;
  class?: string;
}

const { href, solid = false, class: className, ...rest } = Astro.props;

const variantProps = solid ? { bdc: 'text', c: 'base-2', bgc: 'text' } : { bdc: 'divider', c: 'text-2', bgc: 'base-2' };
---

<Link
  href={href}
  class:list={['c--tag', solid && 'c--tag--solid', className]}
  set="plain"
  d="inline-flex"
  ai="center"
  fz="2xs"
  lts="l"
  lh="xs"
  py="5"
  px="10"
  bdrs="10"
  {...variantProps}
  {...rest}
>
  <slot />
</Link>
