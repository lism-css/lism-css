---
import { Cluster, Link } from 'lism-css/astro';
import { CATEGORIES } from '@/config/categories';

type Current = 'all' | 'dev' | 'life';

interface Props {
  current: Current;
}

const { current } = Astro.props;

const tabs: { key: Current; label: string; href: string }[] = [
  { key: 'all', label: 'ALL', href: '/' },
  { key: 'dev', label: CATEGORIES.dev.label, href: '/dev/' },
  { key: 'life', label: CATEGORIES.life.label, href: '/life/' },
];
---

<Cluster as="nav" g="30" class="c--catTabs" bd-b ff="accent" fz="xs" lts=":2xl" aria-label="カテゴリーで絞り込む">
  {
    tabs.map((tab) => (
      <Link
        href={tab.href}
        class="c--catTab"
        d="inline-block"
        py="15"
        px="5"
        c="text-2"
        tt="upper"
        td="none"
        hasTransition
        aria-current={current === tab.key ? 'page' : undefined}
      >
        {tab.label}
      </Link>
    ))
  }
</Cluster>

<style>
  @layer lism-component {
    /* === カテゴリータブ === */
    /* 視覚補正（透明な下線 + 1px 食い込み）と擬似クラス・状態属性 */
    .c--catTab {
      border-block-end: 1px solid transparent;
      margin-block-end: -1px;

      &:hover {
        color: var(--brand);
      }

      &[aria-current] {
        color: var(--text);
        border-block-end-color: var(--brand);
      }
    }
  }
</style>
