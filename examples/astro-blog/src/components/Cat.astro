---
import { Inline, Link } from 'lism-css/astro';

interface Props {
  href?: string;
  class?: string;
}

const { href, class: className, ...rest } = Astro.props;

const Tag = href ? Link : Inline;
const linkProps = href ? { href, set: 'plain', hov: '-o,underline' } : {};
---

<Tag class:list={['c--cat', className]} ff="accent" fz="2xs" lts=":xl" c="brand" px="5" {...linkProps} {...rest}>
  <slot />
</Tag>
