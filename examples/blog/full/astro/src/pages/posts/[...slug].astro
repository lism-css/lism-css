---
import { getCollection, render } from 'astro:content';
import { Group, Flow, Stack, Cluster, WithSide, Heading } from 'lism-css/astro';
import Layout from '@/layouts/Layout.astro';
import { Callout } from '@lism-css/ui/astro/Callout';
import { Alert } from '@lism-css/ui/astro/Alert';
import TableOfContents from '@/components/TableOfContents.astro';
import ArticleNav from '@/components/ArticleNav.astro';
import ShareButtons from '@/components/ShareButtons.astro';
import Date from '@/components/Date.astro';
import Cat from '@/components/Cat.astro';
import Tag from '@/components/Tag.astro';
import { generateToc } from '@/lib/generateToc';
import { assertUniquePostSlugs, getCategoryHref, getPostOgImageHref, getTagHref, parsePostId } from '@/lib/posts';
import { CATEGORIES } from '@/config/categories';
import { siteConfig } from '@/config/site';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).sort((a, b) => b.data.date.localeCompare(a.data.date));
  assertUniquePostSlugs(posts);

  return posts.map((post, index) => {
    const { slug } = parsePostId(post.id);
    return {
      params: { slug },
      props: {
        post,
        prev: posts[index - 1], // 表示順で「新しい記事」が prev に来る
        next: posts[index + 1],
      },
    };
  });
}

const { post, prev, next } = Astro.props;
const { category } = parsePostId(post.id);
const meta = CATEGORIES[category];
const categoryHref = getCategoryHref(category);
const { Content, headings } = await render(post);
const toc = generateToc(headings);
const ogImage = getPostOgImageHref(post.id);
---

<Layout
  title={`${post.data.title} — ${siteConfig.name}`}
  description={post.data.excerpt}
  breadcrumb={[{ label: meta.label, href: categoryHref }, { label: post.data.title }]}
  ogImage={ogImage}
  ogType="article"
>
  <Stack g="50">
    {/* 記事ヘッダー */}
    <Group as="header" isWrapper="l" hasGutter>
      <Stack g="30">
        <Cluster g="10">
          <Date>{post.data.date}</Date>
          <Cat href={categoryHref}>{meta.label}</Cat>
        </Cluster>
        <Heading level="1">
          {post.data.title}
        </Heading>
        {
          post.data.tags.length > 0 && (
            <Cluster g="10" ai="center">
              {post.data.tags.map((tag) => (
                <Tag href={getTagHref(tag)}>{tag}</Tag>
              ))}
            </Cluster>
          )
        }
      </Stack>
    </Group>

    {/* 本文 + TOC */}
    <Group isWrapper="l" hasGutter>
      <WithSide fxd="row-reverse" mainW="40em" sideW="var(--sz--toc)" g="40">
        <Group as="aside" isSide>
          <Group pos="sticky" t="20" z="1">
            <TableOfContents toc={toc} />
          </Group>
        </Group>
        <Flow as="article" class="c--articleBody">
          <Content components={{ Callout, Alert }} />
        </Flow>
      </WithSide>

      {/* フッター（シェアボタン → 前後記事ナビ） */}
      <Group as="footer" my-s="60">
        <Group py="30" bd-y>
          <ShareButtons title={post.data.title} />
        </Group>
        <Group py="30">
          <ArticleNav
            prev={prev ? { title: prev.data.title, id: prev.id } : undefined}
            next={next ? { title: next.data.title, id: next.id } : undefined}
          />
        </Group>
      </Group>
    </Group>
  </Stack>
</Layout>
