---
/**
 * Details - ルートコンポーネント
 * details要素をレンダリングし、CSSのみでアニメーションを実装
 * スクリプト不要で::details-contentを使用
 */
import type { AstroLismFixedLayoutProps } from 'lism-css/astro';
import getLismProps from 'lism-css/lib/getLismProps';
import { getDetailsProps, type DetailsProps } from '../getProps';

// スタイルのインポート
import '../_style.css';

type Props = AstroLismFixedLayoutProps & DetailsProps;

const props: Props = Astro.props;
---

<details {...getLismProps(getDetailsProps(props))}>
  <slot />
</details>
