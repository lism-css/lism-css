---
/**
 * Icon - アイコンコンポーネント
 * 開閉状態を示すアイコン（開いた時に回転）
 */
import { Lism } from 'lism-css/astro';
import atts from 'lism-css/lib/helper/atts';
import { defaultProps } from '../getProps';

const { class: className, ...props } = Astro.props || {};
const { className: baseClass, ...baseIconProps } = defaultProps.icon;
---

<Lism {...baseIconProps} {...props} class={atts(className, baseClass)}><slot /></Lism>
