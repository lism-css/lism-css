---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';
import atts from 'lism-css/lib/helper/atts';
import '../_style.css';

type Props<Tag extends HTMLTag = 'details'> = Polymorphic<{ as: Tag }> &
  AstroLismBaseProps & {
    open?: boolean;
  };

const { class: className, as = 'details', open, ...props } = Astro.props;
---

<Lism as={as} class={atts(className, 'c--details')} open={open} {...props}><slot /></Lism>
