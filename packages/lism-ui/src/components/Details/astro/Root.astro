---
/**
 * Details - ルートコンポーネント
 * details要素をレンダリングし、CSSのみでアニメーションを実装
 * スクリプト不要で::details-contentを使用
 */
import type { AstroLismBaseProps } from 'lism-css/astro';
import getLismProps from 'lism-css/lib/getLismProps';
import atts from 'lism-css/lib/helper/atts';

// スタイルのインポート
import '../_style.css';

type Props = AstroLismBaseProps & {
  open?: boolean;
};

const { class: className, open, ...props } = Astro.props;

const lismProps = getLismProps({
  className: atts(className, 'c--details'),
  ...props,
});
---

<details open={open} {...lismProps}><slot /></details>
