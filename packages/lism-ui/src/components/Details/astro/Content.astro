---
/**
 * Content - コンテンツコンポーネント
 * details要素の開閉されるコンテンツ部分のラッパー
 * grid-template-rows: 0fr → 1fr のアニメーションに必要
 */
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';
import atts from 'lism-css/lib/helper/atts';

type Props<Tag extends HTMLTag = 'div'> = Polymorphic<{ as: Tag }> & AstroLismBaseProps;

const { class: className, ...props } = Astro.props;
---

<Lism class="c--details_body">
  <Lism layout="flow" flow="s" class={atts(className, 'c--details_content')} {...props as Record<string, unknown>}><slot /></Lism>
</Lism>
