---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismFixedLayoutProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';
import { defaultProps } from '../getProps';

type Props<Tag extends HTMLTag = 'summary'> = Polymorphic<{ as: Tag }> & AstroLismFixedLayoutProps;

const { as: asTag = 'summary' as HTMLTag, ...restProps } = Astro.props;
---

<Lism as={asTag} {...defaultProps.summary as Record<string, unknown>} {...restProps}>
  <slot />
</Lism>
