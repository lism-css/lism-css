---
import type { AstroLismFixedLayoutProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';
import { defaultProps } from '../getProps';

type Props = AstroLismFixedLayoutProps;

const props: Props = Astro.props;
---

<Lism as="summary" {...defaultProps.summary as Record<string, unknown>} {...props}>
  <slot />
</Lism>
