---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLayoutProps } from 'lism-css/astro';
import type { FlexProps } from 'lism-css/lib/types/LayoutProps';
import { Flex } from 'lism-css/astro';
import atts from 'lism-css/lib/helper/atts';

type Props<Tag extends HTMLTag = 'summary'> = Polymorphic<{ as: Tag }> & AstroLayoutProps<FlexProps>;

const { class: className, as = 'summary', ...props } = Astro.props;
---

<Flex as={as} g="10" ai="center" class={atts(className, 'c--details_summary')} {...props}><slot /></Flex>
