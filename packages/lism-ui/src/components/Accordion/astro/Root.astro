---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Stack } from 'lism-css/astro';
import { getRootProps, type AccordionRootProps } from '../getProps';
import '../_style.css';

type Props<Tag extends HTMLTag = 'div'> = Polymorphic<{ as: Tag }> & AstroLismBaseProps & AccordionRootProps;

const { as: asTag = 'div' as HTMLTag, ...restProps } = Astro.props;
const rootProps = getRootProps(restProps as AccordionRootProps);
---

<Stack as={asTag} {...rootProps as Record<string, unknown>}>
  <slot />
</Stack>

<script>
  import setAccordion from '../setAccordion';
  setAccordion();
</script>
