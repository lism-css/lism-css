---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';
import { defaultProps } from '../getProps';

type Props<Tag extends HTMLTag = 'span'> = Polymorphic<{ as: Tag }> & AstroLismBaseProps;

const { as: asTag = 'span' as HTMLTag, ...restProps } = Astro.props;
const { as: _defaultAs, ...iconDefaultProps } = defaultProps.icon;
---

<Lism as={asTag} {...iconDefaultProps as Record<string, unknown>} {...restProps} />
