---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';
import atts from 'lism-css/lib/helper/atts';

type Props<Tag extends HTMLTag = 'span'> = Polymorphic<{ as: Tag }> & AstroLismBaseProps;

const { class: className, as = 'span', ...props } = Astro.props;
---

<Lism atomic="icon" as={as} pi="center" fxsh="0" aria-hidden="true" class={atts(className, 'c--accordion_icon')} {...props} />
