---
import { Lism } from 'lism-css/astro';
import atts from 'lism-css/lib/helper/atts';

const { class: className, as = 'div', role, set = 'plain', ...props } = Astro.props || {};
---

<Lism as={as} class={atts(className, 'c--accordion_heading')} set={set} role={as === 'div' ? (role ?? 'heading') : role} {...props}>
  <slot />
</Lism>
