---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';
import { getHeadingProps, type AccordionHeadingProps } from '../getProps';

type Props<Tag extends HTMLTag = 'div'> = Polymorphic<{ as: Tag }> & AstroLismBaseProps & AccordionHeadingProps;

const { as: asTag = 'div' as HTMLTag, ...restProps } = Astro.props;
const { as: _as, ...headingProps } = getHeadingProps(restProps as AccordionHeadingProps);
---

<Lism as={asTag} {...headingProps as Record<string, unknown>}>
  <slot />
</Lism>
