---
import type { AstroLayoutProps } from 'lism-css/astro';
import type { FlowLayoutProps } from 'lism-css/lib/types/LayoutProps';
import { Lism, Flow } from 'lism-css/astro';
import atts from 'lism-css/lib/helper/atts';

type Props = AstroLayoutProps<FlowLayoutProps> & {
  accID?: string;
  isOpen?: boolean;
};

const { class: className, accID = '__LISM_ACC_ID__', isOpen = false, ...props } = Astro.props;
---

<Lism class={atts(className, 'c--accordion_panel')} id={accID} hidden={isOpen ? undefined : 'until-found'} pos="relative" ov="hidden">
  <Flow class="c--accordion_content" {...props}><slot /></Flow>
</Lism>
