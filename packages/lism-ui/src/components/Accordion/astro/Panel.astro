---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';
import { getPanelProps, type AccordionPanelProps } from '../getProps';

type Props<Tag extends HTMLTag = 'div'> = Polymorphic<{ as: Tag }> & AstroLismBaseProps & AccordionPanelProps;

const { as: asTag = 'div' as HTMLTag, ...restProps } = Astro.props;
const { panelProps, contentProps } = getPanelProps(restProps as AccordionPanelProps);
---

<Lism as={asTag} {...panelProps as Record<string, unknown>}>
  <Lism {...contentProps as Record<string, unknown>}>
    <slot />
  </Lism>
</Lism>
