---
// import type { LismProps } from 'lism-css/types';
import { Lism } from 'lism-css/astro';
import { defaultProps } from '../getProps';

// interface Props extends LismProps {}
const { flow, isOpen = false, accID = '__LISM_ACC_ID__', ...props } = Astro.props || {};
---

<Lism {...defaultProps.panel} id={accID} hidden={isOpen ? undefined : 'until-found'}>
	<div hidden='until-found'>hoge</div>
	<Lism layout='flow' flow={flow} {...defaultProps.content} {...props}>
		<slot />
	</Lism>
</Lism>
