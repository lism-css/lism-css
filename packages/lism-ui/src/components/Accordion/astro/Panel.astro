---
import { Lism } from 'lism-css/astro';
import atts from 'lism-css/lib/helper/atts';
import { getPanelProps } from '../getProps';

const { class: className, ...props } = Astro.props || {};
const { panelProps, contentProps } = getPanelProps(props);
---

<Lism class={atts(className, 'c--accordion_panel')} {...panelProps}>
  <Lism class="c--accordion_content" {...contentProps}><slot /></Lism>
</Lism>
