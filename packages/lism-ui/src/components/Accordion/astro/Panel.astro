---
import { Lism } from 'lism-css/astro';
import atts from 'lism-css/lib/helper/atts';

const { class: className, accID = '__LISM_ACC_ID__', isOpen = false, ...props } = Astro.props || {};
---

<Lism class={atts(className, 'c--accordion_panel')} id={accID} hidden={isOpen ? undefined : 'until-found'} pos="relative" ov="hidden">
  <Lism class="c--accordion_content" layout="flow" {...props}><slot /></Lism>
</Lism>
