---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';
import Icon from './Icon.astro';
import { getButtonProps } from '../getProps';

type Props<Tag extends HTMLTag = 'button'> = Polymorphic<{ as: Tag }> &
  AstroLismBaseProps & {
    isOpen?: boolean;
    accID?: string;
  };

const { as: asTag = 'button' as HTMLTag, isOpen = false, accID = '__LISM_ACC_ID__', ...restProps } = Astro.props;
const { as: _as, ...buttonProps } = getButtonProps(restProps as Record<string, unknown>);
---

<Lism as={asTag} {...buttonProps as Record<string, unknown>} aria-controls={accID} aria-expanded={isOpen ? 'true' : 'false'}>
  <slot />
  <Icon />
</Lism>
