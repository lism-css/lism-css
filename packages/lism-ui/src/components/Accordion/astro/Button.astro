---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLayoutProps } from 'lism-css/astro';
import type { FlexProps } from 'lism-css/lib/types/LayoutProps';
import { Flex } from 'lism-css/astro';
import atts from 'lism-css/lib/helper/atts';
import Icon from './Icon.astro';

type Props<Tag extends HTMLTag = 'button'> = Polymorphic<{ as: Tag }> &
  AstroLayoutProps<FlexProps> & {
    isOpen?: boolean;
    accID?: string;
  };

const { isOpen = false, accID = '__LISM_ACC_ID__', class: className, as = 'button', ...props } = Astro.props;
---

<Flex
  as={as}
  set="plain"
  g="10"
  w="100%"
  ai="center"
  jc="between"
  class={atts(className, 'c--accordion_button')}
  aria-controls={accID}
  aria-expanded={isOpen ? 'true' : 'false'}
  {...props}
>
  <slot />
  <Icon />
</Flex>
