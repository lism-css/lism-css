---
import type { HTMLTag, Polymorphic } from 'astro/types';
import { Flow, Flex, Stack, Icon, Center } from 'lism-css/astro';
import atts from 'lism-css/lib/helper/atts';
import getCalloutProps, { type CalloutProps } from '../getProps';

type Props<Tag extends HTMLTag = 'div'> = Polymorphic<{ as: Tag }> & CalloutProps;

const { class: className, ...astroProps } = Astro.props;
const { icon, title, flow, ...calloutProps } = getCalloutProps(astroProps);
---

<Stack class={atts(className, 'c--callout')} {...calloutProps}>
  {
    title && (
      <Flex c="keycolor" fw="bold" ai="center" g="10">
        <Center>
          <Icon icon={icon} size="1.25em" />
        </Center>
        <span>{title}</span>
      </Flex>
    )
  }
  <Flow flow={flow}>
    <slot />
  </Flow>
</Stack>
