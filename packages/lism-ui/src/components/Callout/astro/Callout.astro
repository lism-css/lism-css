---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import type { IconProps } from 'lism-css/react';
import { Flow, Flex, Stack, Icon, Center } from 'lism-css/astro';
import getCalloutProps, { type CalloutProps } from '../getProps';

type Props<Tag extends HTMLTag = 'div'> = Polymorphic<{ as: Tag }> &
  AstroLismBaseProps & {
    type?: string;
    keycolor?: string;
    icon?: IconProps['icon'];
    title?: string;
    flow?: string;
  };

const { icon, title, flow, ...calloutProps } = getCalloutProps(Astro.props as CalloutProps);
---

<Stack {...calloutProps}>
  {
    title && (
      <Flex class="c--callout_head" c="keycolor" fw="bold" ai="center" g="10">
        <Center class="c--callout_icon" fz="xl">
          <Icon icon={icon} />
        </Center>
        <span class="c--callout_title">{title}</span>
      </Flex>
    )
  }
  <Flow class="c--callout_body" flow={flow}>
    <slot />
  </Flow>
</Stack>
