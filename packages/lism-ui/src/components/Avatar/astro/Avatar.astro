---
import { Frame } from 'lism-css/astro';
import atts from 'lism-css/lib/helper/atts';

const { size = '1.5em', src = '', alt = '', class: className, ...props } = Astro.props;
---

<Frame class={atts(className, 'c--avatar')} ar="1/1" w={size} bdrs="99" {...props}>
  <img src={src} alt={alt} width="100%" height="100%" decoding="async" />
</Frame>
