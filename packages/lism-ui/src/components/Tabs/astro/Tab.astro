---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';
import { getTabProps } from '../getProps';

type Props<Tag extends HTMLTag = 'button'> = Polymorphic<{ as: Tag }> &
  AstroLismBaseProps & {
    tabId?: string | number;
    index?: number;
    isActive?: boolean;
  };

const { as: asTag = 'button' as HTMLTag, tabId = 'tab', index = 0, isActive, ...restProps } = Astro.props;
const { as: _as, ...tabProps } = getTabProps(restProps as Record<string, unknown>);
const controlId = `${tabId}-${index}`;
---

<Lism as={asTag} {...tabProps as Record<string, unknown>} role="tab" aria-controls={controlId} aria-selected={isActive ? 'true' : 'false'}>
  <slot />
</Lism>
