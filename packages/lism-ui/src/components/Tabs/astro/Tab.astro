---
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';
import atts from 'lism-css/lib/helper/atts';

type Props = AstroLismBaseProps & {
  tabId?: string;
  index?: number;
  isActive?: boolean;
};

const { tabId = 'tab', index = 0, isActive = false, class: className, ...props } = Astro.props;
const controlId = `${tabId}-${index}`;
---

<Lism
  as="button"
  set="plain"
  class={atts(className, 'c--tabs_tab')}
  role="tab"
  aria-controls={controlId}
  aria-selected={isActive ? 'true' : 'false'}
  {...props}
>
  <slot />
</Lism>
