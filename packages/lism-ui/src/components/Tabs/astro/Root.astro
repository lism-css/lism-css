---
// import type { LismProps } from 'lism-css/types';
import { Lism } from 'lism-css/astro';
import atts from 'lism-css/lib/helper/atts';
import buildModifierClass from '../../../helper/buildModifierClass';
// import Tab from './Tab.astro';
// import TabPanel from './Panel.astro';
import TabList from './List.astro';
import uuid from '../../../helper/uuid.js';

import transformTabitems from './transformTabitems.js';

import '../_style.css';

// import TheTab from './TheTab.astro';}
// slotsについて: https://docs.astro.build/ja/reference/api-reference/#astroslots

// Propsの定義
// interface Props extends LismProps {
// 	uid?: string | number;
// 	defaultIndex?: string | number;
// }
// propsの取得
const { defaultIndex = 1, tabId = '', listProps = {}, variant, class: className, ...props } = Astro.props || {};

// tabID生成
const theTabID = tabId ? tabId : uuid();

// 子要素の方から順番に処理されていくので、文字列処理でデータを抽出
const { btns, panels } = transformTabitems(await Astro.slots.render('default'), theTabID, defaultIndex);

const hasItems = btns.length > 0;
---

<Lism class={atts(className, buildModifierClass('c--tabs', { variant }))} {...props}>
  {
    btns && (
      <TabList {...listProps}>
        {btns.map((btn, index) => {
          return <Fragment key={index} set:html={btn} />;
        })}
      </TabList>
    )
  }
  {
    panels.map((panel, index) => {
      return <Fragment key={index} set:html={panel} />;
    })
  }
  {!hasItems && <slot />}
</Lism>

<script>
  import setTabs from '../setTabs';
  const tabsAll = document.querySelectorAll('.c--tabs');
  tabsAll.forEach((tabs) => {
    setTabs(tabs);
  });
</script>
