---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';
import atts from 'lism-css/lib/helper/atts';

type Props<Tag extends HTMLTag = 'div'> = Polymorphic<{ as: Tag }> & AstroLismBaseProps;

const { class: className, as = 'div', ...props } = Astro.props;
---

<Lism as={as} role="tablist" class={atts(className, 'c--tabs_list')} {...props}><slot /></Lism>
