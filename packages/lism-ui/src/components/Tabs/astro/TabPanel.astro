---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';

type Props<Tag extends HTMLTag = 'div'> = Polymorphic<{ as: Tag }> &
  AstroLismBaseProps & {
    tabId?: string | number;
    index?: number;
    isActive?: boolean;
  };

const { as: asTag = 'div' as HTMLTag, tabId = 'tab', index = 0, isActive = false, ...restProps } = Astro.props;
const controlId = `${tabId}-${index}`;
---

<Lism
  as={asTag}
  id={controlId}
  role="tabpanel"
  aria-hidden={isActive ? 'false' : 'true'}
  lismClass="c--tabs_panel"
  {...restProps as Record<string, unknown>}
>
  <slot />
</Lism>
