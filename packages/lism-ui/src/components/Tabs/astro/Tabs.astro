---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';
import TabList from './TabList.astro';
import uuid from '../../../helper/uuid';
import transformTabitems from './transformTabitems';
import getTabsProps from '../getProps';
import '../_style.css';

type Props<Tag extends HTMLTag = 'div'> = Polymorphic<{ as: Tag }> &
  AstroLismBaseProps & {
    defaultIndex?: number;
    tabId?: string;
    listProps?: Record<string, unknown>;
  };

const { as: asTag = 'div' as HTMLTag, defaultIndex = 1, tabId = '', listProps = {}, ...restProps } = Astro.props;

// tabID生成
const theTabID = tabId ? tabId : uuid();

// 子要素の方から順番に処理されていくので、文字列処理でデータを抽出
const { btns, panels } = transformTabitems(await Astro.slots.render('default'), theTabID, defaultIndex);

const hasItems = btns.length > 0;
---

<Lism as={asTag} {...getTabsProps(restProps as Record<string, unknown>) as Record<string, unknown>}>
  {
    btns && (
      <TabList {...listProps}>
        {btns.map((btn, index) => {
          return <Fragment key={index} set:html={btn} />;
        })}
      </TabList>
    )
  }
  {
    panels.map((panel, index) => {
      return <Fragment key={index} set:html={panel} />;
    })
  }
  {!hasItems && <slot />}
</Lism>

<script>
  import setTabs from '../setTabs';
  const tabsAll = document.querySelectorAll<HTMLElement>('.c--tabs');
  tabsAll.forEach((tabs) => {
    setTabs(tabs);
  });
</script>
