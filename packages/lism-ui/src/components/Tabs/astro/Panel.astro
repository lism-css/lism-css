---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';
import atts from 'lism-css/lib/helper/atts';

type Props<Tag extends HTMLTag = 'div'> = Polymorphic<{ as: Tag }> &
  AstroLismBaseProps & {
    tabId?: string;
    index?: number;
    isActive?: boolean;
  };

const { tabId = 'tab', index = 0, isActive = false, class: className, as = 'div', ...props } = Astro.props;
const controlId = `${tabId}-${index}`;
---

<Lism as={as} id={controlId} role="tabpanel" aria-hidden={isActive ? 'false' : 'true'} class={atts(className, 'c--tabs_panel')} {...props}
  ><slot /></Lism
>
