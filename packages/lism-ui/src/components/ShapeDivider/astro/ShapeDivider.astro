---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';
import getProps, { type ShapeDividerProps } from '../getProps';
import '../_style.css';

type Props<Tag extends HTMLTag = 'div'> = Polymorphic<{ as: Tag }> & AstroLismBaseProps & ShapeDividerProps;

const componentProps = getProps(Astro.props);
const { viewBox, isEmpty, ...lismProps } = componentProps || {};
---

{
  componentProps && (
    <Lism {...lismProps}>
      {isEmpty ? null : (
        <div class="c--shapeDivider_inner">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="c--shapeDivider_svg"
            viewBox={viewBox}
            width="100%"
            height="100%"
            fill="currentColor"
            focusable="false"
            preserveAspectRatio="none"
          >
            <slot />
          </svg>
        </div>
      )}
    </Lism>
  )
}
