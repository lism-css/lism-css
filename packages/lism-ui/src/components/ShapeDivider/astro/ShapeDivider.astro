---
import { Lism } from 'lism-css/astro';
import getProps from '../getProps';
import '../_style.css';

const { class: className, ...astroProps } = Astro.props;
const componentProps = getProps({ className, ...astroProps });
const { viewBox, isAnimation, isEmpty, className: outClassName, ...lismProps } = componentProps || {};
---

{
  componentProps && (
    <Lism class={outClassName} {...lismProps}>
      {isEmpty ? null : (
        <div class="c--shapeDivider_inner">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="c--shapeDivider_svg"
            viewBox={viewBox}
            width="100%"
            height="100%"
            fill="currentColor"
            focusable="false"
            preserveAspectRatio="none"
          >
            <slot />
          </svg>
        </div>
      )}
    </Lism>
  )
}
