---
import { Lism } from 'lism-css/astro';
import atts from 'lism-css/lib/helper/atts';
import getProps from '../getProps';
import '../_style.css';

const { class: className, ...astroProps } = Astro.props;
const componentProps = getProps(astroProps);
const { viewBox, isAnimation, isEmpty, ...lismProps } = componentProps || {};
---

{
  componentProps && (
    <Lism class={atts(className, 'c--shapeDivider')} {...lismProps}>
      {isEmpty ? null : (
        <div class="c--shapeDivider_inner">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="c--shapeDivider_svg"
            viewBox={viewBox}
            width="100%"
            height="100%"
            fill="currentColor"
            focusable="false"
            preserveAspectRatio="none"
          >
            <slot />
          </svg>
        </div>
      )}
    </Lism>
  )
}
