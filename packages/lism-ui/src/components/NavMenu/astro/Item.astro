---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';
import { getItemProps } from '../getProps';

type Props<Tag extends HTMLTag = 'li'> = Polymorphic<{ as: Tag }> & AstroLismBaseProps;

const { as: asTag = 'li' as HTMLTag, ...restProps } = Astro.props;
const { as: _as, ...itemProps } = getItemProps(restProps);
---

<Lism as={asTag} {...itemProps as Record<string, unknown>}>
  <slot />
</Lism>
