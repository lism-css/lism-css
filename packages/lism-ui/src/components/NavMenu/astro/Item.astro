---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';
import atts from 'lism-css/lib/helper/atts';

type Props<Tag extends HTMLTag = 'li'> = Polymorphic<{ as: Tag }> & AstroLismBaseProps;

const { class: className, as = 'li', ...props } = Astro.props;
---

<Lism as={as} class={atts(className, 'c--navMenu_item')} {...props}><slot /></Lism>
