---
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Stack } from 'lism-css/astro';
import atts from 'lism-css/lib/helper/atts';

type Props = AstroLismBaseProps;

const { class: className, ...props } = Astro.props;
---

<Stack as="ul" class={atts(className, 'c--navMenu_nest')} px-s="20" {...props}><slot /></Stack>
