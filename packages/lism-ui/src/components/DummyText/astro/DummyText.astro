---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismFixedLayoutProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';
import getContent from '../getContent';

type Props<Tag extends HTMLTag = 'p'> = Polymorphic<{ as: Tag }> &
  AstroLismFixedLayoutProps & {
    pre?: string;
    length?: string;
    lang?: 'ja' | 'en';
    offset?: number;
  };

const { as: tagName = 'p' as HTMLTag, pre = '', length = 'm', lang = 'en', offset = 0, ...props } = Astro.props;
const content = getContent({ pre, lang, length, offset });
---

<Lism as={tagName} {...props} set:html={content} />
