---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';
import getContent from '../getContent';

type Props<Tag extends HTMLTag = 'p'> = Polymorphic<{ as: Tag }> &
  AstroLismBaseProps & {
    pre?: string;
    length?: string;
    lang?: 'ja' | 'en' | 'ar';
    offset?: number;
  };

const { as = 'p', pre = '', length = 'm', lang = 'en', offset = 0, ...props } = Astro.props;
const content = getContent({ pre, lang, length, offset });
---

<Lism as={as} {...props} set:html={content} />
