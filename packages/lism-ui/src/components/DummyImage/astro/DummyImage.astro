---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismFixedLayoutProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';

type Props<Tag extends HTMLTag = 'img'> = Polymorphic<{ as: Tag }> & AstroLismFixedLayoutProps;

const props = Astro.props;
---

<Lism as="img" src="https://cdn.lism-css.com/dummy-image.jpg" width="600" height="400" alt="" {...props} />
