---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Flex } from 'lism-css/astro';
import atts from 'lism-css/lib/helper/atts';
import buildModifierClass from '../../../helper/buildModifierClass';
import '../_style.css';

type Props<Tag extends HTMLTag = 'a'> = Polymorphic<{ as: Tag }> &
  AstroLismBaseProps & {
    variant?: string;
  };

const { class: className, variant, ...props } = Astro.props;
---

<Flex as="a" lh="s" py="10" px="20" hov="-o" class={atts(className, buildModifierClass('c--button', { variant }))} {...props}><slot /></Flex>
