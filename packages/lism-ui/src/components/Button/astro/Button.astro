---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Flex } from 'lism-css/astro';
import '../_style.css';

type Props<Tag extends HTMLTag = 'a'> = Polymorphic<{ as: Tag }> & AstroLismBaseProps;

const props = Astro.props;
---

<Flex lismClass="c--button" as="a" lh="s" py="10" px="20" hov="o" {...props}>
  <slot />
</Flex>
