---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Lism, Flow, Grid, Frame, Decorator } from 'lism-css/astro';
import atts from 'lism-css/lib/helper/atts';
import buildModifierClass from '../../../helper/buildModifierClass';
import '../_style.css';

type Props<Tag extends HTMLTag = 'div'> = Polymorphic<{ as: Tag }> &
  AstroLismBaseProps & {
    /** 吹き出しスタイル */
    variant?: 'speak' | 'think';
    /** 吹き出しの方向 */
    direction?: 'start' | 'end';
    /** 発言者名 */
    name?: string;
    /** アバター画像URL */
    avatar?: string;
    /** キーカラー */
    keycolor?: string;
    /** コンテンツのフロー間隔 */
    flow?: string;
  };

const { name, avatar, flow = 's', variant = 'speak', direction = 'start', class: className, ...props } = Astro.props;
---

<Grid class={atts(className, buildModifierClass('c--chat', { variant }))} keycolor="gray" data-chat-dir={direction} ji={direction} {...props}>
  {
    avatar && (
      <Frame class="c--chat_avatar" bgc="base" ar="1/1" bdrs="99" aria-hidden="true">
        <img src={avatar} alt="" width="60" height="60" decoding="async" />
      </Frame>
    )
  }
  {
    name && (
      <Lism class="c--chat_name" c="text-2" fs="italic" fz="2xs" lh="1" py="5" px="10" aslf="end">
        {name}
      </Lism>
    )
  }
  <Lism class="c--chat_body" pos="relative">
    <Decorator class="c--chat_deco" util="cbox" isSkipFlow pos="absolute" />
    <Flow class="c--chat_content" util="cbox" bdrs="30" p="20" lh="s" flow={flow} jslf={direction}>
      <slot />
    </Flow>
  </Lism>
</Grid>
