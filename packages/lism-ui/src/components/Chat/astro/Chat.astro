---
/**
 * Chat コンポーネント（Astro版）
 * チャット形式の吹き出しUIを提供します。
 */
import { Lism, Flow, Grid, Frame, Decorator } from 'lism-css/astro';
import '../_style.css';

interface Props {
	/** 吹き出しスタイル */
	variant?: 'speak' | 'think';
	/** 吹き出しの方向 */
	direction?: 'start' | 'end';
	/** 発言者名 */
	name?: string;
	/** アバター画像URL */
	avatar?: string;
	/** キーカラー */
	keycolor?: string;
	/** コンテンツのフロー間隔 */
	flow?: string;
	[key: string]: unknown;
}

const { variant = 'speak', direction = 'start', name, avatar, keycolor = 'gray', flow = 's', ...props } = Astro.props;
---

<Grid lismClass='c--chat' variant={variant} keycolor={keycolor} data-chat-dir={direction} ji={direction} {...props}>
	{
		avatar && (
			<Frame lismClass='c--chat_avatar' src={avatar} alt='' bgc='base' ar='1/1' bdrs='99' aria-hidden='true'>
				<img src={avatar} alt='' width='60' height='60' decoding='async' />
			</Frame>
		)
	}
	{
		name && (
			<Lism lismClass='c--chat_name' c='text-2' fs='italic' fz='2xs' lh='1' py='5' px='10' aslf='end'>
				{name}
			</Lism>
		)
	}
	<Lism lismClass='c--chat_body' pos='rel'>
		<Decorator lismClass='c--chat_deco' class='u-cbox is--skipFlow' pos='abs' />
		<Flow lismClass='c--chat_content' class='u-cbox' bdrs='30' p='20' lh='s' flow={flow} jslf={direction}>
			<slot />
		</Flow>
	</Lism>
</Grid>
