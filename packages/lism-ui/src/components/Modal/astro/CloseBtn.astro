---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import type { IconOwnProps } from 'lism-css/react/atomic/Icon/getProps';
import { Lism, Icon } from 'lism-css/astro';

type Props<Tag extends HTMLTag = 'button'> = Polymorphic<{ as: Tag }> &
  AstroLismBaseProps & {
    modalId?: string;
    icon?: IconOwnProps['icon'];
    srText?: string;
  };

const { modalId = '', icon, srText = 'Close', ...props } = Astro.props;
---

{
  Astro.slots.has('default') ? (
    <Lism as="button" set="plain" hov="-o" d="inline-flex" data-modal-close={modalId} {...props}>
      <slot />
    </Lism>
  ) : (
    <Lism as="button" set="plain" hov="-o" d="inline-flex" data-modal-close={modalId} {...props}>
      <Icon icon={icon || 'x'} />
      <span class="u--srOnly">{srText || 'Close'}</span>
    </Lism>
  )
}
