---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Lism, Icon } from 'lism-css/astro';
import type { IconProps } from 'lism-css/react';
import { getCloseBtnProps } from '../getProps';

type Props<Tag extends HTMLTag = 'button'> = Polymorphic<{ as: Tag }> &
  AstroLismBaseProps & {
    modalId?: string;
    icon?: IconProps['icon'];
    srText?: string;
  };

const { as: asTag = 'button' as HTMLTag, modalId = '', icon, srText = 'Close', ...restProps } = Astro.props;
const { as: _as, ...btnProps } = getCloseBtnProps(restProps as Record<string, unknown>);
---

{
  Astro.slots.has('default') ? (
    <Lism as={asTag} data-modal-close={modalId} {...(btnProps as Record<string, unknown>)}>
      <slot />
    </Lism>
  ) : (
    <Lism as={asTag} data-modal-close={modalId} {...(btnProps as Record<string, unknown>)}>
      <Icon icon={icon || 'x'} />
      <span class="u--srOnly">{srText || 'Close'}</span>
    </Lism>
  )
}
