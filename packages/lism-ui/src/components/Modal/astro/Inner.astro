---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';
import { getInnerProps, type ModalInnerProps } from '../getProps';

type Props<Tag extends HTMLTag = 'div'> = Polymorphic<{ as: Tag }> & AstroLismBaseProps & ModalInnerProps;

const { as: asTag = 'div' as HTMLTag, ...restProps } = Astro.props;
const innerProps = getInnerProps(restProps as ModalInnerProps);
---

<Lism as={asTag} {...innerProps as Record<string, unknown>}>
  <slot />
</Lism>
