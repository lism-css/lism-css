---
import { Lism } from 'lism-css/astro';
import atts from 'lism-css/lib/helper/atts';

const { class: className, offset, style, ...props } = Astro.props || {};
const mergedStyle = offset ? { ...style, '--offset': offset } : style;
---

<Lism class={atts(className, 'c--modal_inner')} style={mergedStyle} {...props}><slot /></Lism>
