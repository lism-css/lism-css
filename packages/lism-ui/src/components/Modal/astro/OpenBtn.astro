---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';
import { getOpenBtnProps } from '../getProps';

type Props<Tag extends HTMLTag = 'button'> = Polymorphic<{ as: Tag }> &
  AstroLismBaseProps & {
    modalId?: string;
  };

const { as: asTag = 'button' as HTMLTag, modalId = '', ...restProps } = Astro.props;
const { as: _as, ...openBtnProps } = getOpenBtnProps(restProps as Record<string, unknown>);
---

<Lism as={asTag} data-modal-open={modalId} {...openBtnProps as Record<string, unknown>}>
  <slot />
</Lism>
