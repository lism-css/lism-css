---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from 'lism-css/astro';
import { Lism } from 'lism-css/astro';
import { getProps, type ModalRootProps } from '../getProps';
import '../_style.css';

type Props<Tag extends HTMLTag = 'dialog'> = Polymorphic<{ as: Tag }> & AstroLismBaseProps & ModalRootProps;

const { as: asTag = 'dialog' as HTMLTag, ...restProps } = Astro.props;
const { as: _as, ...modalProps } = getProps(restProps as ModalRootProps);
---

<Lism as={asTag} {...modalProps as Record<string, unknown>}>
  <slot />
</Lism>

<script>
  import setModal from '../setModal';
  setModal();
</script>
