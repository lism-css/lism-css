{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist",
    "declaration": true,
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@templates/*": ["../../templates/*"]
    }
  },
  "include": ["src", "tsup.config.ts", "vitest.config.ts", "../../templates/manifest.ts"]
}
