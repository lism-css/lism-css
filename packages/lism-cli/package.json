{
  "name": "@lism-css/cli",
  "version": "0.1.3",
  "description": "CLI for adding Lism UI components to your project",
  "type": "module",
  "bin": {
    "lism": "./bin/lism.mjs",
    "lism-ui": "./bin/cli.mjs"
  },
  "files": [
    "dist",
    "bin",
    "skills"
  ],
  "scripts": {
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "build": "tsup && rm -rf skills && cp -r ../../skills ./skills",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "commander": "^13.0.0",
    "giget": "^3.2.0",
    "jiti": "^2.6.1",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
