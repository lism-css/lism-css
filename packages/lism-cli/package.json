{
  "name": "@lism-css/cli",
  "version": "0.2.0-beta.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "CLI for adding Lism UI components to your project",
  "type": "module",
  "bin": {
    "lism": "./bin/lism.mjs"
  },
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "default": "./dist/lib.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "commander": "^13.0.0",
    "giget": "^3.2.0",
    "jiti": "^2.6.1",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
