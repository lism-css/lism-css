        },
        {
          "prop": "hl",
          "cssProperty": "--hl (CSS変数)",
          "type": "string | array",
          "responsive": true,
          "description": "見出し用の行間を制御するCSS変数。",
          "values": ["base", "xs", "s", "l"]
        },
        {
          "prop": "lts",
          "cssProperty": "letter-spacing",
          "type": "string",
          "responsive": false,
          "description": "文字間隔。",
          "values": ["base", "s", "l"]
