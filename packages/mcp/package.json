{
  "name": "@lism-css/mcp",
  "version": "0.3.0",
  "description": "MCP server for lism-css documentation and API reference.",
  "type": "module",
  "bin": {
    "mcp": "./bin/lism-mcp.mjs"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "build": "tsc -p tsconfig.build.json && cp src/data/*.json dist/data/",
    "dev": "tsc --watch",
    "test": "vitest run",
    "prepack": "case \"$npm_execpath\" in *pnpm*) ;; *) echo 'Error: Use pnpm publish' && exit 1;; esac"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0"
  },
  "license": "MIT"
}
