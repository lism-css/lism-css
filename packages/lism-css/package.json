{
	"name": "lism-css",
	"version": "0.8.3",
	"description": "A layout-first CSS framework for websites.",
	"author": {
		"name": "ddryo",
		"url": "https://github.com/ddryo"
	},
	"license": "MIT",
	"keywords": [
		"css-framework",
		"astro-component",
		"react-component"
	],
	"scripts": {
		"dev": "vite",
		"test": "pnpm typecheck && pnpm vitest",
		"vitest": "vitest run",
		"typecheck": "tsc --noEmit",
		"build": "pnpm build:js && pnpm build:css",
		"build:js": "vite build && pnpm exec tsc -p config/tsconfig.json",
		"build:css": "tsx bin/script-build-css.js",
		"lint": "pnpm lint:eslint && pnpm lint:style",
		"lint:eslint": "eslint '**/*.{js,mjs,ts,tsx}'",
		"lint:style": "stylelint '**/*.{css,scss}'",
		"preview": "vite preview",
		"prepack": "case \"$npm_execpath\" in *pnpm*) ;; *) echo 'Error: Use pnpm publish' && exit 1;; esac"
	},
	"bin": {
		"lism-css": "./bin/cli.mjs"
	},
	"files": [
		"dist",
		"config",
		"config.js",
		"config.d.ts",
		"vite-plugin.js",
		"bin",
		"packages",
		"src/scss"
	],
	"type": "module",
	"main": "./dist/index.js",
	"exports": {
		".": "./dist/index.js",
		"./config.js": "./config.js",
		"./config": {
			"import": "./config/index.js",
			"types": "./dist/config/index.d.ts"
		},
		"./default-config": {
			"import": "./config/default-config.js",
			"types": "./dist/config/default-config.d.ts"
		},
		"./vite-plugin": "./vite-plugin.mjs",
		"./lib/*": {
			"import": "./dist/lib/*",
			"types": "./dist/lib/*.d.ts"
		},
		"./bin/*": "./bin/*",
		"./react": {
			"import": "./dist/components/index.js",
			"types": "./dist/components/index.d.ts"
		},
		"./react/*": {
			"import": "./dist/components/*.js",
			"types": "./dist/components/*.d.ts"
		},
		"./next-js/*": "./packages/next-js/*",
		"./astro": {
			"import": "./packages/astro/index.js",
			"types": "./packages/types/index.d.ts"
		},
		"./astro/*": "./packages/astro/*",
		"./scss/*": "./src/scss/*",
		"./*.css": "./dist/css/*.css"
	},
	"homepage": "https://www.lism.style",
	"repository": {
		"type": "git",
		"url": "https://github.com/lism-css/lism-css/tree/main/packages/lism-css"
	},
	"bugs": {
		"url": "https://github.com/lism-css/lism-css/issues"
	},
	"devDependencies": {
		"@babel/cli": "^7.27.2",
		"@babel/core": "^7.27.3",
		"@babel/preset-env": "^7.27.2",
		"@babel/preset-react": "^7.27.1",
		"@rollup/plugin-babel": "^6.0.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.1",
		"@types/node": "^25.0.3",
		"@vitejs/plugin-react-swc": "^3.10.0",
		"glob": "^11.0.2",
		"jsdom": "^27.4.0",
		"rollup": "^4.41.1",
		"tsx": "^4.21.0",
		"typescript": "~5.8.3",
		"unplugin-dts": "1.0.0-beta.6",
		"vite": "^6.3.5",
		"vitest": "^4.0.16"
	},
	"peerDependencies": {
		"@types/react": "*",
		"@types/react-dom": "*",
		"react": "^18 || ^19",
		"react-dom": "^18 || ^19"
	},
	"sideEffects": false
}
