{
  "name": "lism-css",
  "version": "0.15.0",
  "description": "Lism CSS is a layout-first CSS framework for websites.",
  "author": {
    "name": "ddryo",
    "url": "https://github.com/ddryo"
  },
  "license": "MIT",
  "keywords": [
    "css-framework",
    "astro-component",
    "react-component"
  ],
  "scripts": {
    "dev": "vite",
    "test": "pnpm vitest",
    "vitest": "vitest run",
    "typecheck": "tsc --noEmit && astro check --tsconfig packages/astro/tsconfig.json",
    "build": "pnpm build:js && pnpm build:css",
    "build:js": "vite build && pnpm exec tsc -p config/tsconfig.json",
    "build:css": "tsx bin/script-build-css.js",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "lint": "pnpm lint:eslint && pnpm lint:style",
    "lint:eslint": "eslint '**/*.{js,mjs,ts,tsx,astro}'",
    "lint:style": "stylelint '**/*.{css,scss}'",
    "preview": "vite preview",
    "prepack": "case \"$npm_execpath\" in *pnpm*) ;; *) echo 'Error: Use pnpm publish' && exit 1;; esac"
  },
  "bin": {
    "lism-css": "./bin/cli.mjs"
  },
  "files": [
    "dist",
    "config",
    "config.js",
    "config.d.ts",
    "vite-plugin.js",
    "bin",
    "packages",
    "src/scss"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./config.js": "./config.js",
    "./config": {
      "import": "./config/index.js",
      "types": "./dist/config/index.d.ts"
    },
    "./default-config": {
      "import": "./config/default-config.js",
      "types": "./dist/config/default-config.d.ts"
    },
    "./vite-plugin": "./vite-plugin.mjs",
    "./lib/*": {
      "import": "./dist/lib/*",
      "types": "./dist/lib/*.d.ts"
    },
    "./bin/*": "./bin/*",
    "./react": {
      "import": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    },
    "./react/*": {
      "import": "./dist/components/*.js",
      "types": "./dist/components/*.d.ts"
    },
    "./next-js/*": "./packages/next-js/*",
    "./astro": {
      "import": "./packages/astro/index.ts"
    },
    "./astro/*": "./packages/astro/*",
    "./scss/*": "./src/scss/*",
    "./*.css": "./dist/css/*.css"
  },
  "homepage": "https://lism-css.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/lism-css/lism-css/tree/main/packages/lism-css"
  },
  "bugs": {
    "url": "https://github.com/lism-css/lism-css/issues"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@rollup/plugin-babel": "^6.1.0",
    "@storybook/react-vite": "^10.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "astro": "^6.1.1",
    "eslint": "^9.39.4",
    "glob": "^13.0.6",
    "jsdom": "^27.4.0",
    "lucide-react": "^0.577.0",
    "rollup": "^4.59.0",
    "stylelint": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "unplugin-dts": "1.0.0-beta.6",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "csstype": "^3.2.3"
  },
  "peerDependencies": {
    "@types/react": "*",
    "@types/react-dom": "*",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "sideEffects": false
}
