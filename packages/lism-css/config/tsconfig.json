{
	"extends": "../tsconfig.json",
	"compilerOptions": {
		"allowJs": false,
		"declaration": true,
		"declarationMap": false,
		"declarationDir": "../dist/config",
		"emitDeclarationOnly": false,
		"outDir": "../dist/config",
		"rootDir": ".",
		"composite": false,
		"baseUrl": "..",
		"incremental": false
	},
	"include": [
		"./**/*.ts"
	],
	"exclude": [
		"**/*.test.ts"
	]
}