---
import type { Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from '../types';
import Lism from '../Lism/Lism.astro';

type GroupAllowedTag = 'div' | 'section' | 'article' | 'figure' | 'nav' | 'aside' | 'header' | 'footer' | 'main' | 'fieldset' | 'hgroup';
type Props<Tag extends GroupAllowedTag = 'div'> = Polymorphic<{ as: Tag }> & AstroLismBaseProps;

const { as: Tag = 'div', ...props } = Astro.props;
---

<Lism as={Tag} {...props}><slot /></Lism>
