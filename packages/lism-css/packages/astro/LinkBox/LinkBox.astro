---
import type { AstroLismBaseProps } from '../types';
import { Lism } from '../Lism';

type Props = astroHTML.JSX.AnchorHTMLAttributes & AstroLismBaseProps;

const { exProps, ...props } = Astro.props;

const hasHref = !!props.href;
const tag = hasHref ? 'a' : 'div';
---

<Lism isLinkBox as={tag} {...props} {...exProps}>
	<slot />
</Lism>
