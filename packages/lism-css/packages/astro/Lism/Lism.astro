---
import type { ElementType } from 'react';
import type { LismComponentProps } from '../../../src/components/Lism/Lism';
import getLismProps from '../../../src/lib/getLismProps';

type Props = LismComponentProps<ElementType>;

const { as, exProps, ...props } = Astro.props || {};
const JSX = as || 'div';
---

<JSX {...getLismProps(props)} {...exProps}>
	<slot />
</JSX>
