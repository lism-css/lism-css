---
import type { Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from '../types';
import type { ListAllowedTag } from 'lism-css/lib/types/allowedTags';
import Lism from '../Lism/Lism.astro';

type Props<Tag extends ListAllowedTag = 'ul'> = Polymorphic<{ as: Tag }> & AstroLismBaseProps;

const { as: Tag = 'ul', ...props } = Astro.props;
---

<Lism as={Tag} {...props}><slot /></Lism>
