---
import type { Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from '../types';
import type { ListItemAllowedTag } from 'lism-css/lib/types/allowedTags';
import Lism from '../Lism/Lism.astro';

type Props<Tag extends ListItemAllowedTag = 'li'> = Polymorphic<{ as: Tag }> & AstroLismBaseProps;

const { as: Tag = 'li', ...props } = Astro.props;
---

<Lism as={Tag} {...props}><slot /></Lism>
