---
import type { AstroLismBaseProps } from '../types';
import Lism from '../Lism/Lism.astro';

type SpanAttrs = Omit<astroHTML.JSX.HTMLAttributes, keyof AstroLismBaseProps>;
interface Props extends AstroLismBaseProps, SpanAttrs {}

const props = Astro.props;
---

<Lism as='span' {...props}><slot /></Lism>
