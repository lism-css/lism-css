---
import type { AstroLismBaseProps } from '../types';
import Lism from '../Lism/Lism.astro';

type ButtonAttrs = Omit<astroHTML.JSX.ButtonHTMLAttributes, keyof AstroLismBaseProps>;
interface Props extends AstroLismBaseProps, ButtonAttrs {}

const props = Astro.props;
---

<Lism as='button' {...props}><slot /></Lism>
