---
import type { AstroLismBaseProps } from '../types';
import Lism from '../Lism/Lism.astro';

type ImgAttrs = Omit<astroHTML.JSX.ImgHTMLAttributes, keyof AstroLismBaseProps>;
interface Props extends AstroLismBaseProps, ImgAttrs {}

const props = Astro.props;
---

<Lism as='img' {...props}><slot /></Lism>
