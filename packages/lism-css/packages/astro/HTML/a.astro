---
import type { AstroLismBaseProps } from '../types';
import Lism from '../Lism/Lism.astro';

type AnchorAttrs = Omit<astroHTML.JSX.AnchorHTMLAttributes, keyof AstroLismBaseProps>;
interface Props extends AstroLismBaseProps, AnchorAttrs {}

const props = Astro.props;
---

<Lism as='a' {...props}><slot /></Lism>
