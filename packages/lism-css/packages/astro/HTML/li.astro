---
import type { AstroLismBaseProps } from '../types';
import Lism from '../Lism/Lism.astro';

type LiAttrs = Omit<astroHTML.JSX.LiHTMLAttributes, keyof AstroLismBaseProps>;
interface Props extends AstroLismBaseProps, LiAttrs {}

const props = Astro.props;
---

<Lism as='li' {...props}><slot /></Lism>
