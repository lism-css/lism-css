---
import type { AstroLismBaseProps } from '../types';
import Lism from '../Lism/Lism.astro';

type UlAttrs = Omit<astroHTML.JSX.HTMLAttributes, keyof AstroLismBaseProps>;
interface Props extends AstroLismBaseProps, UlAttrs {}

const props = Astro.props;
---

<Lism as='ul' {...props}><slot /></Lism>
