---
import type { AstroLismBaseProps } from '../types';
import Lism from '../Lism/Lism.astro';

type HAttrs = Omit<astroHTML.JSX.HTMLAttributes, keyof AstroLismBaseProps>;
interface Props extends AstroLismBaseProps, HAttrs {
	lv?: '1' | '2' | '3' | '4' | '5' | '6';
}

const { lv = '1', ...props } = Astro.props;
---

<Lism as={`h${lv}`} {...props}><slot /></Lism>
