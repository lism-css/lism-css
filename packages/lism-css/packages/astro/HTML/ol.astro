---
import type { AstroLismBaseProps } from '../types';
import Lism from '../Lism/Lism.astro';

type OlAttrs = Omit<astroHTML.JSX.OlHTMLAttributes, keyof AstroLismBaseProps>;
interface Props extends AstroLismBaseProps, OlAttrs {}

const props = Astro.props;
---

<Lism as='ol' {...props}><slot /></Lism>
