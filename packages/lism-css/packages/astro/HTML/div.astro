---
import type { AstroLismBaseProps } from '../types';
import Lism from '../Lism/Lism.astro';

type DivAttrs = Omit<astroHTML.JSX.HTMLAttributes, keyof AstroLismBaseProps>;
interface Props extends AstroLismBaseProps, DivAttrs {}

const props = Astro.props;
---

<Lism as='div' {...props}><slot /></Lism>
