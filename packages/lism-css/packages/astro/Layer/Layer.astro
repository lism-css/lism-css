---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from '../types';
import { Lism } from '../Lism';
import getFilterProps, { type FilterProps } from 'lism-css/react/getFilterProps';

type Props<Tag extends HTMLTag = 'div'> = Polymorphic<{ as: Tag }> & AstroLismBaseProps & FilterProps;

const { as: Tag = 'div', exProps, ...props } = Astro.props;
---

<Lism isLayer as={Tag} {...getFilterProps(props, 'backdropFilter')} {...exProps}><slot /></Lism>
