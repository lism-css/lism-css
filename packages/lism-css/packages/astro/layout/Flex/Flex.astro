---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroFlexProps } from './types';
import { Lism } from '../../Lism';

type Props<Tag extends HTMLTag = 'div'> = Polymorphic<{ as: Tag }> & AstroFlexProps;

const props = Astro.props;
---

<Lism layout="flex" {...props}><slot /></Lism>
