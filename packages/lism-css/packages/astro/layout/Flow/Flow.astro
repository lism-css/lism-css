---
import type { HTMLTag, Polymorphic } from 'astro/types';
import type { AstroFlowProps } from './types';
import { Lism } from '../../Lism';

type Props<Tag extends HTMLTag = 'div'> = Polymorphic<{ as: Tag }> & AstroFlowProps;

const props = Astro.props;
---

<Lism layout="flow" {...props}><slot /></Lism>
