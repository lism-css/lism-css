---
import type { ElementType } from 'react';
import type { MediaProps } from '../../../src/components/atomic/Media/getProps';
import getLismProps from '../../../src/lib/getLismProps';
import getMediaProps from '../../../src/components/atomic/Media/getProps';
import { Image } from 'astro:assets';

type Props = MediaProps & astroHTML.JSX.ImgHTMLAttributes & { as?: ElementType };

const { as, exProps, ...props } = Astro.props || {};

let JSX: any = as || 'img';
if (JSX === 'AstroImage') {
	JSX = Image;
}
---

<JSX {...getLismProps(getMediaProps(props))} {...exProps}>
	<slot />
</JSX>
