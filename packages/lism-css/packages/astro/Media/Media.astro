---
import type { Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from '../types';
import type { MediaAllowedTag } from 'lism-css/lib/types/allowedTags';
import getLismProps from 'lism-css/lib/getLismProps';
import { Image, Picture } from 'astro:assets';

type Props<Tag extends MediaAllowedTag = 'img'> = Polymorphic<{ as: Tag }> & AstroLismBaseProps;

const { as: Tag = 'img', exProps, ...props } = Astro.props;

// as="img"（デフォルト）→ Astro <Image />, as="picture" → Astro <Picture />
// as="video" / "iframe" 等はそのまま HTML タグとして出力
let JSX: any = Tag;
if (Tag === 'img') {
  JSX = Image;
} else if (Tag === 'picture') {
  JSX = Picture;
}
---

<JSX {...getLismProps(props)} {...exProps}><slot /></JSX>
