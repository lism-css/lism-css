---
import type { AstroLismBaseProps } from '../types';
import type { MediaAllowedTag } from 'lism-css/lib/types/allowedTags';
import getLismProps from 'lism-css/lib/getLismProps';
import { Image } from 'astro:assets';

type MediaProps<Tag extends MediaAllowedTag | 'AstroImage'> = Tag extends 'video'
  ? astroHTML.JSX.VideoHTMLAttributes
  : Tag extends 'iframe'
    ? astroHTML.JSX.IframeHTMLAttributes
    : Tag extends 'picture'
      ? astroHTML.JSX.HTMLAttributes
      : astroHTML.JSX.ImgHTMLAttributes;

type Props<Tag extends MediaAllowedTag | 'AstroImage' = 'img'> = AstroLismBaseProps & MediaProps<Tag> & { as?: Tag };

const { as, exProps, ...props } = Astro.props;

let JSX: any = as || 'img';
if (JSX === 'AstroImage') {
  JSX = Image;
}
---

<JSX {...getLismProps(props)} {...exProps}><slot /></JSX>
