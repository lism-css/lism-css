---
import type { AstroLismBaseProps } from '../types';
import getLismProps from 'lism-css/lib/getLismProps';
import { Image } from 'astro:assets';

type MediaAllowedTag = 'img' | 'video' | 'iframe' | 'picture' | 'AstroImage';
type Props = AstroLismBaseProps & astroHTML.JSX.ImgHTMLAttributes & { as?: MediaAllowedTag };

const { as, exProps, ...props } = Astro.props;

let JSX: any = as || 'img';
if (JSX === 'AstroImage') {
  JSX = Image;
}
---

<JSX {...getLismProps(props)} {...exProps}><slot /></JSX>
