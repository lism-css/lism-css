---
import type { LismComponentProps } from '../../../dist/components/Lism/Lism';
import getLismProps from '../../../dist/lib/getLismProps';
import getMediaProps from '../../../dist/components/atomic/Media/getProps';
import { Image } from 'astro:assets';

type Props = LismComponentProps;

const { as, exProps, ...props } = Astro.props || {};

let JSX = as || 'img';
if (JSX === 'AstroImage') {
	JSX = Image;
}
---

<JSX {...getLismProps(getMediaProps(props))} {...exProps}>
	<slot />
</JSX>
