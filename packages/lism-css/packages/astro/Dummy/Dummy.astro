 */
import { Lism } from '../Lism';

const { lang = 'en', ...props } = Astro.props;
const message =
  lang === 'ja'
    ? 'Lorem ipsum dolor sit amet... ⚠️Dummy は非推奨コンポーネントです。@lism-css/ui のDummyTextをご利用ください'
