---
import type { HTMLTag } from 'astro/types';
import type { AstroLismBaseProps } from '../types';
import { Lism } from '../Lism';
import getContent from 'lism-css/react/Dummy/getContent';

type DummyAttrs = Omit<astroHTML.JSX.HTMLAttributes, keyof AstroLismBaseProps>;
interface Props extends AstroLismBaseProps, DummyAttrs {
	as?: HTMLTag;
	pre?: string;
	length?: string;
	lang?: 'ja' | 'en' | 'ar';
	offset?: number;
}

const { as: tagName = 'p', pre = '', length = 'm', lang = 'en', offset = 0, ...props } = Astro.props;
const content = getContent({ tag: tagName, pre, lang, length, offset });
---

{tagName === 'img' && <Lism as='img' src='https://cdn.lism-css.com/dummy-image.jpg' width='600' height='400' alt='' {...props} />}
{tagName !== 'img' && <Lism as={tagName} {...props} set:html={content} />}
