---
import type { Polymorphic } from 'astro/types';
import type { AstroLismBaseProps } from '../types';
import type { InlineAllowedTag } from 'lism-css/lib/types/allowedTags';
import Lism from '../Lism/Lism.astro';

type Props<Tag extends InlineAllowedTag = 'span'> = Polymorphic<{ as: Tag }> & AstroLismBaseProps;

const { as: Tag = 'span', ...props } = Astro.props;
---

<Lism as={Tag} {...props}><slot /></Lism>
