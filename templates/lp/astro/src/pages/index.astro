---
import Layout from '@/layouts/Layout.astro';
import { Lism, Stack, Center, Grid, Heading, Link, Text, BoxLink, Frame } from 'lism-css/astro';
import corporateThumb from '../../screenshots/corporate.png';
import naturalThumb from '../../screenshots/natural.png';
import ryokanThumb from '../../screenshots/ryokan.png';

const variants = [
  {
    slug: 'corporate',
    title: 'Corporate LP',
    description: 'コーポレートサイト向けの1ページ構成ランディングページ。',
    thumb: corporateThumb,
  },
  {
    slug: 'natural',
    title: 'Simple Natural LP',
    description: 'ナチュラルで親しみやすいデザインのランディングページ。',
    thumb: naturalThumb,
  },
  {
    slug: 'ryokan',
    title: 'Japanese Ryokan LP',
    description: '和の趣ある旅館サイト向けランディングページ。',
    thumb: ryokanThumb,
  },
];
---

<Layout title="Lism CSS - LP Templates">
  <Stack min-h="100svh">
    <Center as="header" isContainer hasGutter py="40">
      <Stack ai="center" g="10">
        <Heading level="1" ff="accent" fw="normal" ta="center" fz="4xl" m="0">LP Templates</Heading>
        <Text ta="center" c="text-2" fz="s" m="0"> Lism CSS で構築したLPテンプレート集 </Text>
      </Stack>
    </Center>

    <Lism as="section" isContainer hasGutter fxg="1" py="20">
      <Grid gtc={['1fr', null, 'repeat(3, 1fr)']} g="30">
        {
          variants.map(({ slug, title, description, thumb }) => (
            <BoxLink href={`/${slug}/`} layout="stack" g="15" set="var:hov" bdrs="20" ov="clip" bgc="base">
              <Frame ar="16/10" ov="hidden">
                <img src={thumb.src} alt={`${title} のサムネイル`} loading="lazy" />
              </Frame>
              <Stack g="5" px="20" py="15">
                <Heading level="2" fz="l" fw="600" lts="l" m="0">
                  {title}
                </Heading>
                <Text fz="s" c="text-2" m="0">
                  {description}
                </Text>
              </Stack>
            </BoxLink>
          ))
        }
      </Grid>
    </Lism>

    <Lism as="footer" isContainer hasGutter py="40">
      <Center>
        <Text ta="center" c="text-2" fz="xs">
          LP templates for <Link href="https://lism-css.com/">Lism CSS</Link>
        </Text>
      </Center>
    </Lism>
  </Stack>
</Layout>
