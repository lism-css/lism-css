---
import Layout from '@/layouts/Layout.astro';
import { Lism, Stack, Center, Grid, Heading, Link, Text, BoxLink, Frame } from 'lism-css/astro';
import type { ImageMetadata } from 'astro';

// 英語版 LP のサムネは en スクショ（screenshots/en/*.png）を優先し、未撮影なら ja を流用する。
// （この一覧ページはテンプレのプレビュー専用で、lism create の生成プロジェクトには含まれない）
const enThumbs = import.meta.glob<ImageMetadata>('../../../screenshots/en/*.png', { eager: true, import: 'default' });
const jaThumbs = import.meta.glob<ImageMetadata>('../../../screenshots/*.png', { eager: true, import: 'default' });
const thumbFor = (slug: string): ImageMetadata => enThumbs[`../../../screenshots/en/${slug}.png`] ?? jaThumbs[`../../../screenshots/${slug}.png`];

const variants = [
  {
    slug: 'corporate',
    title: 'LP Corporate',
    description: 'A single-page landing page for corporate sites.',
    thumb: thumbFor('corporate'),
  },
  {
    slug: 'interior',
    title: 'LP Interior',
    description: 'A landing page for interior and lifestyle coordination services.',
    thumb: thumbFor('interior'),
  },
];
---

<Layout title="Lism CSS - LP Templates" lang="en">
  <Stack min-h="100svh">
    <Center as="header" isContainer hasGutter py="40">
      <Stack ai="center" g="10">
        <Heading level="1" ff="accent" fw="normal" ta="center" fz="4xl" m="0">LP Templates</Heading>
        <Text ta="center" c="text-2" fz="s" m="0"> A collection of LP templates built with Lism CSS </Text>
      </Stack>
    </Center>

    <Lism as="section" isContainer hasGutter fxg="1" py="20">
      <Grid gtc={['1fr', null, 'repeat(3, 1fr)']} g="30">
        {
          variants.map(({ slug, title, description, thumb }) => (
            <BoxLink href={`/en/${slug}/`} layout="stack" g="15" set="hov" bdrs="20" ov="clip" bgc="base">
              <Frame ar="16/10" ov="hidden">
                <img src={thumb.src} alt={`${title} thumbnail`} loading="lazy" />
              </Frame>
              <Stack g="5" px="20" py="15">
                <Heading level="2" fz="l" fw="600" lts="l" m="0">
                  {title}
                </Heading>
                <Text fz="s" c="text-2" m="0">
                  {description}
                </Text>
              </Stack>
            </BoxLink>
          ))
        }
      </Grid>
    </Lism>

    <Lism as="footer" isContainer hasGutter py="40">
      <Center>
        <Text ta="center" c="text-2" fz="xs">
          LP templates for <Link href="https://lism-css.com/en/">Lism CSS</Link>
        </Text>
      </Center>
    </Lism>
  </Stack>
</Layout>
