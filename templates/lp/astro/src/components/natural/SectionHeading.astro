---
/**
 * セクション見出し。
 * 英語タイトル（大、`ff="accent"`）＋ 日本語サブタイトル（中・太字）の 2 段構成。
 * 黒文字背景（base/base-2）と白文字背景（contact）の両方で使うため、`c` props で色を切り替える。
 */
import { Heading, Stack, Text } from 'lism-css/astro';

interface Props {
  en: string;
  ja: string;
  level?: '1' | '2' | '3' | '4' | '5' | '6';
  c?: string;
}

const { en, ja, level = '2', c = 'text' } = Astro.props;
---

<Stack g="10" ai="center">
  <Heading level={level} fz="4xl" lts="l" m="0" ta="center" c={c} ff="accent">{en}</Heading>
  <Text as="p" fz="m" fw="bold" lts="l" m="0" c={c} o="p" ta="center">{ja}</Text>
</Stack>
