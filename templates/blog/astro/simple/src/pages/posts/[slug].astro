---
import { getCollection, render } from 'astro:content';
import { Group, Flow, Stack, Cluster, WithSide, Heading } from 'lism-css/astro';
import Layout from '@/layouts/Layout.astro';
import ArticleNav from '@/components/ArticleNav.astro';
import ShareButtons from '@/components/ShareButtons.astro';
import Date from '@/components/Date.astro';
import Tag from '@/components/Tag.astro';
import { siteConfig } from '@/config/site';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).sort((a, b) => b.data.date.localeCompare(a.data.date));
  return posts.map((post, index) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: posts[index - 1], // 表示順で「新しい記事」が prev に来る
      next: posts[index + 1],
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} — ${siteConfig.name}`} description={post.data.excerpt}>
  <Group isWrapper isContainer hasGutter>
    {/* 記事ヘッダー */}
    <Group as="header">
      <Heading level="1">
        {post.data.title}
      </Heading>
      <Cluster g="15" mbs="30">
        <Date>{post.data.date}</Date>
        {
          post.data.tags.length > 0 && (
            <Cluster g="5" ai="center">
              <span class="-c:text-2 -fz:2xs" aria-hidden="true">
                #
              </span>
              {post.data.tags.map((tag) => (
                <Tag href={`/tag/${tag}/`}>{tag}</Tag>
              ))}
            </Cluster>
          )
        }
      </Cluster>
    </Group>

    <Flow as="article" class="c--articleBody" mbs="50">
      <Content />
    </Flow>

    {/* フッター（シェアボタン → 前後記事ナビ） */}
    <Group as="footer" mbs="60">
      <Group py="30" bd-y>
        <ShareButtons title={post.data.title} />
      </Group>
      <Group py="30">
        <ArticleNav
          prev={prev ? { title: prev.data.title, slug: prev.id } : undefined}
          next={next ? { title: next.data.title, slug: next.id } : undefined}
        />
      </Group>
    </Group>
  </Group>
</Layout>
