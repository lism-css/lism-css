---
// 画面下部に固定した目次ボタン + 目次モーダルのシェル。
// 中身（目次本体）は <slot /> で受け取るので、このコンポーネントは目次の構造を知らない。
import { Container, Center, Inline, Icon } from 'lism-css/astro';
import { Modal } from '@lism-css/ui/astro/Modal';
---

{/* md 未満でのみ表示する、画面右下固定の目次ボタン */}
<Container>
  <Center d={['grid', null, 'none']} pos="fixed" b="0" r="0" z="99">
    <Modal.OpenBtn
      modalId="toc-modal"
      class="c--fixedTocBtn l--center"
      d={null}
      bd
      bgc="base-2"
      c="brand"
      bdrs="20"
      p="15"
      m="20"
      g="3px"
      bxsh="30"
      ar="1/1"
      hasTransition
      hov={{ bgc: 'base' }}
      aria-labelledby="toc-open-label"
    >
      <Icon viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" fz="l">
        <line x1="8" y1="6" x2="21" y2="6"></line>
        <line x1="8" y1="12" x2="21" y2="12"></line>
        <line x1="8" y1="18" x2="21" y2="18"></line>
        <line x1="3" y1="6" x2="3.01" y2="6"></line>
        <line x1="3" y1="12" x2="3.01" y2="12"></line>
        <line x1="3" y1="18" x2="3.01" y2="18"></line>
      </Icon>
      <Inline fz="2xs" lh="xs">目次</Inline>
      <Inline d="none" id="toc-open-label">目次を開く</Inline>
    </Modal.OpenBtn>
  </Center>
</Container>

{/* 目次モーダル本体（中央表示・フェードイン。ボトムシートではない） */}
<Modal.Root id="toc-modal" isContainer isWrapper="s" py="40" px="30">
  <Modal.Inner layout="stack" g="20" w="100%" max-h="100%" pos="relative" py="20" bdrs="20" bxsh="40">
    <Modal.CloseBtn modalId="toc-modal" autofocus pos="absolute" t="0" r="0" z="1" fz="l" p="10" m="15" bdrs="10" bgc="base-2" />
    <Modal.Body layout="stack" g="20" py-s="30" px="20" ov-y="auto">
      <slot />
    </Modal.Body>
  </Modal.Inner>
</Modal.Root>

<script>
  // 目次リンクをタップしたらモーダルを閉じる（リンク先へのスクロールはそのまま実行される）
  const tocModal = document.getElementById('toc-modal');
  if (tocModal) {
    tocModal.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('[data-toc-link]')) {
        document.querySelector<HTMLElement>('[data-modal-close="toc-modal"]')?.click();
      }
    });
  }
</script>
