---
import { Lism, Link, Inline } from 'lism-css/astro';
import type { ComponentProps } from 'astro/types';

type LismProps = ComponentProps<typeof Lism>;

interface Item {
  label: string;
  href?: string;
  muted?: boolean;
}

type Props = LismProps & {
  items: Item[];
};

const { items, class: className, ...rest } = Astro.props;
---

<Lism as="nav" aria-label="パンくず" class:list={['c--breadcrumb', className]} {...rest}>
  {
    items.map((item, i) => (
      <Fragment>
        {i > 0 && <Inline aria-hidden="true">／ </Inline>}
        {item.href ? (
          <Link href={item.href} td="none" c="inherit" hov={{ c: 'brand' }}>
            {item.label}
          </Link>
        ) : (
          <Inline o="p" aria-current="page">
            {item.label}
          </Inline>
        )}
        {i < items.length - 1 && ' '}
      </Fragment>
    ))
  }
</Lism>
