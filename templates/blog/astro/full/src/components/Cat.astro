---
import { Inline, Link } from 'lism-css/astro';
import type { ComponentProps } from 'astro/types';

type LinkProps = ComponentProps<typeof Link>;

type Props = LinkProps & {
  href?: string;
};

const { href, class: className, ...rest } = Astro.props;

const Tag = href ? Link : Inline;
const linkProps = href ? { href, set: 'plain', hov: '-o,underline' } : {};
---

<Tag class:list={['c--cat', className]} ff="accent" fz="2xs" lts="l" c="brand" px="5" {...linkProps} {...rest}>
  <slot />
</Tag>
