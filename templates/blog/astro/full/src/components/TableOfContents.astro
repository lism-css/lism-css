---
import { Lism, List, Group } from 'lism-css/astro';
import type { TocItem } from '@/lib/generateToc';
import Eyebrow from '@/components/Eyebrow.astro';

interface Props {
  toc: TocItem[];
  // ラベル見出しの id。サイド版とモーダル版を同一ページに置くため、インスタンスごとに一意にする
  labelId?: string;
}

const { toc, labelId = 'toc-label' } = Astro.props;

// 目次リンク共通: Property Class / Trait に寄せ、ホバー・トランジションも Lism で統一する
const tocLinkCommon = {
  set: 'plain',
  d: 'block',
  py: '5',
  lh: 's',
  'bd-s': true,
  hasTransition: true,
  hov: { c: 'brand' },
  css: {
    '--duration': '0.2s',
    '--transitionProps': 'color, border-color',
  },
} as const;
---

<Lism as="nav" aria-labelledby={labelId}>
  <Eyebrow as="h2" id={labelId} class="c--toc_label" fw="normal" p="5" util="trim">Table of Contents</Eyebrow>
  <Group class="c--toc" bd-y py="20">
    <List as="ol" class="c--toc_list" ms="5">
      {
        toc.map((item) => (
          <li data-level={item.depth}>
            <Lism as="a" {...tocLinkCommon} href={`#${item.slug}`} data-toc-link={item.slug} fz="xs" ps="15">
              {item.text}
            </Lism>
            {item.children.length > 0 && (
              <ol class="c--toc_sublist">
                {item.children.map((child) => (
                  <li data-level={child.depth}>
                    <Lism as="a" {...tocLinkCommon} href={`#${child.slug}`} data-toc-link={child.slug} fz="2xs" fw="normal" ps="30" c="text-2">
                      {child.text}
                    </Lism>
                  </li>
                ))}
              </ol>
            )}
          </li>
        ))
      }
    </List>
  </Group>
</Lism>
<style>
  /* リストの list-style/padding リセットは lism-css のリセット層が
     `:is(ul,ol)[class]` に対して行うため、ネストした ol にも class を付けて任せる
     （class なしの ol は lism-css の非レイヤー規則で list-style:revert に戻され、レイヤー内の打ち消しが効かない） */
  /* スクロール連動のアクティブ表示（複数プロパティ切替・data-* のみ CSS に残す） */
  .c--toc_list [data-is-active] {
    color: var(--brand);
    font-weight: var(--fw--bold);
    border-inline-start-color: var(--brand);
  }
</style>

<script>
  // スクロール連動で目次のアクティブ状態を更新する
  // 「最後に上端を通過した見出し」を active にすることで、クリック遷移直後の表示と一致させる
  // 注: 目次はサイド版とモーダル版が同一ページに存在するため、tocLinks には同じ slug のリンクが
  //     複数含まれる。setActive は data-toc-link 一致で全リンクに反映されるので両方に効く。
  //     一方 headings は本文の見出し要素なので、id で重複排除して 1 見出し 1 エントリにする。
  const tocLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]'));
  const OFFSET = 80;

  if (tocLinks.length > 0) {
    const seenHeadingIds = new Set<string>();
    const headings = tocLinks
      .map((link) => {
        const slug = link.dataset.tocLink;
        return slug ? document.getElementById(slug) : null;
      })
      .filter((heading): heading is HTMLElement => heading !== null)
      .filter((heading) => {
        if (seenHeadingIds.has(heading.id)) return false;
        seenHeadingIds.add(heading.id);
        return true;
      });

    function setActive(slug: string) {
      tocLinks.forEach((link) => {
        if (link.dataset.tocLink === slug) {
          link.dataset.isActive = '';
          link.setAttribute('aria-current', 'location');
        } else {
          delete link.dataset.isActive;
          link.removeAttribute('aria-current');
        }
      });
    }

    function updateActive() {
      let current: HTMLElement | null = null;
      for (const heading of headings) {
        if (heading.getBoundingClientRect().top - OFFSET <= 0) {
          current = heading;
        } else {
          break;
        }
      }
      // 最初の見出しより上にいる場合でも、最初の項目を active にしておく
      setActive(current ? current.id : headings[0].id);
    }

    let ticking = false;
    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        updateActive();
        ticking = false;
      });
    }

    // クリック時は即座に active を切り替える（スクロール完了を待たない）
    tocLinks.forEach((link) => {
      link.addEventListener('click', () => {
        const slug = link.dataset.tocLink;
        if (slug) setActive(slug);
      });
    });

    if (headings.length > 0) {
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll);
      updateActive();
    }
  }
</script>
