---
import { getCollection } from 'astro:content';
import { Lism, List, ListItem, Heading, Link, Cluster } from 'lism-css/astro';
import ArchiveLayout from '@/layouts/ArchiveLayout.astro';
import { getArchiveSummaries, getArchiveHref } from '@/lib/archive';
import { siteConfig } from '@/config/site';

const posts = await getCollection('posts');
const summaries = getArchiveSummaries(posts);
---

<ArchiveLayout title={`Archive — ${siteConfig.name}`} description="年月別の記事一覧">
  <Heading level="1">Archive</Heading>

  <List bd-be>
    {
      summaries.map(({ year, month, count }) => (
        <ListItem bd-bs>
          <Link href={getArchiveHref(year, month)} set="plain" hov={{ c: 'brand' }} d="block" py="15" px="5">
            <Cluster jc="between" g="15">
              <Lism fw="500">
                {year}.{month}
              </Lism>
              <Lism fz="xs" c="text-2" lts="l">
                ({count})
              </Lism>
            </Cluster>
          </Link>
        </ListItem>
      ))
    }
  </List>
</ArchiveLayout>
