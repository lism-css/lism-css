---
import { Lism, Columns, Link, Stack, Inline } from 'lism-css/astro';
import Eyebrow from '@/components/Eyebrow.astro';

interface NavItem {
  title: string;
  id: string;
}

interface Props {
  prev?: NavItem;
  next?: NavItem;
}

const { prev, next } = Astro.props;
---

<Lism as="nav" aria-label="記事ナビゲーション">
  <Columns g="0">
    {
      prev ? (
        <Link href={`/posts/${prev.id}/`} set="plain" hov={{ c: 'brand' }} d="block">
          <Stack g="5" lh="s">
            <Eyebrow c="inherit">
              <Inline aria-hidden="true">←</Inline> PREVIOUS
            </Eyebrow>
            <Lism fz="s">{prev.title}</Lism>
          </Stack>
        </Link>
      ) : (
        <span />
      )
    }
    {
      next ? (
        <Link href={`/posts/${next.id}/`} set="plain" hov={{ c: 'brand' }} d="block" ta="right">
          <Stack g="5" lh="s">
            <Eyebrow c="inherit">
              NEXT <Inline aria-hidden="true">→</Inline>
            </Eyebrow>
            <Lism fz="s">{next.title}</Lism>
          </Stack>
        </Link>
      ) : (
        <span />
      )
    }
  </Columns>
</Lism>
