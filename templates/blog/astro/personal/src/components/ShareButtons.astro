---
import { Lism, Cluster } from 'lism-css/astro';
import Eyebrow from '@/components/Eyebrow.astro';
import ShareBtn from '@/components/ShareBtn.astro';
import { siteConfig } from '@/config/site';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<Lism class="c--share" data-share-title={title} data-share-copy-prompt={siteConfig.ui.share.copyPrompt}>
  <Cluster g="20">
    <Eyebrow>SHARE</Eyebrow>
    <Cluster g="10">
      <ShareBtn data-share-x aria-label={siteConfig.ui.share.x}>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
          ></path>
        </svg>
        <span>POST</span>
      </ShareBtn>
      <ShareBtn data-share-copy aria-label={siteConfig.ui.share.copy}>
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 0 0-7.07-7.07l-1 1"></path>
          <path d="M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 0 0 7.07 7.07l1-1"></path>
        </svg>
        <span data-share-copy-label>COPY</span>
      </ShareBtn>
    </Cluster>
  </Cluster>
</Lism>

<style>
  @layer lism-component {
    .c--shareBtn[data-is-copied] {
      color: var(--brand);
      --bdc: var(--brand);
    }
    .c--shareBtn svg {
      flex-shrink: 0;
    }
  }
</style>

<script>
  function initShare(root: HTMLElement) {
    const title = root.dataset.shareTitle ?? document.title;
    const copyPrompt = root.dataset.shareCopyPrompt ?? '';

    const xBtn = root.querySelector<HTMLButtonElement>('[data-share-x]');
    xBtn?.addEventListener('click', () => {
      const url = window.location.href;
      const intent = `https://x.com/intent/post?url=${encodeURIComponent(url)}&text=${encodeURIComponent(title)}`;
      window.open(intent, '_blank', 'noopener,noreferrer');
    });

    const copyBtn = root.querySelector<HTMLButtonElement>('[data-share-copy]');
    const copyLabel = root.querySelector<HTMLElement>('[data-share-copy-label]');
    copyBtn?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        copyBtn.dataset.isCopied = '';
        if (copyLabel) copyLabel.textContent = 'COPIED';
        window.setTimeout(() => {
          delete copyBtn.dataset.isCopied;
          if (copyLabel) copyLabel.textContent = 'COPY';
        }, 1800);
      } catch {
        window.prompt(copyPrompt, window.location.href);
      }
    });
  }

  document.querySelectorAll<HTMLElement>('.c--share').forEach(initShare);
</script>
