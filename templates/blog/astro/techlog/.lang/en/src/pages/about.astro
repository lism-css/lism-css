---
import PageLayout from '@/layouts/PageLayout.astro';
import { Group, Stack, Container, Frame, WithSide, Media, Layer, Heading, Divider } from 'lism-css/astro';
import { DummyText } from '@lism-css/ui/astro/DummyText';
---

<PageLayout title="About" description="About lism.blog">
  <p>
    This site is a blog template built with <a href="https://astro.build/">Astro</a> and
    <a href="https://lism-css.com/en/">Lism CSS</a>.<br />
    The full source is published in the <a href="https://github.com/lism-css/lism-css">repository</a>, under
    <code>templates/blog/astro/techlog/</code>.
  </p>

  <p>
    For how this template site is structured, see <a href="/posts/astro-blog-overview/">Inside the blog-astro-techlog template</a>.
  </p>

  <Divider my="60" />
  <DummyText lang="en" />

  <Group as="section" pos="relative" max-sz="full" my="60">
    <Layer>
      <Frame h="100%">
        <Media src="https://cdn.lism-css.com/img/a-2.jpg" alt="" width="960" height="640" />
        <Layer bgc="black:40%" />
      </Frame>
    </Layer>
    <Container isWrapper gr="1" gc="1" hasGutter pos="relative" z="1">
      <!-- <Grid gtc={['auto', null, 'auto 1fr']} c="white" g="50" py="50"> -->
      <WithSide sideW="auto" mainW="xs" c="white" g="50" py="50">
        <Heading level="2" isSide class="u--trim" fz="3xl" fw="bold" hl="l">Lorem ipsum</Heading>
        <Stack class="u--trimAll" g="40">
          <DummyText lang="en" />
          <DummyText lang="en" length="xl" />
        </Stack>
        <!-- </Grid> -->
      </WithSide>
    </Container>
  </Group>

  <DummyText lang="en" length="l" />
</PageLayout>
