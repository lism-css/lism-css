import PageLayout from '@/layouts/PageLayout.astro';
import { Box } from 'lism-css/astro';
---

<PageLayout title="Privacy Policy" description="Privacy policy (placeholder)">
  <p>
    This site (the "Site") respects the privacy of its visitors and is committed to protecting personal information. This policy describes how the
    Site handles personal information.
  </p>

  <Box util="cbox" keycolor="red" bd bdrs="20" p="30" my="40">
    <p>
      <strong>The content of this page is entirely placeholder text.</strong><br />
      Rewrite it to match how your site is actually operated.
    </p>
  </Box>

  <h2>1. Information we collect</h2>
  <p>The Site may collect the following information from visitors.</p>
  <ul>
    <li>The name, email address, and message entered in the contact form</li>
    <li>Access logs (IP address, browser type, referring URL, and so on)</li>
    <li>Information collected automatically through cookies and similar technologies</li>
  </ul>

  <h2>2. Purpose of use</h2>
  <p>We use the information we collect only within the scope of the following purposes.</p>
  <ul>
    <li>To respond to inquiries and verify identity</li>
    <li>To analyze and improve how the Site is used</li>
    <li>To prevent unauthorized access and misuse</li>
  </ul>

  <h2>3. Provision to third parties</h2>
  <p>Except as required by law, the Site does not provide personal information to third parties without the visitor's consent.</p>

  <h2>4. Cookies and analytics</h2>
  <p>
    The Site may use analytics tools to understand how it is used. These tools collect information through cookies, but the information does not
    identify individuals. You can disable cookies in your browser settings.
  </p>

  <h2>5. Requests for disclosure, correction, etc.</h2>
  <p>
    Visitors may request the disclosure, correction, or deletion of their own personal information held by the Site. To make a request, please use the
    contact below.
  </p>

  <h2>6. Contact</h2>
  <p>For inquiries regarding this policy, please contact the site operator by email.</p>

  <h2>7. Revisions</h2>
  <p>The content of this policy may be changed without notice as needed. Any changes take effect once posted on this page.</p>

  <p><small>Established: January 1, 2026</small></p>
</PageLayout>
