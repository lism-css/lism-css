---
import { Group, Stack } from 'lism-css/astro';
import Layout from './Layout.astro';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description?: string;
  breadcrumb?: BreadcrumbItem[];
  ogImage?: string;
}

const { title, description, breadcrumb, ogImage } = Astro.props;
---

<Layout title={title} description={description} breadcrumb={breadcrumb} ogImage={ogImage}>
  <Group isWrapper="l" isContainer hasGutter>
    <Stack g="40">
      <slot />
    </Stack>
  </Group>
</Layout>
