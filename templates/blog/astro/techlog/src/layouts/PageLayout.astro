---
import { Flow, Group, Heading, Stack } from 'lism-css/astro';
import Layout from './Layout.astro';
import { siteConfig } from '@/config/site';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description?: string;
  breadcrumb?: BreadcrumbItem[];
  ogImage?: string;
}

const { title, description, breadcrumb, ogImage } = Astro.props;
const resolvedBreadcrumb = breadcrumb ?? [{ label: title.toUpperCase() }];
---

<Layout title={`${title} — ${siteConfig.name}`} description={description} breadcrumb={resolvedBreadcrumb} ogImage={ogImage}>
  <Stack g="50">
    {/* page title */}
    <Group isWrapper hasGutter>
      <Heading level="1" util="trim">{title}</Heading>
    </Group>

    {/* body */}
    <Flow as="article" class="c--pageBody" isWrapper isContainer hasGutter>
      <slot />
    </Flow>
  </Stack>
</Layout>
