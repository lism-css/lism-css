---
import 'lism-css/main.css';
import '../styles/global.css';
import { siteConfig } from '@/config/site';
import { buildOgImageUrl } from '@/lib/ogImage';
import { Container, Stack, Group } from 'lism-css/astro';
import Header from '@/components/Header.astro';
import Main from '@/components/Main.astro';
import Footer from '@/components/Footer.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description?: string;
  breadcrumb?: BreadcrumbItem[];
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const { title, description = siteConfig.description, breadcrumb, ogImage, ogType = 'website' } = Astro.props;
const hasBreadcrumb = Array.isArray(breadcrumb) && breadcrumb.length > 0;

// og:image は loos.tools/ogimg-maker の URL を直接利用する（絶対URL）
const ogImageUrl =
  ogImage ??
  buildOgImageUrl({
    title: siteConfig.name,
    head: siteConfig.tagline,
  });
// og:url は絶対 URL 推奨。Astro.site が設定されていれば絶対化、なければ相対パスのまま
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.pathname;
---

<html lang={siteConfig.lang}>
  <head>
    <meta charset="utf-8" />
    <script is:inline define:vars={{ defaultTheme: siteConfig.theme.default }}>
      // ちらつきを防ぐため、 head 内でテーマセットする
      (function () {
        var stored = localStorage.getItem('theme');
        var theme;
        if (stored === 'light' || stored === 'dark') {
          theme = stored;
        } else if (defaultTheme === 'light' || defaultTheme === 'dark') {
          theme = defaultTheme;
        } else {
          theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    {/* Open Graph */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={siteConfig.name} />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {/* Webフォント */}
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/gen-interface-jp@0.1.7/cdn/400.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/gen-interface-jp@0.1.7/cdn/500.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/gen-interface-jp@0.1.7/cdn/600.css" />
  </head>
  <body>
    <Container>
      <Stack min-h="100svh" g="0">
        <Header />
        {
          hasBreadcrumb && (
            <Group isWrapper="l" hasGutter py="5" bgc="base-2" fz="11px" c="text-2">
              <Breadcrumb items={[{ label: 'HOME', href: '/' }, ...breadcrumb!]} />
            </Group>
          )
        }
        <Main>
          <slot />
        </Main>
        <Footer />
      </Stack>
    </Container>
  </body>
</html>
