---
import { Lism, Cluster, Link, Center } from 'lism-css/astro';
import { siteConfig } from '@/config/site';
import SnsLinks from '@/components/SnsLinks.astro';
import TagCloud from '@/components/TagCloud.astro';
import type { ComponentProps } from 'astro/types';

type LismProps = ComponentProps<typeof Lism>;

type Props = LismProps;
---

<Lism as="footer" py="40" hasGutter bd-bs {...Astro.props}>
  <Center g="30" max-sz="l" mx="auto">
    <Cluster as="nav" aria-label={siteConfig.uiText.footer.aria} fz="xs" c="text-2" hl="xs" util="divide">
      {
        siteConfig.footer.nav.map((item) => (
          <Link href={item.href} set="plain" px="10" hov={{ c: 'brand' }}>
            {item.label}
          </Link>
        ))
      }
    </Cluster>
    <TagCloud />
    <SnsLinks my="-10" />
    <Lism ta="center" o="p" fz="xs" util="trim">
      {siteConfig.footer.copyright}
    </Lism>
  </Center>
</Lism>
