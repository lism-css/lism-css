---
import { Lism, Link, Inline, Cluster } from 'lism-css/astro';
import { CATEGORIES, CATEGORY_KEYS, type CategoryKey } from '@/config/categories';
import { getCategoryHref } from '@/lib/posts';

interface Props {
  current: 'all' | CategoryKey;
}

const { current } = Astro.props;

const items: Array<{ key: 'all' | CategoryKey; label: string; href: string }> = [
  { key: 'all', label: 'All', href: '/' },
  ...CATEGORY_KEYS.map((k) => ({ key: k, label: CATEGORIES[k].label, href: getCategoryHref(k) })),
];

const tabProps = { d: 'inline-flex', px: '5', py: '5', lh: 's' };
const linkProps = { set: 'plain', c: 'text-2', hov: { c: 'brand' } };
---

<Lism as="nav" class="c--categoryTabs" fz="s" lts="l" aria-label="カテゴリー">
  <Cluster g="20">
    {
      items.map((item) =>
        item.key === current ? (
          <Inline class="c--categoryTabs_item" {...tabProps} aria-current="page">
            {item.label}
          </Inline>
        ) : (
          <Link class="c--categoryTabs_item" {...tabProps} {...linkProps} href={item.href}>
            {item.label}
          </Link>
        )
      )
    }
  </Cluster>
</Lism>

<style>
  @layer lism-component {
    .c--categoryTabs_item {
      /* margin-bottom: -2px; */
      border-bottom: 2px solid transparent;
    }
  }

  .c--categoryTabs_item[aria-current] {
    /* color: var(--text); */
    border-bottom-color: var(--brand);
  }
</style>
