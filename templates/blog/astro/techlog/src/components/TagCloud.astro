---
import { getCollection } from 'astro:content';
import { Cluster } from 'lism-css/astro';
import Tag from '@/components/Tag.astro';
import { getAllTags } from '@/lib/tags';
import { getTagHref } from '@/lib/posts';
import { siteConfig } from '@/config/site';

const posts = await getCollection('posts');
const tags = getAllTags(posts);

// const {} = Astro.props;
---

<Cluster as="nav" aria-label={siteConfig.ui.tagCloud.aria} g="5">
  <!-- <span class="-fz:2xs -c:text-2" aria-hidden="true">#</span> -->
  {tags.map((tag) => <Tag href={getTagHref(tag)}>{tag}</Tag>)}
</Cluster>
