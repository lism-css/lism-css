---
import { Link } from 'lism-css/astro';

interface Props {
  href: string;
  class?: string;
  // bgc?: string;
}

const { href, class: className, ...rest } = Astro.props;
---

<Link
  href={href}
  class:list={['c--tag', className]}
  set="plain"
  d="inline-flex"
  ai="center"
  fz="2xs"
  lh="xs"
  py="5"
  px="5"
  c="text-2"
  hov="underline"
  {...rest}
>
  # <slot />
</Link>
