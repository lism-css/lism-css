---
import { Flex, Cluster, Stack, Link, Container, Inline, Icon, Center } from 'lism-css/astro';
import { Modal } from '@lism-css/ui/astro/Modal';
import Eyebrow from '@/components/Eyebrow.astro';
import SnsLinks from '@/components/SnsLinks.astro';
import SearchModal from '@/components/SearchModal.astro';
import ThemeSwitch from '@/components/ThemeSwitch.astro';
import { siteConfig } from '@/config/site';
---

<Container as="header" isWrapper="l" hasGutter py="20" pos="sticky" t="0" z="99">
  <Flex ai="center" jc="between" g="15">
    <Link href="/" set="plain" d="flex" fw="bold" fz="l" lh="xs">
      {siteConfig.name}
    </Link>

    <Cluster ai="center" g="10">
      {/* テーマ切り替え */}
      <ThemeSwitch />

      {/* 検索トリガー */}
      <Modal.OpenBtn modalId="search-modal" class="l--center" bdrs="10" p="0.4em" hov={{ bgc: 'base-2' }} aria-label="記事を検索">
        <Icon icon="search" fz="l" />
      </Modal.OpenBtn>

      {/* メニューボタン（全幅で常時表示・PCナビと併設） */}
      <Modal.OpenBtn
        modalId="site-nav"
        class="c--menuTrigger l--center set--plain"
        bdrs="10"
        p="0.4em"
        hov={{ bgc: 'base-2' }}
        aria-labelledby="menu-open-label"
      >
        <Icon
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          aria-hidden="true"
          style={{ scale: '1.1' }}
        >
          <line x1="2" y1="8" x2="22" y2="8"></line>
          <line x1="2" y1="16" x2="22" y2="16"></line>
        </Icon>
        <Inline d="none" id="menu-open-label">メニューを開く</Inline>
      </Modal.OpenBtn>
    </Cluster>
  </Flex>

  <SearchModal />

  {/* モバイル用モーダルナビ */}
  <Modal.Root id="site-nav" isContainer isWrapper="s" hasGutter py="40">
    <Modal.Inner layout="stack" g="20" w="100%" max-h="100%" pos="relative" p="30" bdrs="20" bxsh="40" bgc="base">
      <Flex ai="center" jc="between" mt="-5">
        <Eyebrow>MENU</Eyebrow>
        <Modal.CloseBtn modalId="site-nav" autofocus p="0.4em" me="-0.4em" bdrs="10" hov={{ bgc: 'base-2' }} aria-labelledby="menu-close-label">
          <Icon
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            aria-hidden="true"
            style={{ scale: '1.15' }}
          >
            <path d="M18 6 6 18"></path><path d="m6 6 12 12"></path>
          </Icon>
          <Inline d="none" id="menu-close-label">メニューを閉じる</Inline>
        </Modal.CloseBtn>
      </Flex>
      <Modal.Body layout="stack" g="20" ov-y="auto">
        <Stack as="nav" aria-label="メインナビゲーション" util="divide" fz="s">
          {
            siteConfig.header.nav.map((item) => (
              <Link href={item.href} c="inherit" td="none" py="10" hov={{ c: 'brand' }}>
                {item.label}
              </Link>
            ))
          }
        </Stack>
      </Modal.Body>
      <Center my="-5">
        <SnsLinks />
      </Center>
    </Modal.Inner>
  </Modal.Root>
</Container>

<style>
  header {
    backdrop-filter: blur(0.5em);
    background-color: color-mix(in srgb, var(--base) 50%, transparent);
  }
</style>

<script>
  const header = document.querySelector<HTMLElement>('header');
  if (header) {
    const setHeaderH = () => {
      document.documentElement.style.setProperty('--header-h', `${header.offsetHeight}px`);
    };
    setHeaderH();
    new ResizeObserver(setHeaderH).observe(header);
  }
</script>
