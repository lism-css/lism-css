---
import { Inline } from 'lism-css/astro';
import type { ComponentProps } from 'astro/types';

type InlineProps = ComponentProps<typeof Inline>;

type Props = InlineProps & {
  date: string;
};

const { date, class: className, ...rest } = Astro.props;
const formatted = date.replaceAll('-', '.');
---

<Inline class:list={['c--date', className]} fz="2xs" c="text-2" {...rest}>
  {formatted}
</Inline>
