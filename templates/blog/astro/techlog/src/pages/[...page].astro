---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import ArchiveLayout from '@/layouts/ArchiveLayout.astro';
import ArchiveHeader from '@/components/ArchiveHeader.astro';
import CategoryTabs from '@/components/CategoryTabs.astro';
import PostList from '@/components/PostList.astro';
import Pager from '@/components/Pager.astro';
import { siteConfig } from '@/config/site';
import { Stack } from 'lism-css/astro';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = (await getCollection('posts')).sort((a, b) => b.data.date.localeCompare(a.data.date));
  return paginate(posts, { pageSize: siteConfig.pagination.postsPerPage });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<ArchiveLayout title={`${siteConfig.name} — ${siteConfig.tagline}`}>
  {/* ページタイトル */}
  <ArchiveHeader eyebrow="BLOGS" title="All Posts">
    {siteConfig.tagline}
  </ArchiveHeader>

  <Stack g="30">
    {/* カテゴリタブ */}
    <CategoryTabs current="all" />

    {/* 記事リスト */}
    <PostList posts={page.data} />
  </Stack>

  {/* ページャー */}
  <Pager currentPage={page.currentPage} lastPage={page.lastPage} />
</ArchiveLayout>
