---
import { getCollection } from 'astro:content';
import { Lism, List, ListItem, Link, Cluster, Stack, Heading, Text } from 'lism-css/astro';
import ArchiveLayout from '@/layouts/ArchiveLayout.astro';
import { getArchiveSummaries, getArchiveHref } from '@/lib/archive';
import { siteConfig } from '@/config/site';

const posts = await getCollection('posts');
const summaries = getArchiveSummaries(posts);
const totalCount = posts.length;
---

<ArchiveLayout title={`Archive — ${siteConfig.name}`} description={siteConfig.ui.archiveIndexDescription} breadcrumb={[{ label: 'ARCHIVE' }]}>
  <Stack g="40">
    <Heading level="1" util="trim">Archive</Heading>
    <Text fz="s" c="text-2" util="trim">{siteConfig.ui.archiveTotalCount(totalCount)}</Text>
  </Stack>

  <List bd-be>
    {
      summaries.map(({ year, month, count }) => (
        <ListItem bd-bs>
          <Link href={getArchiveHref(year, month)} set="plain" hov={{ c: 'brand' }} d="block" py="15" px="5">
            <Cluster jc="between" g="15">
              <Lism fw="500">
                {year}.{month}
              </Lism>
              <Lism fz="xs" c="text-2" lts="l">
                ({count})
              </Lism>
            </Cluster>
          </Link>
        </ListItem>
      ))
    }
  </List>
</ArchiveLayout>
