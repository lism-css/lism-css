---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import ArchiveLayout from '@/layouts/ArchiveLayout.astro';
import ArchiveHeader from '@/components/ArchiveHeader.astro';
import PostList from '@/components/PostList.astro';
import Pager from '@/components/Pager.astro';
import { siteConfig } from '@/config/site';
import { getArchiveSummaries, getPostsByArchive, getArchiveHref } from '@/lib/archive';

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection('posts');
  const summaries = getArchiveSummaries(allPosts);

  return summaries.flatMap(({ year, month }) => {
    const posts = getPostsByArchive(allPosts, year, month);
    return paginate(posts, {
      params: { year, month },
      props: { year, month },
      pageSize: siteConfig.pagination.postsPerPage,
    });
  });
}) satisfies GetStaticPaths;

const { year, month, page } = Astro.props;

const baseHref = getArchiveHref(year, month);
const getPageHref = (n: number) => (n === 1 ? baseHref : `${baseHref}${n}/`);
---

<ArchiveLayout
  title={`${year}.${month} — ${siteConfig.name}`}
  description={siteConfig.uiText.monthArchiveDescription(year, month)}
  breadcrumb={[{ label: 'ARCHIVE', href: '/archive/' }, { label: `${year}.${month}` }]}
>
  <ArchiveHeader eyebrow="ARCHIVE" title={`${year}.${month}`}>
    {siteConfig.uiText.postCount(page.total)}
  </ArchiveHeader>

  <PostList posts={page.data} />

  <Pager currentPage={page.currentPage} lastPage={page.lastPage} getPageHref={getPageHref} />
</ArchiveLayout>
