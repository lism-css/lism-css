---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import ArchiveLayout from '@/layouts/ArchiveLayout.astro';
import ArchiveHeader from '@/components/ArchiveHeader.astro';
import PostList from '@/components/PostList.astro';
import Pager from '@/components/Pager.astro';
import { siteConfig } from '@/config/site';
import { getAllTags } from '@/lib/tags';
import { getTagHref } from '@/lib/posts';

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection('posts');

  return getAllTags(allPosts).flatMap((tag) => {
    const posts = allPosts.filter((p) => p.data.tags.includes(tag)).sort((a, b) => b.data.date.localeCompare(a.data.date));
    return paginate(posts, {
      params: { tag },
      props: { tag },
      pageSize: siteConfig.pagination.postsPerPage,
    });
  });
}) satisfies GetStaticPaths;

const { tag, page } = Astro.props;

const getPageHref = (n: number) => (n === 1 ? getTagHref(tag) : `/tags/${tag}/${n}/`);
---

<ArchiveLayout
  title={`#${tag} — ${siteConfig.name}`}
  description={siteConfig.uiText.tagArchiveDescription(tag)}
  breadcrumb={[{ label: 'TAGS', href: '/tags/' }, { label: tag.toUpperCase() }]}
>
  {/* ページタイトル */}
  <ArchiveHeader eyebrow="TAG" title={`# ${tag}`}>
    {siteConfig.uiText.postCount(page.total)}
  </ArchiveHeader>

  {/* 記事リスト */}
  <PostList posts={page.data} />

  {/* ページャー */}
  <Pager currentPage={page.currentPage} lastPage={page.lastPage} getPageHref={getPageHref} />
</ArchiveLayout>
