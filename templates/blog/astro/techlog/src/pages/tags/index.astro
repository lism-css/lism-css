---
import ArchiveHeader from '@/components/ArchiveHeader.astro';
import TagCloud from '@/components/TagCloud.astro';
import { siteConfig } from '@/config/site';
import ArchiveLayout from '@/layouts/ArchiveLayout.astro';
---

<ArchiveLayout title={`Tags — ${siteConfig.name}`} description={siteConfig.ui.tagsIndexDescription} breadcrumb={[{ label: 'TAGS' }]}>
  <ArchiveHeader eyebrow="TAGS" title="Tags">{siteConfig.ui.tagsIndexDescription}</ArchiveHeader>
  <TagCloud />
</ArchiveLayout>
