---
import { Flex, Cluster, Link, Container } from 'lism-css/astro';
import SnsLinks from '@/components/SnsLinks.astro';
import { siteConfig } from '@/config/site';
---

<Container as="header" isWrapper hasGutter py="20" pos="sticky" t="0" z="99">
  <Flex ai="center" jc="between" g="20">
    <Link href="/" set="plain" d="flex" fw="bold" fz="l" lh="xs">
      {siteConfig.name}
    </Link>

    <Cluster as="nav" aria-label="メインナビゲーション" ai="center" g="20" fz="s">
      {
        siteConfig.nav
          .filter((item) => item.href !== '/')
          .map((item) => (
            <Link href={item.href} c="inherit" td="none" hov="underline">
              {item.label}
            </Link>
          ))
      }
      <SnsLinks g="5" d={['none', 'flex']} />
    </Cluster>
  </Flex>
</Container>

<style>
  header {
    backdrop-filter: blur(0.5em);
    background-color: color-mix(in srgb, var(--base) 50%, transparent);
  }
</style>
