---
import { getCollection, render } from 'astro:content';
import { Group, Flow, Cluster, Heading } from 'lism-css/astro';
import Layout from '@/layouts/Layout.astro';
import Date from '@/components/Date.astro';
import Tag from '@/components/Tag.astro';
import ArticleNav from '@/components/ArticleNav.astro';
import { siteConfig } from '@/config/site';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).sort((a, b) => b.data.date.localeCompare(a.data.date));

  return posts.map((post, index) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: posts[index - 1],
      next: posts[index + 1],
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} — ${siteConfig.name}`} description={post.data.excerpt}>
  <Group as="article" isWrapper isContainer hasGutter>
    <Group as="header">
      <Heading level="1">
        {post.data.title}
      </Heading>
      <Cluster g="15" mbs="30">
        <Date>{post.data.date}</Date>
        {
          post.data.tags.length > 0 && (
            <Cluster g="5" ai="center">
              {post.data.tags.map((tag) => (
                <Tag href={`/tags/${tag}/`}>{tag}</Tag>
              ))}
            </Cluster>
          )
        }
      </Cluster>
    </Group>

    <Flow class="c--articleBody" mbs="50">
      <Content />
    </Flow>

    <Group as="footer" mbs="60" py="30" bd-y>
      <ArticleNav
        prev={prev ? { title: prev.data.title, id: prev.id } : undefined}
        next={next ? { title: next.data.title, id: next.id } : undefined}
      />
    </Group>
  </Group>
</Layout>
