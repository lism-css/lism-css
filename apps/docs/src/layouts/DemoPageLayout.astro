---
/**
 * デモページ用レイアウト
 * - テンプレートプレビューやデモページで使用
 * - シンプルなLism CSSのみを読み込み、noindexを設定
 */
import 'lism-css/main.css';

const { title = '', lang = 'ja' } = Astro.props;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Lism CSS - {title}</title>
    <style is:global>
      .-bg\:stripe {
        background-image: repeating-linear-gradient(-55deg, var(--divider), var(--divider) 1px, transparent 1px, transparent 6px) !important;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
