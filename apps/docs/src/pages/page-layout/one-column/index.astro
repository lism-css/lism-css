---
import DemoPageLayout from '@/layouts/DemoPageLayout.astro';
import DemoHeader from '../_DemoHeader.astro';
import DemoFooter from '../_DemoFooter.astro';
import DemoContent from '../_DemoContent.astro';
import { Wrapper, Box, Stack } from 'lism-css/astro';
---

<DemoPageLayout title="One Column Layout">
  <Stack id="wrap" min-h="100vh">
    <DemoHeader />
    <Box as="main" py="50" fx="1" isContainer>
      <Box as="article">
        <Wrapper as="header" set="gutter">
          <h1>Page Title</h1>
        </Wrapper>

        <Wrapper set="gutter" layout="flow" my-s="50">
          <DemoContent />
        </Wrapper>

        <Wrapper as="aside" set="gutter" my-s="50">
          <Box bgc="base-2" p="40">
            <div>Comment area, etc...</div>
          </Box>
        </Wrapper>
      </Box>
    </Box>
    <DemoFooter />
  </Stack>
</DemoPageLayout>
