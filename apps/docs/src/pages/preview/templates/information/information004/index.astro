---
import DemoLayout from '@/layouts/DemoLayout.astro';

import { Container, Frame, Grid, Lism, Stack, Flex, Text, Heading } from 'lism-css/astro';
import { Button } from '@lism-css/ui/astro';
import './_style.css';
---

<DemoLayout title="Information004">
  <Container isWrapper="m" bgc="base" py="50" setGutter>
    <Stack g="20" ai="center" mb="40">
      <Heading level="2" class="u--trim" fz="2xl" fw="bold">オフィス</Heading>
      <Text class="u--trim" fz="s" ta="center" o="-20">All Offices</Text>
    </Stack>
    <Stack>
      <Grid gtc={['auto', null, 'minmax(auto, 200px) repeat(2, 1fr)']} g="40" py="40" bd-y-e>
        <Stack class="u--trimChildren" g="15">
          <Text fz="l" fw="bold" lts="l">東京本社</Text>
          <Text fz="s" o="-20">Tokyo Office</Text>
        </Stack>
        <Stack g="30">
          <Stack class="u--trim" fz="s">
            <p>〒150-0001 東京都渋谷区神宮前1-1-1-1</p>
            <p>TEL: 03-1234-5678</p>
            <p>営業時間: 10:00 - 20:00</p>
            <p>定休日: 水曜日</p>
          </Stack>
          <Flex my-s="auto" g="20">
            <Button href="#" fz="s" bdrs="99">Web Site</Button>
            <Button variant="outline" href="#" fz="s" bdrs="99">Google Map</Button>
          </Flex>
        </Stack>
        <Frame as="figure" ar="gold" bdrs="10">
          <Lism as="img" src="https://cdn.lism-css.com/img/random-2510?category=office&r=1" alt="" width="960" height="640" />
        </Frame>
      </Grid>
      <Grid gtc={['auto', null, 'minmax(auto, 200px) repeat(2, 1fr)']} g="40" py="40" bd-y-e>
        <Stack class="u--trimChildren" g="15">
          <Text fz="l" fw="bold" lts="l">北海道支店</Text>
          <Text fz="s" o="-20">Hokkaido Branch</Text>
        </Stack>
        <Stack g="30">
          <Stack class="u--trim" fz="s">
            <p>〒060-0001 北海道札幌市中央区北1条西1-1-1-1</p>
            <p>TEL: 011-1234-5678</p>
            <p>営業時間: 10:00 - 20:00</p>
            <p>定休日: 水曜日</p>
          </Stack>
          <Flex my-s="auto" g="20">
            <Button href="#" fz="s" bdrs="99">Web Site</Button>
            <Button variant="outline" href="#" fz="s" bdrs="99">Google Map</Button>
          </Flex>
        </Stack>
        <Frame as="figure" ar="gold" bdrs="10">
          <Lism as="img" src="https://cdn.lism-css.com/img/random-2510?category=office&r=2" alt="" width="960" height="640" />
        </Frame>
      </Grid>
      <Grid gtc={['auto', null, 'minmax(auto, 200px) repeat(2, 1fr)']} g="40" py="40" bd-y-e>
        <Stack class="u--trimChildren" g="15">
          <Text fz="l" fw="bold" lts="l">沖縄支店</Text>
          <Text fz="s" o="-20">Okinawa Branch</Text>
        </Stack>
        <Stack g="30">
          <Stack class="u--trim" fz="s">
            <p>〒900-0001 沖縄県那覇市久茂地1-1-1-1</p>
            <p>TEL: 03-1234-5678</p>
            <p>営業時間: 10:00 - 20:00</p>
            <p>定休日: 水曜日</p>
          </Stack>
          <Flex my-s="auto" g="20">
            <Button variant="outline" href="#" fz="s" bdrs="99">Google Map</Button>
          </Flex>
        </Stack>
        <Frame as="figure" ar="gold" bdrs="10">
          <Lism as="img" src="https://cdn.lism-css.com/img/random-2510?category=office&r=3" alt="" width="960" height="640" />
        </Frame>
      </Grid>
    </Stack>
  </Container>
</DemoLayout>
