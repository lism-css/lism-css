---
import DemoLayout from '@/layouts/DemoLayout.astro';

import { Stack, Container, Frame, TileGrid, Media, Layer, Icon, BoxLink, Flex, Center, Text, Inline } from 'lism-css/astro';
import { Button } from '@lism-css/ui/astro';
import './_style.css';
---

<DemoLayout title="CTA004">
  <Stack pos="relative">
    <Frame isLayer>
      <Media isLayer src="https://cdn.lism-css.com/random/img?r=1" alt="" width="960" height="640" />
      <Layer style={{ backdropFilter: 'blur(4px) grayscale(100%)' }} bgc="black:30%" />
    </Frame>
    <Container isWrapper="m" hasGutter py="50" z="1">
      <Stack g="40">
        <Stack ai="center" g="30">
          <Text class="u--trim" fz="5xl" fw="light" lts="l" c="white" ta="center">Contact</Text>
          <Text class="u--trim" fz="m" c="white" ta="center">Get in touch with us</Text>
        </Stack>
        <Stack g="30">
          <TileGrid cols={['1', null, '2']} ai="center" g="30" w="stretch">
            <Button
              href="#"
              g="15"
              variant="outline"
              w="stretch"
              c="white"
              bdrs="10"
              py="15"
              fw="bold"
              hasTransition
              hov={{ bgc: 'white', c: 'black' }}
            >
              <Icon icon="book" fz="2em" />
              <span>Request a brochure</span>
            </Button>
            <Button
              href="#"
              g="15"
              variant="outline"
              w="stretch"
              c="white"
              bdrs="10"
              py="15"
              fw="bold"
              hasTransition
              hov={{ bgc: 'white', c: 'black' }}
            >
              <Icon icon="user" fz="2em" />
              <span>Contact via email</span>
            </Button>
            <BoxLink layout="grid" href="#" gc="1 / -1" gtc={['1fr auto', null, '1fr 2fr auto']} ai="center" bgc="white" bdrs="10" ov="h" set="hov">
              <Frame as="figure" ar={['16/9', null, 'inherit']} gc={['1 / -1', null, '1']} pos="relative" h="100%" ov="h">
                <Media src="https://cdn.lism-css.com/random/img?r=2" alt="" width="960" height="540" hasTransition hov="to:zoom" />
                <Layer hasTransition hov="to:show" bgc="rgb(0 0 0 / 30%)" style={{ backdropFilter: 'blur(4px)' }}>
                  <Center h="100%" c="white">
                    <Inline fz="xl" fs="i" fw="light" lts="l" px="20" py="10">View More</Inline>
                  </Center>
                </Layer>
              </Frame>
              <Stack jc="center" g="30" p="40">
                <Text class="u--trim" fz="l" fw="bold">Schedule an in-person consultation</Text>
                <Text class="u--trim" fz="s" o="-20">
                  Our specialists will visit you at your convenience. Please check here first to learn about consultation methods and the process
                  after your request.
                </Text>
              </Stack>
              <Flex ai="center" jc="center" p="15" bd bdrs="99" mx="30" hasTransition hov="to:reverse">
                <Icon icon="arrow-right" fz="120%" hasTransition />
              </Flex>
            </BoxLink>
          </TileGrid>
          <Stack ai="center" g="40" w="100%">
            <Text class="u--trim" fz="s" c="white" ta="center">Feel free to contact us. Our team will respond promptly</Text>
          </Stack>
        </Stack>
      </Stack>
    </Container>
  </Stack>
</DemoLayout>

<style>
  @media (any-hover: hover) {
    .-hov\:to\:zoom {
      scale: var(--_isHov, 1.1);
    }
    .-hov\:to\:reverse {
      background-color: var(--_isHov, var(--black));
      color: var(--_isHov, var(--white));
    }
  }
</style>
