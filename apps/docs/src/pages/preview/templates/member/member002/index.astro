---
import DemoLayout from '@/layouts/DemoLayout.astro';

import { Container, Flex, Frame, FluidCols, Media, Stack, Text, Heading } from 'lism-css/astro';
import './_style.css';
---

<DemoLayout title="Member002">
  <Container isWrapper="l" bgc="base" py="50" setGutter>
    <Stack g="50">
      <Heading level="2" class="u--trim" fz="2xl" fw="bold" ta="center">社員一覧</Heading>
      <FluidCols cols="14rem" g="40">
        <Flex g="30" ai="center">
          <Frame as="figure" ar="1/1" w="stretch" max-w="100px" bdrs="99">
            <Media src="https://cdn.lism-css.com/img/random-2510?category=avatar&r=1" width="960" height="640" />
          </Frame>
          <Stack g="20">
            <Text class="u--trim" fz="m" fw="bold">鈴木 太郎</Text>
            <Text class="u--trim" fz="xs" o="-10">代表取締役 / クリエイティブディレクター</Text>
          </Stack>
        </Flex>
        <Flex g="30" ai="center">
          <Frame as="figure" ar="1/1" w="stretch" max-w="100px" bdrs="99">
            <Media src="https://cdn.lism-css.com/img/random-2510?category=avatar&r=2" width="960" height="640" />
          </Frame>
          <Stack g="20">
            <Text class="u--trim" fz="m" fw="bold">佐藤 美咲</Text>
            <Text class="u--trim" fz="xs" o="-10">アートディレクター / UI/UXデザイナー</Text>
          </Stack>
        </Flex>
        <Flex g="30" ai="center">
          <Frame as="figure" ar="1/1" w="stretch" max-w="100px" bdrs="99">
            <Media src="https://cdn.lism-css.com/img/random-2510?category=avatar&r=3" width="960" height="640" />
          </Frame>
          <Stack g="20">
            <Text class="u--trim" fz="m" fw="bold">高橋 健太</Text>
            <Text class="u--trim" fz="xs" o="-10">テクニカルディレクター / リードエンジニア</Text>
          </Stack>
        </Flex>
        <Flex g="30" ai="center">
          <Frame as="figure" ar="1/1" w="stretch" max-w="100px" bdrs="99">
            <Media src="https://cdn.lism-css.com/img/random-2510?category=avatar&r=4" width="960" height="640" />
          </Frame>
          <Stack g="20">
            <Text class="u--trim" fz="m" fw="bold">田中 雄大</Text>
            <Text class="u--trim" fz="xs" o="-10">Webディレクター / プロジェクトマネージャー</Text>
          </Stack>
        </Flex>
        <Flex g="30" ai="center">
          <Frame as="figure" ar="1/1" w="stretch" max-w="100px" bdrs="99">
            <Media src="https://cdn.lism-css.com/img/random-2510?category=avatar&r=5" width="960" height="640" />
          </Frame>
          <Stack g="20">
            <Text class="u--trim" fz="m" fw="bold">伊藤 沙織</Text>
            <Text class="u--trim" fz="xs" o="-10">Webデザイナー</Text>
          </Stack>
        </Flex>
        <Flex g="30" ai="center">
          <Frame as="figure" ar="1/1" w="stretch" max-w="100px" bdrs="99">
            <Media src="https://cdn.lism-css.com/img/random-2510?category=avatar&r=6" width="960" height="640" />
          </Frame>
          <Stack g="20">
            <Text class="u--trim" fz="m" fw="bold">渡辺 拓也</Text>
            <Text class="u--trim" fz="xs" o="-10">フロントエンドエンジニア</Text>
          </Stack>
        </Flex>
        <Flex g="30" ai="center">
          <Frame as="figure" ar="1/1" w="stretch" max-w="100px" bdrs="99">
            <Media src="https://cdn.lism-css.com/img/random-2510?category=avatar&r=7" width="960" height="640" />
          </Frame>
          <Stack g="20">
            <Text class="u--trim" fz="m" fw="bold">山本 大輔</Text>
            <Text class="u--trim" fz="xs" o="-10">バックエンドエンジニア</Text>
          </Stack>
        </Flex>
        <Flex g="30" ai="center">
          <Frame as="figure" ar="1/1" w="stretch" max-w="100px" bdrs="99">
            <Media src="https://cdn.lism-css.com/img/random-2510?category=avatar&r=8" width="960" height="640" />
          </Frame>
          <Stack g="20">
            <Text class="u--trim" fz="m" fw="bold">小林 誠</Text>
            <Text class="u--trim" fz="xs" o="-10">アカウントエグゼクティブ / 営業</Text>
          </Stack>
        </Flex>
      </FluidCols>
    </Stack>
  </Container>
</DemoLayout>
