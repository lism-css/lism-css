---
import DemoLayout from '@/layouts/DemoLayout.astro';

import { Stack, Container, Frame, Grid, Media, Flex, Box, Heading } from 'lism-css/astro';
import { Button } from '@lism-css/ui/astro';
import './_style.css';
---

<DemoLayout title="Section902">
  <Container class="t--section902" size="l" bgc="base-2" py="50">
    <Box>
      <Grid gtc={['auto', null, 'minmax(24rem, 1fr) 2fr']} ji={[null, null, 'end']} g="50 60">
        <Stack gr="1" gc="1" pl={[null, null, '30']}>
          <Stack g="40" px={['30', null, '0']} h="100%">
            <Heading level="2" class="u--trim" fz="3xl" fw="bold" lts="l" c="gray"
              >A Comfortable Temperature<br />That Makes You Want<br />to Take a Deep Breath</Heading
            >
            <Stack class="u--trimChildren" g="20">
              <p>
                Bring the refreshing, crisp air of a highland forest right into your room. The high-performance filter thoroughly removes invisible
                fine particles and household odors, keeping your space clean and pure. With a whisper-quiet design you'll forget is even running, it's
                perfect for bedrooms and studies. A quiet partner that brings gentle comfort and healthy deep breaths into your daily life.
              </p>
            </Stack>
            <Flex g="15" ai="center" my-s="auto">
              <Button href="#" jc="center" w="stretch" p="15" bdrs="10">View More</Button>
            </Flex>
          </Stack>
        </Stack>
        <Frame gr={['2', null, '1']} gc={['1', null, '2']} w="stretch" max-h="32rem">
          <Media src="/img/img-1.jpg" alt="" width="960" height="640" />
        </Frame>
      </Grid>
    </Box>
  </Container>
</DemoLayout>

<style>
  @layer lism-component {
    @property --is-over-md {
      syntax: '<integer>';
      inherits: true;
      initial-value: 0;
    }
    .t--section902 {
      container-type: inline-size;
      container-name: section902;
      --size-md: var(--size-m, 960px);
      --is-over-md: clamp(0, calc((100cqw - var(--size-md)) / 1px) * 1000, 1);
    }
    @container section902 style(--is-over-md: 1) {
      .t--section902 > .l--box > .l--grid {
        margin-inline-end: calc(50% - 50vw);
      }
    }
  }
</style>
