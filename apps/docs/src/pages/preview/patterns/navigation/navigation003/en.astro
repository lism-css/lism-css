            g="30"
            ai="center"
            jc="between"
            p="30"
            bd
            bgc="white"
            bdrs="10"
            set="var:hov"
            hasTransition
            hov={{ bxsh: '20' }}
          >
            <Text class="u--trim" fz="m" fw="bold" hasTransition hov="in:cLink">Washers & Garment Care</Text>
            <Flex ai="center" jc="center" bgc="black" bdrs="99" p="10">
              <Icon icon="arrow-right" fz="2xs" c="white" />
            </Flex>
          </BoxLink>
          <BoxLink
            href="#"
            layout="flex"
            g="30"
            ai="center"
            jc="between"
            p="30"
            bd
            bgc="white"
            bdrs="10"
            set="var:hov"
            hasTransition
            hov={{ bxsh: '20' }}
