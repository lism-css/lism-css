              <Icon icon="arrow-right" fz="2xs" c="white" />
            </Flex>
          </BoxLink>
        </AutoColumns>
        <Flex jc="flex-end">
          <BoxLink href="#" layout="flex" ai="center" g="10" hasTransition hov={{ c: 'link' }}>
            <Text class="u--trim">View All Categories</Text>
            <Icon icon="arrow-right" />
          </BoxLink>
        </Flex>
      </Stack>
    </Stack>
  </Container>
