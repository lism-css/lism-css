---
/**
 * トップページ
 * Lism CSSの紹介とドキュメントへの導線
 */
import SimpleLayout from '@/layouts/SimpleLayout.astro';
import { Stack, TileGrid, Flex, Lism, Heading, Text, Link, Columns, BoxLink } from 'lism-css/astro';
import { Button } from '@lism-css/ui/astro';
import Gradbox from '@/components/parts/Gradbox.astro';
import { siteConfig } from '@/config/site';
// import LismExDemo from '@/content/ja/_demo/LismExDemo.mdx';

const FEATURES = [
  {
    icon: '<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>',
    title: 'レイアウトモジュール',
    desc: 'Stack, Flex, Grid, Columns など、よく使うレイアウトパターンをモジュール化。組み合わせるだけでサイトの骨組みが完成します。',
  },
  {
    icon: '<line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/>',
    title: 'ハーモニックスケール',
    desc: '余白・フォントサイズ・行間を調和的な比率で設計。自然と心地よいリズムをデザインに生み出すタイポグラフィ設計です。',
  },
  {
    icon: '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
    title: 'デザイントークン',
    desc: 'カラー・フォントサイズ・余白・角丸・シャドウなどを段階的なCSS変数で一元管理。サイト全体の一貫性を保ちます。',
  },
  {
    icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
    title: 'Property Class',
    desc: '-fz:l, -p:20 のような直感的なクラス名で素早くスタイリング可能。形式が明確で短縮記法なのにAIが迷いません。',
  },
  {
    icon: '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>',
    title: 'CSSレイヤー構造',
    desc: '@layer による 厳格なCSSレイヤー設計。詳細度の衝突を防ぎ、拡張性と保守性を両立します。',
  },
  {
    icon: '<rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>',
    title: 'レスポンシブ',
    desc: 'CSS変数とクラスを組み合わせた独自のレスポンシブ手法。軽量なのに柔軟で幅広いレイアウトに対応できます。',
  },
];

// エコシステム
const ecosystems = [
  {
    icon: '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
    title: 'Skills',
    desc: 'AIエージェント向けの実装ガイドスキルを用意しています。AIが Lism CSS の設計を理解し、ベストプラクティスに従ったコードを生成します。',
    href: '/docs/skills/',
  },
  {
    icon: '<rect x="4" y="4" width="16" height="16" rx="2" ry="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/>',
    title: 'MCPサーバー',
    desc: 'Claude Code や Cursor 等のAIコーディングツールに Lism CSSの仕様を提供。AIと協力して効率的にサイトを構築できます。',
    href: '/docs/mcp/',
  },
  {
    icon: '<rect width="7" height="7" x="14" y="3" rx="1"/><path d="M10 21V8a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-5a1 1 0 0 0-1-1H3"/>',
    title: 'UIコンポーネント',
    desc: 'Accordion, Modal, Tabs, Button 等のインタラクティブUIを React / Astro で提供。CLIコマンドでプロジェクトに追加できます。',
    href: '/ui/',
  },
  {
    icon: '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>',
    title: 'Templates',
    desc: 'すぐに使えるページテンプレート集。ランディングページやブログなど、実用的なレイアウトパーツをコピーしてすぐに始められます。',
    href: '/templates/',
  },
];
---

<SimpleLayout title={siteConfig.name} description={siteConfig.description} schemaType="SoftwareSourceCode" excludeFromSearch>
  <TileGrid class="c--hero" cols="5" rows="1" min-h={['50svh', '75vh']} ai="center">
    <Stack class="c--hero_content" g="40" gc="1 / 5" gr="1" z="1">
      <Stack g="30">
        <Lism class="-w:fit">
          <Heading level="1" fz={['3xl', '4xl']} fw="light" ff="accent" lts="l">
            AIと人のための<br />CSS設計<Lism as="br" d={['inherit', null, 'none']} />フレームワーク</Heading
          >
        </Lism>
        <Text class="c--hero_tagline" fz="m" c="text-2">
          軽量でビルド不要。どのサイトにも導入できます。<br />
          あなたはもう、CSS設計に悩む必要はありません。
        </Text>
      </Stack>
      <Flex>
        <Link href="/docs/overview/" bgc="text" c="base" td="none" bdrs="99" py="10" px="30" hov="neutral">ドキュメント</Link>
      </Flex>
    </Stack>
    <Lism class="c--hero_image" gc="3 / 6" gr="1" pb="10" z="0">
      <Gradbox />
    </Lism>
  </TileGrid>

  <Stack as="section" ai="center" g="50" py="60">
    <Stack ai="center" g="20">
      <Text fz="2xs" fw="500" c="text-2" tt="upper" lts="0.15em"> FEATURES </Text>
      <!-- <Heading level="2" ff="accent" fw="normal" ta="center" fz="48px" lts="s">A sophisticated design philosophy</Heading> -->
      <Heading level="2" ff="accent" fw="normal" ta="center" fz="3xl" lts="s">洗練された設計理論</Heading>
    </Stack>

    <Columns cols={[1, 2, 3]} g="40">
      {
        FEATURES.map((card) => (
          <Stack g="20" p="10">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={card.icon}
            />
            <Text fw="bold">{card.title}</Text>
            <Text fz="s" c="text-2" lh="s">
              {card.desc}
            </Text>
          </Stack>
        ))
      }
    </Columns>
  </Stack>

  <Stack as="section" ai="center" g="50" py="60">
    <Stack ai="center" g="20">
      <Text fz="2xs" fw="500" c="text-2" tt="upper" lts="0.15em">ECOSYSTEM</Text>
      <Heading level="2" ff="accent" fw="normal" ta="center" fz="3xl" lts="s">充実のエコシステム</Heading>
    </Stack>

    <Columns cols={[1, 2]} g="30">
      {
        ecosystems.map((item) => (
          <BoxLink href={item.href} layout="stack" g="20" p="30" bd hov="bxsh" td="none">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={item.icon}
            />
            <Text fz="l" fw="bold">
              {item.title}
            </Text>
            <Text fz="s" c="text-2" lh="s">
              {item.desc}
            </Text>
          </BoxLink>
        ))
      }
    </Columns>
  </Stack>

  <Stack as="section" ai="center" g="20" py="60">
    <Heading level="2" ff="accent" fw="normal" ta="center" fz="3xl" lts="s">どこでも使えます</Heading>
    <Text ta="center" c="text-2" lh="s"> Lism CSSは、CSSファイルを一つ読み込むだけでも導入できます。 </Text>
  </Stack>

  {/* CTAボタン */}
  <Flex jc="center" my-s="60">
    <Button variant="fill" href="/docs/installation" bdrs="99" py="15" px="30">
      <span>Getting Started</span>
    </Button>
  </Flex>
</SimpleLayout>
