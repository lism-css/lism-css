---
/**
 * パターン一覧ページ（非root言語用）
 * カテゴリ別にパターンを一覧表示
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Stack, AutoColumns, Frame, BoxLink, Box, Lism, Text, Inline, Heading } from 'lism-css/astro';
import { patterns, categoryIds, type PatternCategoryId } from '@/config/patterns';
import { filterDraftItems } from '@/lib/patterns';
import { siteConfig } from '@/config/site';
import { isRootLang, isValidLang, type LangCode } from '@/lib/i18n';

export async function getStaticPaths() {
  const langCodes = Object.keys(siteConfig.langs) as LangCode[];
  const nonRootLangs = langCodes.filter((lang) => !isRootLang(lang));
  return nonRootLangs.map((lang) => ({
    params: { lang },
    props: { lang },
  }));
}

interface Props {
  lang: LangCode;
}

const { lang } = Astro.props as Props;

if (!isValidLang(lang)) {
  return Astro.redirect('/404');
}
---

<BaseLayout title="Patterns" description="Web site patterns built with Lism CSS" excludeFromSearch>
  <Stack g="40" class="patterns">
    <Stack as="header" g="20">
      <h1>Web Patterns</h1>
      <Text c="text-2">A collection of copy-and-paste ready web site patterns built with Lism CSS.</Text>
    </Stack>

    <Stack g="40">
      {
        categoryIds.map((categoryId: PatternCategoryId) => {
          const category = patterns[categoryId];
          const items = filterDraftItems(category.items);
          return (
            <Box as="section">
              <Heading level="2" layout="flex" ai="center" g="10" fz="xl" bd-b py="10" px="5">
                <span>{category.label}</span>
                <Inline fz="xs" c="text-2" fw="normal">
                  ({items.length})
                </Inline>
              </Heading>

              <AutoColumns autoFill cols="24rem" g="20" my-s="20" class="patternList">
                {items.map((item) => (
                  <BoxLink class="patternList_link" layout="stack" href={`/${lang}/patterns/${categoryId}/${item.id}`} p="10" g="20" set="var:hov">
                    <Frame ar="3/2" bd bdrs="20" ov="hidden">
                      <img
                        src={`/screenshots/patterns/${lang}/${categoryId}/${item.id}.png`}
                        alt={item.title}
                        loading="lazy"
                        decoding="async"
                        class="patternList_thumb"
                      />
                    </Frame>
                    <Lism layout="cluster" g="10" class="u--trim -ff:mono -fz:s">
                      {item.title}
                    </Lism>
                  </BoxLink>
                ))}
              </AutoColumns>
            </Box>
          );
        })
      }
    </Stack>
  </Stack>
</BaseLayout>

<style>
  /* サムネイルカードのスタイル */
  .patternList_link > .l--frame {
    --bdw: 2px;
    transition: box-shadow 0.2s;
    box-shadow: var(--_isHov, var(--bxsh--30)) var(--_notHov, var(--bxsh--10));
  }

  /* サムネイル画像のスタイル */
  .patternList_thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform 0.3s ease;
  }

  /* ホバー時のズーム効果 */
  .patternList_link:hover .patternList_thumb {
    transform: scale(1.02);
  }
</style>
