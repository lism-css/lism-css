---
/**
 * パターン詳細ページ（非root言語用）
 *
 * URL: /{lang}/patterns/{category}/{id}
 * 例: /en/patterns/cta/cta001
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Stack, Flow, Text, Group } from 'lism-css/astro';
import { PreviewFrame, PreviewTitle } from '@/components/Preview';
import SrcCode from '@/components/mdx/SrcCode.astro';
import { patterns, type PatternCategoryId } from '@/config/patterns';
import { getAllPatternPaths, getPattern } from '@/lib/patterns';
import { siteConfig } from '@/config/site';
import { isRootLang, isValidLang, type LangCode } from '@/lib/i18n';

// 静的パス生成
export function getStaticPaths() {
  const langCodes = Object.keys(siteConfig.langs) as LangCode[];
  const nonRootLangs = langCodes.filter((lang) => !isRootLang(lang));
  const patternPaths = getAllPatternPaths();

  const paths = [];
  for (const lang of nonRootLangs) {
    for (const { category, id } of patternPaths) {
      paths.push({
        params: { lang, category, id },
        props: { lang },
      });
    }
  }
  return paths;
}

interface Props {
  lang: LangCode;
}

const { lang } = Astro.props;
const { category, id } = Astro.params;

if (!isValidLang(lang)) {
  return Astro.redirect('/404');
}

const pattern = getPattern(category!, id!);

// パターンが見つからない場合は404
if (!pattern) {
  return Astro.redirect('/404');
}

// カテゴリ情報
const categoryData = patterns[category as PatternCategoryId];

// プレビューURLとコード埋め込み用のパス（言語に応じて切り替え）
const previewUrl = `/preview/patterns/${category}/${id}/${lang}/`;
const patternPath = `src/pages/preview/patterns/${category}/${id}`;
---

<BaseLayout title={`${pattern.title} - Patterns`} description={pattern.description[lang]} lang={lang} excludeFromSearch noindex>
  <Flow g="30" class="patternPage">
    <Stack as="header" g="10">
      <Text fz="xs" c="text-2" tt="uppercase" lts="l">
        {categoryData.label}
      </Text>
      <h1 class="-fz:3xl -fw:bold">{pattern.title}</h1>
      <Text c="text-2">{pattern.description[lang]}</Text>
    </Stack>
    {
      pattern.draft && (
        <Group class="draftBadge" fz="xs" w="fit" bgc="red" c="base" bdrs="10" px="10">
          DRAFT
        </Group>
      )
    }
    {/* プレビュー */}
    <Group layout="flow" my-s="50">
      <!-- <PreviewTitle>Preview</PreviewTitle> -->
      <PreviewFrame url={previewUrl} hasSizeSwitch />
    </Group>

    {/* ソースコード */}
    <Stack g="15">
      <PreviewTitle>Code</PreviewTitle>
      <SrcCode dir="docs" path={patternPath + `/${lang}.astro`} title={`${lang}.astro`} />
      <SrcCode dir="docs" path={patternPath + '/_style.css'} title="style.css" />
    </Stack>
  </Flow>
</BaseLayout>

<style>
  .patternPage {
    /* 詳細ページ固有のスタイル */
  }

  .code-embed {
    border-radius: var(--bdrs--10);
    overflow: hidden;
  }
</style>
