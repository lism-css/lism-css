---
/**
 * トップページ（非root言語用）
 * 日本語トップページの翻訳版
 */
import SimpleLayout from '@/layouts/SimpleLayout.astro';
import { Stack, TileGrid, Flex, Lism, Heading, Text, Link, Columns, LinkBox } from 'lism-css/astro';
import { Button } from '@lism-css/ui/astro';
import Gradbox from '@/components/parts/Gradbox.astro';
import { siteConfig } from '@/config/site';
import { isRootLang, isValidLang, type LangCode } from '@/lib/i18n';

export async function getStaticPaths() {
  const langCodes = Object.keys(siteConfig.langs) as LangCode[];
  // 非root言語のみ対象
  const nonRootLangs = langCodes.filter((lang) => !isRootLang(lang));

  return nonRootLangs.map((lang) => ({
    params: { lang },
    props: { lang },
  }));
}

interface Props {
  lang: LangCode;
}

const { lang } = Astro.props;

// 言語が無効な場合は404
if (!isValidLang(lang)) {
  return Astro.redirect('/404');
}

const FEATURES = [
  {
    icon: '<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>',
    title: 'Layout Modules',
    desc: 'Modularized layout patterns like Stack, Flex, Grid, and Columns. Combine them to build your site structure in no time.',
  },
  {
    icon: '<line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/>',
    title: 'Harmonic Scale',
    desc: 'Spacing, font sizes, and line heights designed with harmonic ratios. A typography system that creates a natural, pleasing rhythm.',
  },
  {
    icon: '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
    title: 'Design Tokens',
    desc: 'Colors, font sizes, spacing, border radius, shadows and more — all managed as stepped CSS variables for site-wide consistency.',
  },
  {
    icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
    title: 'Property Class',
    desc: 'Style quickly with intuitive class names like -fz:l and -p:20. A clear, concise notation that even AI can understand without confusion.',
  },
  {
    icon: '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>',
    title: 'CSS Layer Architecture',
    desc: 'A strict CSS layer design powered by @layer. Prevents specificity conflicts while maintaining both extensibility and maintainability.',
  },
  {
    icon: '<rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>',
    title: 'Responsive',
    desc: 'A unique responsive approach combining CSS variables and classes. Lightweight yet flexible enough for a wide range of layouts.',
  },
];

// Ecosystem
const ecosystems = [
  {
    icon: '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
    title: 'Skills',
    desc: 'Implementation guide skills for AI agents. AI understands Lism CSS design principles and generates code following best practices.',
    href: '/docs/skills/',
  },
  {
    icon: '<rect x="4" y="4" width="16" height="16" rx="2" ry="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/>',
    title: 'MCP Server',
    desc: 'Provides Lism CSS specifications to AI coding tools like Claude Code and Cursor. Build sites efficiently with AI collaboration.',
    href: '/docs/mcp/',
  },
  {
    icon: '<rect width="7" height="7" x="14" y="3" rx="1"/><path d="M10 21V8a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-5a1 1 0 0 0-1-1H3"/>',
    title: 'UI Components',
    desc: 'Interactive UI components like Accordion, Modal, Tabs, and Button for React and Astro. Add them to your project with a single CLI command.',
    href: '/ui/',
  },
  {
    icon: '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>',
    title: 'Templates',
    desc: 'Ready-to-use page templates. Copy practical layout parts for landing pages, blogs, and more to get started right away.',
    href: '/templates/',
  },
];
---

<SimpleLayout
  title={siteConfig.name}
  description="The official documentation site for Lism CSS."
  lang={lang}
  schemaType="SoftwareSourceCode"
  excludeFromSearch
>
  <TileGrid class="c--hero" cols="5" rows="1" min-h={['50svh', '75vh']} ai="center">
    <Stack class="c--hero_content" g="40" gc="1 / 5" gr="1" z="1">
      <Stack g="30">
        <Lism class="-w:fit">
          <Heading level="1" fz={['3xl', '4xl']} fw="light" ff="accent" lts="l"> A CSS Design Framework<br />for AI and Humans</Heading>
        </Lism>
        <Text class="c--hero_tagline" fz="m" c="text-2">
          Lightweight and build-free. Works on any site.<br />
          You never have to worry about CSS architecture again.
        </Text>
      </Stack>
      <Flex>
        <Link href="/docs/overview/" bgc="text" c="base" td="none" bdrs="99" py="10" px="30" hov="neutral">Documentation</Link>
      </Flex>
    </Stack>
    <Lism class="c--hero_image" gc="3 / 6" gr="1" pb="10" z="0">
      <Gradbox />
    </Lism>
  </TileGrid>

  <Stack as="section" ai="center" g="50" py="60">
    <Stack ai="center" g="20">
      <Text fz="2xs" fw="500" c="text-2" tt="upper" lts="0.15em"> FEATURES </Text>
      <Heading level="2" ff="accent" fw="normal" ta="center" fz="3xl" lts="s">A Sophisticated Design Theory</Heading>
    </Stack>

    <Columns cols={[1, 2, 3]} g="40">
      {
        FEATURES.map((card) => (
          <Stack g="20" p="10">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={card.icon}
            />
            <Text fw="bold">{card.title}</Text>
            <Text fz="s" c="text-2" lh="s">
              {card.desc}
            </Text>
          </Stack>
        ))
      }
    </Columns>
  </Stack>

  <Stack as="section" ai="center" g="50" py="60">
    <Stack ai="center" g="20">
      <Text fz="2xs" fw="500" c="text-2" tt="upper" lts="0.15em">ECOSYSTEM</Text>
      <Heading level="2" ff="accent" fw="normal" ta="center" fz="3xl" lts="s">A Rich Ecosystem</Heading>
    </Stack>

    <Columns cols={[1, 2]} g="30">
      {
        ecosystems.map((item) => (
          <LinkBox href={item.href} layout="stack" g="20" p="30" bd hov="bxsh" td="none">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={item.icon}
            />
            <Text fz="l" fw="bold">
              {item.title}
            </Text>
            <Text fz="s" c="text-2" lh="s">
              {item.desc}
            </Text>
          </LinkBox>
        ))
      }
    </Columns>
  </Stack>

  <Stack as="section" ai="center" g="20" py="60">
    <Heading level="2" ff="accent" fw="normal" ta="center" fz="3xl" lts="s">Works Everywhere</Heading>
    <Text ta="center" c="text-2" lh="s"> Lism CSS can be adopted by simply loading a single CSS file. </Text>
  </Stack>

  {/* CTA */}
  <Flex jc="center" my-s="60">
    <Button variant="fill" href="/docs/installation" bdrs="99" py="15" px="30">
      <span>Getting Started</span>
    </Button>
  </Flex>
</SimpleLayout>
