---
/**
 * Page Layout 詳細ページ（非root言語用）
 *
 * URL: /{lang}/page-layouts/{category}/{id}
 * 例: /en/page-layouts/article/one-column
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Stack, Flow, Text, Group } from 'lism-css/astro';
import { PreviewFrame, PreviewTitle } from '@/components/Preview';
import SrcCode from '@/components/mdx/SrcCode.astro';
import { pageLayouts, type PageLayoutCategoryId } from '@/config/page-layouts';
import { getAllPageLayoutPaths, getPageLayout } from '@/lib/page-layouts';
import { siteConfig } from '@/config/site';
import { isRootLang, isValidLang, type LangCode } from '@/lib/i18n';

// 静的パス生成
export function getStaticPaths() {
  const langCodes = Object.keys(siteConfig.langs) as LangCode[];
  const nonRootLangs = langCodes.filter((lang) => !isRootLang(lang));
  const layoutPaths = getAllPageLayoutPaths();

  const paths = [];
  for (const lang of nonRootLangs) {
    for (const { category, id } of layoutPaths) {
      paths.push({
        params: { lang, category, id },
        props: { lang },
      });
    }
  }
  return paths;
}

interface Props {
  lang: LangCode;
}

const { lang } = Astro.props as Props;
const { category, id } = Astro.params;

if (!isValidLang(lang)) {
  return Astro.redirect('/404');
}

const layout = getPageLayout(category!, id!);

// レイアウトが見つからない場合は404
if (!layout) {
  return Astro.redirect('/404');
}

// カテゴリ情報
const categoryData = pageLayouts[category as PageLayoutCategoryId];

// プレビューURL（preview に en.astro は無いため共通の index.astro を参照）とコード埋め込み用のパス
const previewUrl = `/preview/page-layouts/${category}/${id}/`;
const layoutPath = `src/pages/preview/page-layouts/${category}/${id}`;
---

<BaseLayout title={`${layout.title} - Page Layouts`} description={layout.description[lang]} lang={lang} excludeFromSearch noindex>
  <Flow g="30" class="pageLayoutPage">
    <Stack as="header" g="10">
      <Text fz="xs" c="text-2" tt="uppercase" lts="l">
        {categoryData.label}
      </Text>
      <h1 class="-fz:3xl -fw:bold">{layout.title}</h1>
      <Text c="text-2">{layout.description[lang]}</Text>
    </Stack>
    {
      layout.draft && (
        <Group class="draftBadge" fz="xs" w="fit" bgc="red" c="base" bdrs="10" px="10">
          DRAFT
        </Group>
      )
    }
    {/* プレビュー */}
    <Group layout="flow" mbs="50">
      <PreviewFrame url={previewUrl} hasSizeSwitch />
    </Group>

    {/* ソースコード */}
    <Stack g="15">
      <PreviewTitle>Code</PreviewTitle>
      <SrcCode dir="docs" path={layoutPath + '/index.astro'} title="index.astro" />
    </Stack>
  </Flow>
</BaseLayout>

<style>
  .pageLayoutPage {
    /* 詳細ページ固有のスタイル */
  }
</style>
