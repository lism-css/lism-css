---
/**
 * Page Layouts 一覧ページ（非root言語用）
 * カテゴリ別にページレイアウトを一覧表示
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Stack, AutoColumns, Frame, BoxLink, Box, Lism, Text, Inline, Heading } from 'lism-css/astro';
import { pageLayouts, categoryIds, type PageLayoutCategoryId } from '@/config/page-layouts';
import { filterDraftItems } from '@/lib/page-layouts';
import { siteConfig } from '@/config/site';
import { isRootLang, isValidLang, type LangCode } from '@/lib/i18n';

export async function getStaticPaths() {
  const langCodes = Object.keys(siteConfig.langs) as LangCode[];
  const nonRootLangs = langCodes.filter((lang) => !isRootLang(lang));
  return nonRootLangs.map((lang) => ({
    params: { lang },
    props: { lang },
  }));
}

interface Props {
  lang: LangCode;
}

const { lang } = Astro.props as Props;

if (!isValidLang(lang)) {
  return Astro.redirect('/404');
}
---

<BaseLayout title="Page Layouts" description="Full-page layout examples built with Lism CSS layout primitives." lang={lang} excludeFromSearch>
  <Stack g="40" class="pageLayouts">
    <Stack as="header" g="20">
      <h1>Page Layouts</h1>
      <Text c="text-2"> Full-page layout examples built with Lism CSS layout primitives. </Text>
    </Stack>

    <Stack g="40">
      {
        categoryIds.map((categoryId: PageLayoutCategoryId) => {
          const category = pageLayouts[categoryId];
          const items = filterDraftItems(category.items);
          // 空カテゴリは表示しない
          if (items.length === 0) return null;
          return (
            <Box as="section">
              <Heading level="2" layout="flex" ai="center" g="10" fz="xl" bd-b py="10" px="5">
                <span>{category.label}</span>
                <Inline fz="xs" c="text-2" fw="normal">
                  ({items.length})
                </Inline>
              </Heading>

              <AutoColumns cols="24rem" g="20" mbs="20" class="pageLayoutList">
                {items.map((item) => (
                  <BoxLink class="pageLayoutList_link" layout="stack" href={`/${lang}/page-layouts/${categoryId}/${item.id}`} p="10" g="20" set="hov">
                    <Frame ar="3/2" bd bdrs="20" ov="hidden">
                      <img
                        src={`/screenshots/page-layouts/${categoryId}/${item.id}.png`}
                        alt={item.title}
                        loading="lazy"
                        decoding="async"
                        class="pageLayoutList_thumb"
                      />
                    </Frame>
                    <Lism layout="cluster" g="10" class="u--trim -ff:mono -fz:s">
                      {item.title}
                    </Lism>
                  </BoxLink>
                ))}
              </AutoColumns>
            </Box>
          );
        })
      }
    </Stack>
  </Stack>
</BaseLayout>

<style>
  /* サムネイルカードのスタイル */
  .pageLayoutList_link > .l--frame {
    --bdw: 2px;
    transition: box-shadow 0.2s;
    box-shadow: var(--_isHov, var(--bxsh--30)) var(--_notHov, var(--bxsh--10));
  }

  /* サムネイル画像のスタイル */
  .pageLayoutList_thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    transition: transform 0.3s ease;
  }

  /* ホバー時のズーム効果 */
  .pageLayoutList_link:hover .pageLayoutList_thumb {
    transform: scale(1.02);
  }
</style>
