---
/**
 * テンプレート詳細ページ（非root言語）
 *
 * URL: /{lang}/templates/{category}/{slug}/
 * 例: /en/templates/lp/lp-astro-ryokan/
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import TemplateDetail from '@/components/templates/TemplateDetail.astro';
import { getSingleTemplatePaths, getTemplate, getCategory } from '@/lib/templates';
import { siteConfig } from '@/config/site';
import { isRootLang, isValidLang, type LangCode } from '@/lib/i18n';

export function getStaticPaths() {
  const langCodes = Object.keys(siteConfig.langs) as LangCode[];
  const nonRootLangs = langCodes.filter((lang) => !isRootLang(lang));
  const templatePaths = getSingleTemplatePaths();

  const paths = [];
  for (const lang of nonRootLangs) {
    for (const { category, slug } of templatePaths) {
      paths.push({
        params: { lang, category, slug },
        props: { lang },
      });
    }
  }
  return paths;
}

interface Props {
  lang: LangCode;
}

const { lang } = Astro.props as Props;
const { category, slug } = Astro.params;

if (!isValidLang(lang)) {
  return Astro.redirect('/404');
}

const template = getTemplate(category!, slug!);
const categoryData = template ? getCategory(template.category) : undefined;

if (!template || !categoryData) {
  return Astro.redirect('/404');
}
---

<BaseLayout title={`${template.title[lang]} - Templates`} description={template.description[lang]} lang={lang}>
  <TemplateDetail template={template} category={categoryData} lang={lang} />
</BaseLayout>
