---
/**
 * カテゴリ単位の詳細ページ（非root言語）
 *
 * URL: /{lang}/templates/{category}/
 * aggregateView: true のカテゴリでのみ生成される。
 * 例: /en/templates/minimal/
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import TemplateCategoryDetail from '@/components/templates/TemplateCategoryDetail.astro';
import { getAggregatedCategoryPaths, getCategory } from '@/lib/templates';
import { getCategoryTemplates } from '@/config/templates';
import { siteConfig } from '@/config/site';
import { isRootLang, isValidLang, type LangCode } from '@/lib/i18n';

export function getStaticPaths() {
  const langCodes = Object.keys(siteConfig.langs) as LangCode[];
  const nonRootLangs = langCodes.filter((lang) => !isRootLang(lang));
  const categoryPaths = getAggregatedCategoryPaths();

  const paths = [];
  for (const lang of nonRootLangs) {
    for (const { category } of categoryPaths) {
      paths.push({
        params: { lang, category },
        props: { lang },
      });
    }
  }
  return paths;
}

interface Props {
  lang: LangCode;
}

const { lang } = Astro.props as Props;
const { category } = Astro.params;

if (!isValidLang(lang)) {
  return Astro.redirect('/404');
}

const categoryData = getCategory(category!);
const templates = categoryData ? getCategoryTemplates(categoryData.id) : [];

if (!categoryData || templates.length === 0) {
  return Astro.redirect('/404');
}
---

<BaseLayout title={`${categoryData.label} - Templates`} description={categoryData.description[lang]} lang={lang}>
  <TemplateCategoryDetail category={categoryData} templates={templates} lang={lang} />
</BaseLayout>
