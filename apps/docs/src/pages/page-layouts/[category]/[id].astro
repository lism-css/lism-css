---
/**
 * Page Layout 詳細ページ（動的ルーティング / root言語: ja）
 *
 * URL: /page-layouts/{category}/{id}
 * 例: /page-layouts/article/one-column
 *
 * プレビューiframeは /preview/page-layouts/{category}/{id}/ を参照
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Stack, Flow, Text, Group } from 'lism-css/astro';
import { PreviewFrame, PreviewTitle } from '@/components/Preview';
import SrcCode from '@/components/mdx/SrcCode.astro';
import { pageLayouts, type PageLayoutCategoryId } from '@/config/page-layouts';
import { getAllPageLayoutPaths, getPageLayout } from '@/lib/page-layouts';

// 静的パス生成
export function getStaticPaths() {
  const paths = getAllPageLayoutPaths();
  return paths.map(({ category, id }) => ({
    params: { category, id },
  }));
}

// Params取得
const { category, id } = Astro.params;
const layout = getPageLayout(category!, id!);

// レイアウトが見つからない場合は404
if (!layout) {
  return Astro.redirect('/404');
}

// カテゴリ情報
const categoryData = pageLayouts[category as PageLayoutCategoryId];

// プレビューURLとコード埋め込み用のパス
const previewUrl = `/preview/page-layouts/${category}/${id}/`;
const layoutPath = `src/pages/preview/page-layouts/${category}/${id}`;
---

<BaseLayout title={`${layout.title} - Page Layouts`} description={layout.description.ja} excludeFromSearch noindex>
  <Flow g="30" class="pageLayoutPage">
    <Stack as="header" g="10">
      <Text fz="xs" c="text-2" tt="uppercase" lts="l">
        {categoryData.label}
      </Text>
      <h1 class="-fz:3xl -fw:bold">{layout.title}</h1>
      <Text c="text-2">{layout.description.ja}</Text>
    </Stack>
    {
      layout.draft && (
        <Group class="draftBadge" fz="xs" w="fit" bgc="red" c="base" bdrs="10" px="10">
          DRAFT
        </Group>
      )
    }
    {/* プレビュー */}
    <Group layout="flow" mbs="50">
      <PreviewFrame url={previewUrl} hasSizeSwitch />
    </Group>

    {/* ソースコード */}
    <Stack g="15">
      <PreviewTitle>コード</PreviewTitle>
      <SrcCode dir="docs" path={layoutPath + '/index.astro'} title="index.astro" />
    </Stack>
  </Flow>
</BaseLayout>

<style>
  .pageLayoutPage {
    /* 詳細ページ固有のスタイル */
  }
</style>
