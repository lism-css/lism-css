---
/**
 * 共通 <head> コンポーネント
 * - メタタグ、OGP、Twitter Card、Google Analytics などを管理
 * - BaseLayout と SimpleLayout で共通使用
 */

import { siteConfig } from '@/config/site';
import { getAlternateUrls, getRootLang, getLocalizedUrl, getPathWithoutLang } from '@/lib/i18n';
import type { LangCode } from '@/lib/i18n';

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
	lang: LangCode;
}

const { title, description, ogImage, lang } = Astro.props;

// 開発環境かどうか
const isDev = import.meta.env.DEV;

// canonical URL: 開発環境では現在のURLをそのまま使用、本番では Astro.site を使用
const canonicalUrl = isDev ? Astro.url.toString() : Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.toString();

// OG画像URL: 開発環境では相対パス、本番環境では絶対URL
const getOgImageUrl = (imgPath?: string): string | undefined => {
	if (!imgPath) return undefined;

	// 開発環境では相対パスをそのまま返す
	if (isDev) {
		return imgPath;
	}

	// 本番環境では Astro.site を使って絶対URLに変換
	if (Astro.site) {
		return new URL(imgPath, Astro.site).toString();
	}

	// Astro.site が未設定の場合は相対パスを返す
	return imgPath;
};

const ogImageUrl = getOgImageUrl(ogImage || '/og-default.jpg');

// タイトルメタテキスト（ページタイトル - サイト名 の形式）
const titleMetaText = title === siteConfig.name ? title : `${title} - ${siteConfig.name}`;

// 言語に応じた og:locale を生成
const ogLocaleMap: Record<LangCode, string> = {
	ja: 'ja_JP',
	en: 'en_US',
};
const ogLocale = ogLocaleMap[lang] || 'ja_JP';

// 多言語 hreflang 用の代替URL一覧
const alternateUrls = getAlternateUrls(Astro.url);
const rootLang = getRootLang();
const rootPath = getLocalizedUrl(getPathWithoutLang(Astro.url), rootLang);

// パスを絶対URLに変換（canonical と一致するよう末尾スラッシュを保証）
const toAbsoluteUrl = (path: string): string => {
	const normalized = path.endsWith('/') ? path : `${path}/`;
	if (isDev) return normalized;
	if (Astro.site) return new URL(normalized, Astro.site).toString();
	return normalized;
};

// Google Analytics: 本番環境かつ測定IDが設定されている場合のみ有効化
// 開発環境・プレビュー環境では計測しない
const gaMeasurementId = siteConfig.googleAnalytics.measurementId;
const enableGA = !isDev && siteConfig.publish && gaMeasurementId;
---

<head>
	<meta charset="utf-8" />
	<script is:inline define:vars={{ defaultTheme: siteConfig.theme.default }}>
		// ちらつきを防ぐため、 head内でテーマセットする
		(function () {
			var stored = localStorage.getItem('theme');
			var theme;
			if (stored === 'light' || stored === 'dark') {
				theme = stored;
			} else if (defaultTheme === 'light' || defaultTheme === 'dark') {
				theme = defaultTheme;
			} else {
				theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
			}
			document.documentElement.setAttribute('data-theme', theme);
		})();
	</script>
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<meta name="viewport" content="width=device-width" />
	<meta name="generator" content={Astro.generator} />

	{/* 基本メタタグ */}
	<title>{titleMetaText}</title>
	{description && <meta name="description" content={description} />}
	<link rel="canonical" href={canonicalUrl} />
	{!siteConfig.publish && <meta name="robots" content="noindex, nofollow" />}

	{/* 多言語 hreflang: 検索エンジンに各言語版の存在を通知 */}
	{alternateUrls.map(({ lang: altLang, url }) => <link rel="alternate" hreflang={altLang} href={toAbsoluteUrl(url)} />)}
	<link rel="alternate" hreflang="x-default" href={toAbsoluteUrl(rootPath)} />

	{/* OGP メタタグ */}
	<meta property="og:type" content="article" />
	<meta property="og:title" content={titleMetaText} />
	{description && <meta property="og:description" content={description} />}
	<meta property="og:url" content={canonicalUrl} />
	{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
	<meta property="og:site_name" content={siteConfig.name} />
	<meta property="og:locale" content={ogLocale} />
	{/* 他言語版の og:locale を通知 */}
	{
		alternateUrls
			.filter(({ lang: altLang }) => altLang !== lang)
			.map(({ lang: altLang }) => <meta property="og:locale:alternate" content={ogLocaleMap[altLang]} />)
	}

	{/* Twitter Card メタタグ */}
	<meta name="twitter:card" content="summary_large_image" />
	<meta name="twitter:title" content={titleMetaText} />
	{description && <meta name="twitter:description" content={description} />}
	{ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

	{
		/*
		Google Analytics
		memo: 条件レンダリング内の script タグは prettier-plugin-astro のパースバグを踏むため、
		script を条件外に置き、data-* 属性の有無でJS側から初期化を判断している
	*/
	}
	{enableGA && <meta id="ga-config" data-ga-id={gaMeasurementId} />}
	<script>
		var gaEl = document.getElementById('ga-config');
		if (gaEl) {
			var s = document.createElement('script');
			s.async = true;
			s.src = 'https://www.googletagmanager.com/gtag/js?id=' + gaEl.dataset.gaId;
			document.head.appendChild(s);

			window.dataLayer = window.dataLayer || [];
			function gtag(...args: any[]) {
				window.dataLayer.push(args);
			}
			gtag('js', new Date());
			gtag('config', gaEl.dataset.gaId);
		}
	</script>

	{/* 追加のhead要素用スロット */}
	<slot />
</head>
