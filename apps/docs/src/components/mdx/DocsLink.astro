---
/**
 * ドキュメント内の別ページへのカードリンク
 * コンテンツコレクションから title / description を取得して表示する
 * URL は現在の言語に自動変換される
 */
import { BoxLink, Flex, Icon, Group, Inline } from 'lism-css/astro';
import { getPostWithFallback } from '@/lib/content';
import { getLangFromUrl, getLocalizedUrl } from '@/lib/i18n';

interface Props {
  // ドキュメント内ページのパス（例: '/docs/features', '/ui/Accordion'）
  path: string;
  // 手動でタイトルを上書きする場合
  title?: string;
  // 手動で説明文を上書きする場合
  description?: string;
}

const { path, title: manualTitle, description: manualDescription } = Astro.props;

// 現在の言語を取得
const currentLang = getLangFromUrl(Astro.url);

// path → content collection の slug に変換
// 例: '/docs/features' → 'features', '/ui/Accordion' → 'ui/Accordion'
const slug = path.replace(/^\/docs\//, '').replace(/^\//, '');

// コンテンツコレクションから記事を取得（フォールバック対応）
const { entry } = await getPostWithFallback(currentLang, slug);

// 記事が見つからない場合の警告
if (!entry) {
  console.warn(`[DocsLink] 記事が見つかりません: ${slug} (path: ${path})`);
}

// 表示用データ（手動指定があればそちらを優先）
const displayTitle = manualTitle || entry?.data.title || path;
const displayDescription = manualDescription || entry?.data.description || '';

// リンク先URL（言語対応）
const href = getLocalizedUrl(path, currentLang);
---

<BoxLink href={href} layout="stack" bdrs="20" my="40" bd bgc="base" hov="bxsh, bdc, bgc" set="hov transition" class="c--docsLink">
  <Flex class="c--docsLink_icon" c="text-2" p="5" lh="1" pos="absolute" set="transition">
    <Icon icon="link" />
  </Flex>
  <Group px-s="40" p="30">
    <div class="c--docsLink_head">
      <span class="c--docsLink_title -fw:bold">{displayTitle}</span>
      <Inline set="transition"> →</Inline>
    </div>
    {displayDescription && <p class="c--docsLink_description -c:text-2 -fz:sm -mt:10">{displayDescription}</p>}
  </Group>
</BoxLink>

<style>
  .c--docsLink {
    --hov-bdc: var(--divider);
    --hov-bxsh: var(--bxsh--30);
    --bdc: var(--base-2);
    --bdw: 3px;
    --hov-prop: border-color, box-shadow, background-color, translate;
  }
  .c--docsLink_icon {
    border-radius: calc(var(--bdrs--20) - 3px) 0 var(--bdrs--20) 0;
    background-color: var(--_isHov, var(--divider)) var(--_notHov, var(--base-2));
  }
  .c--docsLink_title + span {
    display: inline-flex;
    translate: var(--_isHov, 3px 0);
  }
</style>
