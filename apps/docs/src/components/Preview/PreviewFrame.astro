---
import { Stack, Frame, Icon } from 'lism-css/astro';
import { Button } from '@lism-css/ui/astro/Button';
import { DesktopIcon, DeviceMobileCameraIcon, DeviceTabletCameraIcon } from '@phosphor-icons/react';
import PreviewFrameScript from './PreviewFrameScript.astro';
import { getLangFromUrl, t } from '@/lib/i18n';

interface Props {
  [key: string]: any;
}
const { isInline = false, hasSizeSwitch = false, hasExternalLink = true, externalLinkLabel, url, ...props } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const externalLabel = externalLinkLabel ?? t(lang, 'demo').openNewTab;
---

{
  !isInline ? (
    <Stack g="20">
      {/* プレビューサイズ切り替えボタン */}
      {hasSizeSwitch && (
        <div class="c--previewSizeSwitcher l--flex -g:15 -jc:center" data-preview-url={url}>
          <button class="c--previewSizeSwitcher_btn l--center -bdrs:10" data-size="360px" data-w-pct="120" data-ar="2/3">
            <Icon as={DeviceMobileCameraIcon} fz="xl" />
          </button>
          <button class="c--previewSizeSwitcher_btn l--center -bdrs:10" data-size="600px" data-ar="3/4">
            <Icon as={DeviceTabletCameraIcon} fz="xl" />
          </button>
          <button class="c--previewSizeSwitcher_btn l--center -bdrs:10 _active" data-size="100%" data-ar="3/2">
            <Icon as={DesktopIcon} fz="xl" />
          </button>
        </div>
      )}

      <Frame
        id="preview-iframe"
        class="c--previewFrame"
        data-preview-url={url}
        ar
        bxsh="10"
        mx="auto"
        w="100%"
        max-w="100%"
        style={{ '--ar': '3/2' }}
      >
        <Frame className="u--scalePreview" ar bdrs="20" bd bdw="3px" {...props}>
          <iframe src={url} width="800" height="600" style="border:0" />
        </Frame>
      </Frame>
      {hasExternalLink && (
        <Button href={url} variant="fill" target="_blank" rel="noopener noreferrer" bdrs="10" w="fit" mx="auto">
          {externalLabel}
        </Button>
      )}
    </Stack>
  ) : (
    <Frame ar="3/2" {...props}>
      <iframe src={url} width="800" height="600" />
    </Frame>
  )
}
<style>
  .c--previewSizeSwitcher_btn {
    padding: 8px;
    border: 1px solid #ccc;
    background: var(--base-2);
    cursor: pointer;
  }
  .c--previewSizeSwitcher_btn._active {
    background: var(--link) !important;
    color: white !important;
    border-color: var(--link) !important;
  }
</style>
{hasSizeSwitch && !isInline && <PreviewFrameScript url={url} />}
