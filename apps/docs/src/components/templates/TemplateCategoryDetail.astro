---
/**
 * カテゴリ単位の詳細ページ本体（aggregateView: true のカテゴリ用）
 *
 * URL: /templates/{category}/  または  /{lang}/templates/{category}/
 * 「中身共通・stack 違いのみ」のカテゴリ（Minimal 等）で、コマンドだけ stack ごとに並べ、
 * プレビューは representative slug の 1枚だけを表示する。
 */
import { Stack, Text, Group, Cluster, Inline, Frame, Heading } from 'lism-css/astro';
import { Image } from 'astro:assets';
import { PreviewFrame, PreviewTitle } from '@/components/Preview';
import { getLocalizedUrl, type LangCode } from '@/lib/i18n';
import { stackLabels, getAggregateRepresentative, type TemplateItem, type CategoryDef } from '@/config/templates';
import CopyCommand from './CopyCommand.astro';

interface Props {
  category: CategoryDef;
  templates: TemplateItem[];
  lang: LangCode;
}

const { category, templates, lang } = Astro.props as Props;
const isJa = lang === 'ja';

const copy = isJa
  ? {
      backToList: '← Templates 一覧へ',
      install: 'インストールコマンド',
      installCategoryLead: '対話形式で stack を選んで生成します。',
      installStackLead: 'stack を直接指定する場合：',
      preview: 'プレビュー',
      previewMissing: 'このテンプレートはまだプレビューURLが設定されていません。',
      copy: 'コマンドをコピー',
      copied: 'コピーしました',
      thumbAlt: (title: string) => `${title} のサムネイル`,
    }
  : {
      backToList: '← Back to Templates',
      install: 'Install command',
      installCategoryLead: 'Pick a stack through the interactive flow.',
      installStackLead: 'Or specify a stack directly:',
      preview: 'Preview',
      previewMissing: 'A preview URL is not configured for this template yet.',
      copy: 'Copy command',
      copied: 'Copied!',
      thumbAlt: (title: string) => `${title} thumbnail`,
    };

const templatesUrl = getLocalizedUrl('/templates/', lang);
const categoryCommand = `npm create lism@latest -- --template ${category.id}`;
const representative = getAggregateRepresentative(category, templates) ?? templates[0];
const previewUrl = representative?.previewUrl;
---

<Stack g="40" class="p--templates">
  {/* パンくず（一覧へ戻る） */}
  <Cluster g="10" fz="xs">
    <a href={templatesUrl} class="-c:text-2">{copy.backToList}</a>
  </Cluster>

  {/* ヘッダー */}
  <Stack as="header" g="10">
    <Cluster g="10">
      <Text fz="xs" c="text-2" tt="uppercase" lts="l">
        {category.label}
      </Text>
      {
        templates.map((tpl) => (
          <Inline d="inline-flex" px="10" fz="2xs" ff="mono" c="text-2" bd bdc="current" bdrs="99">
            {stackLabels[tpl.stack]}
          </Inline>
        ))
      }
    </Cluster>
    <Heading level="1" fz="3xl" fw="bold">{category.label}</Heading>
    <Text c="text-2">{category.description[lang]}</Text>
  </Stack>

  {/* インストールコマンド */}
  <Group>
    <PreviewTitle>{copy.install}</PreviewTitle>
    <Stack g="20" p="20" bd bdrs="20" bgc="base">
      {/* カテゴリ slug 版 */}
      <Stack g="10">
        <Text util="trim" c="text-2" fz="xs" lh="s">{copy.installCategoryLead}</Text>
        <CopyCommand bdrs="10" command={categoryCommand} copyLabel={copy.copy} copiedLabel={copy.copied} />
      </Stack>

      {/* stack 別 slug 版 */}
      <Stack g="10">
        <Text util="trim" c="text-2" fz="xs" lh="s">{copy.installStackLead}</Text>
        {
          templates.map((tpl) => (
            <Stack g="5">
              <Cluster g="10" ai="baseline">
                <Inline d="inline-flex" px="10" fz="2xs" ff="mono" c="text-2" bd bdc="current" bdrs="99">
                  {stackLabels[tpl.stack]}
                </Inline>
              </Cluster>
              <CopyCommand bdrs="10" command={`npm create lism@latest -- --template ${tpl.slug}`} copyLabel={copy.copy} copiedLabel={copy.copied} />
            </Stack>
          ))
        }
      </Stack>
    </Stack>
  </Group>

  {/* プレビュー（representative slug の 1 枚のみ） */}
  <Group>
    {
      previewUrl ? (
        <PreviewFrame url={previewUrl} hasSizeSwitch />
      ) : representative ? (
        <Stack g="10">
          <Frame bd bdrs="20">
            <Image
              src={representative.thumb}
              alt={copy.thumbAlt(category.label)}
              widths={[400, 800, 1200]}
              sizes="(max-width: 800px) 100vw, 800px"
              loading="lazy"
            />
          </Frame>
          <Text c="text-2" fz="xs" lh="s" ta="center">
            {copy.previewMissing}
          </Text>
        </Stack>
      ) : null
    }
  </Group>
</Stack>
