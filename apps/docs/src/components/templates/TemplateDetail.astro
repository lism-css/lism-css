---
/**
 * テンプレート詳細ページ本体（ja / en 共通）
 *
 * URL: /templates/{category}/{slug}/  または  /{lang}/templates/{category}/{slug}/
 * 一覧（TemplatesIndex）から遷移して使う、テンプレート1件の紹介ページ。
 */
import { Stack, Text, Group, Cluster, Inline, Frame, Heading } from 'lism-css/astro';
import { Image } from 'astro:assets';
import { PreviewFrame, PreviewTitle } from '@/components/Preview';
import { getLocalizedUrl, type LangCode } from '@/lib/i18n';
import { stackLabels, type TemplateItem, type CategoryDef } from '@/config/templates';
import CopyCommand from './CopyCommand.astro';

interface Props {
  template: TemplateItem;
  category: CategoryDef;
  lang: LangCode;
}

const { template, category, lang } = Astro.props as Props;
const isJa = lang === 'ja';

const copy = isJa
  ? {
      backToList: '← Templates 一覧へ',
      install: 'インストールコマンド',
      installLead: '対話なしで生成する場合：',
      preview: 'プレビュー',
      previewMissing: 'このテンプレートはまだプレビューURLが設定されていません。',
      copy: 'コマンドをコピー',
      copied: 'コピーしました',
      thumbAlt: (title: string) => `${title} のサムネイル`,
    }
  : {
      backToList: '← Back to Templates',
      install: 'Install command',
      installLead: 'Skip the interactive flow:',
      preview: 'Preview',
      previewMissing: 'A preview URL is not configured for this template yet.',
      copy: 'Copy command',
      copied: 'Copied!',
      thumbAlt: (title: string) => `${title} thumbnail`,
    };

const templatesUrl = getLocalizedUrl('/templates/', lang);
const installCommand = `pnpm create lism --template ${template.slug}`;
const previewUrl = template.previewUrl;
---

<Stack g="40" class="templatePage">
  {/* パンくず（一覧へ戻る） */}
  <Cluster g="10" fz="xs">
    <a href={templatesUrl} class="-c:text-2">{copy.backToList}</a>
  </Cluster>

  {/* ヘッダー */}
  <Stack as="header" g="10">
    <Cluster g="10">
      <Text fz="xs" c="text-2" tt="uppercase" lts="l">
        {category.label}
      </Text>
      <Inline d="inline-flex" px="10" fz="2xs" ff="mono" c="text-2" bd bdc="current" bdrs="99">
        {stackLabels[template.stack]}
      </Inline>
    </Cluster>
    <Cluster g="10">
      <Heading level="1" fz="3xl" fw="bold">{template.title[lang]}</Heading>
      {
        template.draft && (
          <Inline d="inline-flex" px="10" fz="2xs" ff="mono" bgc="text-2" c="base" bdrs="99">
            draft
          </Inline>
        )
      }
    </Cluster>
    <Text c="text-2">{template.description[lang]}</Text>
  </Stack>

  {/* インストールコマンド */}
  <Group>
    <PreviewTitle>{copy.install}</PreviewTitle>
    <Stack g="10" p="20" bd bdrs="20" bgc="base">
      <Text util="trim" c="text-2" fz="xs" lh="s">{copy.installLead}</Text>
      <CopyCommand bdrs="10" command={installCommand} copyLabel={copy.copy} copiedLabel={copy.copied} />
    </Stack>
  </Group>

  {/* プレビュー */}
  <Group>
    {
      previewUrl ? (
        <PreviewFrame url={previewUrl} hasSizeSwitch />
      ) : (
        <Stack g="10">
          <Frame bd bdrs="20">
            <Image
              src={template.thumb}
              alt={copy.thumbAlt(template.title[lang])}
              widths={[400, 800, 1200]}
              sizes="(max-width: 800px) 100vw, 800px"
              loading="lazy"
            />
          </Frame>
          <Text c="text-2" fz="xs" lh="s" ta="center">
            {copy.previewMissing}
          </Text>
        </Stack>
      )
    }
  </Group>
</Stack>
