---
import { Stack, Flex, Cluster, AutoColumns, Text, Heading, Link, BoxLink, Lism, Inline } from 'lism-css/astro';
import { Button } from '@lism-css/ui/astro/Button';
import { Image } from 'astro:assets';
import { getLocalizedUrl, type LangCode } from '@/lib/i18n';
import { stackLabels, groupByCategory, getAggregateRepresentative, getThumb, getPreviewUrl } from '@/config/templates';
import { Preview, PreviewCode } from '@/components/Preview';
import CopyCommand from './CopyCommand.astro';

interface Props {
  lang: LangCode;
}

const { lang } = Astro.props as Props;
const isJa = lang === 'ja';

const copy = isJa
  ? {
      title: 'Project Templates',
      lead: 'Lism CSSで新しいプロジェクトを始めるための雛形です。CLIの対話選択、またはテンプレートslugの直接指定で生成できます。',
      quickStart: 'クイックスタート',
      available: '利用できるテンプレート',
      availableLead: 'CLIから直接生成できるテンプレート一覧です。',
      commandLead: '対話形式でカテゴリ、スタック、バリアントを選んで生成します。',
      fullFormLead: '引数を渡すと選択UIをスキップして直接生成できます。',
      termTitle: 'TemplatesとPatternsの違い',
      termBody: 'Templatesはプロジェクト一式を生成する雛形です。Patternsは既存サイトへコピーして使うセクション単位・パーツ単位のパターン集です。',
      patternsLink: 'Patternsを見る',
      copy: 'コマンドをコピー',
      copied: 'コピーしました',
      preview: 'Preview',
      details: '詳細を見る',
      thumbAlt: (title: string) => `${title} のサムネイル`,
      stat: (count: number) => `${count} templates`,
    }
  : {
      title: 'Project Templates',
      lead: 'Project starters for building new sites with Lism CSS. Generate them through the interactive CLI flow or by passing a template slug directly.',
      quickStart: 'Quick start',
      available: 'Available templates',
      availableLead: 'Templates you can generate directly from the CLI.',
      commandLead: 'Start the interactive flow and choose category, stack, and variant in order.',
      fullFormLead: 'Pass arguments to skip the selection UI and generate directly.',
      termTitle: 'Templates vs. Patterns',
      termBody: 'Templates generate a full project. Patterns are copy-and-paste section patterns for an existing site.',
      patternsLink: 'View Patterns',
      copy: 'Copy command',
      copied: 'Copied!',
      preview: 'Preview',
      details: 'View details',
      thumbAlt: (title: string) => `${title} thumbnail`,
      stat: (count: number) => `${count} templates`,
    };

const grouped = groupByCategory();

const patternsUrl = getLocalizedUrl('/patterns/', lang);

const buildCommand = (slug: string) => `npm create lism@latest -- --template ${slug}`;
const buildDetailUrl = (category: string, slug: string) => getLocalizedUrl(`/templates/${category}/${slug}/`, lang);
const buildCategoryDetailUrl = (category: string) => getLocalizedUrl(`/templates/${category}/`, lang);
---

<Stack g="50" class="p--templates" data-pagefind-body>
  {/* ===== ヘッダー ===== */}
  <Stack g="20">
    <Heading level="1">{copy.title}</Heading>
    <Text c="text-2" lh="s" max-sz="m">{copy.lead}</Text>
  </Stack>

  {/* ===== クイックスタート ===== */}
  <Stack as="section" g="30">
    <Heading level="2">{copy.quickStart}</Heading>
    <Stack g="40" p="30" bd bdrs="20" bgc="base">
      {/* 対話形式 */}
      <Stack>
        <Text util="trim" c="text-2" fz="s" lh="s">{copy.commandLead}</Text>
        <Preview>
          <PreviewCode slot="tab" label="npm">
            <Lism as="pre" class="p--templates_code" p="15" bdrs="10" bgc="base-2" fz="xs" lh="s">
              <code>npm create lism@latest</code>
            </Lism>
          </PreviewCode>
          <PreviewCode slot="tab" label="pnpm">
            <Lism as="pre" class="p--templates_code" p="15" bdrs="10" bgc="base-2" fz="xs" lh="s">
              <code>pnpm create lism</code>
            </Lism>
          </PreviewCode>
        </Preview>
      </Stack>
      {/* 引数指定 */}
      <Stack>
        <Text util="trim" c="text-2" fz="s" lh="s">{copy.fullFormLead}</Text>
        <Preview>
          <PreviewCode slot="tab" label="npm">
            <Lism as="pre" class="p--templates_code" p="15" bdrs="10" bgc="base-2" fz="xs" lh="s">
              <code>npm create lism@latest {'{targetDir}'} -- --template {'{slug}'}</code>
            </Lism>
          </PreviewCode>
          <PreviewCode slot="tab" label="pnpm">
            <Lism as="pre" class="p--templates_code" p="15" bdrs="10" bgc="base-2" fz="xs" lh="s">
              <code>pnpm create lism {'{targetDir}'} --template {'{slug}'}</code>
            </Lism>
          </PreviewCode>
        </Preview>
      </Stack>
    </Stack>
  </Stack>

  {/* ===== テンプレート一覧 ===== */}
  <Stack as="section" g="40" aria-labelledby="templates-list-title">
    <Stack g="20">
      <Heading id="templates-list-title" level="2">{copy.available}</Heading>
      <Text c="text-2" lh="s">{copy.availableLead}</Text>
    </Stack>

    {/* カテゴリ別グルーピング */}

    {
      grouped.map(({ category, items }) => (
        <Stack g="30">
          <Stack g="20">
            <Cluster g="15" ai="baseline">
              <Heading id={`templates-${category.id}`} level="3">
                {category.label}
              </Heading>
              <Inline c="text-2" fz="xs" lh="s" ff="mono">
                ({items.length})
              </Inline>
            </Cluster>
            <Text c="text-2" fz="s" lh="s">
              {category.description[lang]}
            </Text>
          </Stack>

          {() => {
            /* カード描画用データを正規化 */
            const cards = category.aggregateView
              ? (() => {
                  const rep = getAggregateRepresentative(category, items) ?? items[0];
                  return [
                    {
                      id: category.id,
                      title: category.label,
                      description: category.description[lang],
                      thumb: getThumb(rep, lang),
                      stacks: items.map((tpl) => tpl.stack),
                      detailUrl: buildCategoryDetailUrl(category.id),
                      command: buildCommand(category.id),
                      previewUrl: rep ? getPreviewUrl(rep, lang) : undefined,
                      features: undefined as string[] | undefined,
                      draft: false,
                    },
                  ];
                })()
              : items.map((tpl) => ({
                  id: tpl.slug,
                  title: tpl.title[lang],
                  description: tpl.description[lang],
                  thumb: getThumb(tpl, lang),
                  stacks: [tpl.stack],
                  detailUrl: buildDetailUrl(tpl.category, tpl.slug),
                  command: buildCommand(tpl.slug),
                  previewUrl: getPreviewUrl(tpl, lang),
                  features: tpl.features?.[lang],
                  draft: tpl.draft,
                }));

            return (
              <AutoColumns cols="20em" g="30">
                {cards.map((card) => (
                  <Stack as="article" id={card.id} g="0" bd bdrs="20" bgc="base" ov="hidden" class="p--templates_card">
                    <BoxLink
                      layout="frame"
                      href={card.detailUrl}
                      aria-label={card.title}
                      class="p--templates_thumbLink"
                      ar="16/9"
                      ov="hidden"
                      bd-b
                      fxsh="0"
                    >
                      <Image
                        src={card.thumb}
                        alt={copy.thumbAlt(card.title)}
                        widths={[400, 800]}
                        sizes="(max-width: 600px) 100vw, 33vw"
                        loading="lazy"
                      />
                    </BoxLink>

                    <Stack p="20" g="20" fxg="1">
                      <Cluster g="5">
                        {card.stacks.map((stack) => (
                          <Inline d="inline-flex" px="10" fz="2xs" ff="mono" c="text-2" bd bdc="current" bdrs="99">
                            {stackLabels[stack]}
                          </Inline>
                        ))}
                      </Cluster>
                      <Heading level="4" fz="l" util="trim">
                        <Link href={card.detailUrl} set="plain" hov="underline">
                          {card.title}
                        </Link>
                        {card.draft && (
                          <Inline px="10" fz="2xs" bdrs="99" c="red">
                            draft
                          </Inline>
                        )}
                      </Heading>
                      <Text c="text-2" fz="s" lh="s" util="trim">
                        {card.description}
                      </Text>
                      {card.features && card.features.length > 0 && (
                        <Cluster as="ul" g="5" cg="15" fz="xs" lh="s" class="p--templates_features">
                          {card.features.map((feat) => (
                            <li class="-d:flex -g:5 -c:text-2">{feat}</li>
                          ))}
                        </Cluster>
                      )}
                      <Stack g="15" mt="auto">
                        <CopyCommand bdrs="10" command={card.command} copyLabel={copy.copy} copiedLabel={copy.copied} />
                        <Flex g="15" ai="stretch">
                          <Button as="a" href={card.detailUrl} bdrs="10" g="5" fz="xs" fx="1" variant="outline">
                            <span>{copy.details}</span>
                          </Button>
                          <Button
                            as="a"
                            variant="fill"
                            href={card.previewUrl ?? '#'}
                            target={card.previewUrl ? '_blank' : undefined}
                            rel={card.previewUrl ? 'noopener noreferrer' : undefined}
                            aria-disabled={card.previewUrl ? undefined : 'true'}
                            tabindex={card.previewUrl ? undefined : -1}
                            bdrs="10"
                            g="5"
                            fz="xs"
                            fx="1"
                          >
                            <span>{copy.preview}</span>
                            <svg
                              width="12"
                              height="12"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2.5"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              aria-hidden="true"
                            >
                              <line x1="7" y1="17" x2="17" y2="7" />
                              <polyline points="7 7 17 7 17 17" />
                            </svg>
                          </Button>
                        </Flex>
                      </Stack>
                    </Stack>
                  </Stack>
                ))}
              </AutoColumns>
            );
          }}
        </Stack>
      ))
    }
  </Stack>

  {/* ===== Templates vs Patterns ===== */}
  <Stack as="section" g="20">
    <Heading level="2" fz="xl">{copy.termTitle}</Heading>
    <Text c="text-2" lh="s">{copy.termBody}</Text>
    <Link href={patternsUrl}>{copy.patternsLink}</Link>
  </Stack>

  <style>
    /* Quick start カード内のコードブロック：折り返し許可 */
    .p--templates_code {
      max-width: 100%;
      overflow-x: auto;
      white-space: pre-wrap;
      overflow-wrap: anywhere;
    }

    /* previewUrl 未設定の Preview ボタン等：クリック自体を抑止 */
    [aria-disabled='true'] {
      opacity: 0.5;
      pointer-events: none;
    }

    /* サムネイル：リンクとして拡大ホバー */
    .p--templates_thumbLink img {
      transition: transform 0.3s ease;
    }
    .p--templates_thumbLink:hover img {
      transform: scale(1.03);
    }

    /* 機能リスト：✅ プレフィックス付きで縦並び */
    .p--templates_features li::before {
      content: '✅';
      flex-shrink: 0;
      font-size: 0.9em;
    }
  </style>
</Stack>
