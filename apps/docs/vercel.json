{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"ignoreCommand": "git diff HEAD^ HEAD --quiet -- apps/docs/",
	"headers": [
		{
			"source": "/:path*/og/:slug*.png",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, s-maxage=31536000, max-age=86400, must-revalidate"
				}
			]
		}
	]
}
