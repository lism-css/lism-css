{
	"name": "lism-docs",
	"type": "module",
	"version": "0.0.1",
	"scripts": {
		"dev": "astro dev",
		"build": "astro build && pagefind --site dist",
		"build:astro": "astro build",
		"build:full": "npm run build && npm run screenshot",
		"preview": "astro preview",
		"astro": "astro",
		"typecheck": "astro sync && tsc --noEmit && astro check --tsconfig ./tsconfig.json",
		"screenshot": "npx tsx scripts/generate-screenshots.ts",
		"screenshot:force": "npx tsx scripts/generate-screenshots.ts --force",
		"screenshot:compare": "npx tsx scripts/compare-screenshots.ts",
		"screenshot:update": "npx tsx scripts/compare-screenshots.ts --update",
		"lint": "pnpm lint:eslint",
		"lint:eslint": "eslint '**/*.{js,mjs,ts,tsx,astro,mdx}'",
		"test": "pnpm run typecheck"
	},
	"dependencies": {
		"@astrojs/mdx": "^5.0.3",
		"@astrojs/react": "^5.0.2",
		"@astrojs/sitemap": "^3.7.2",
		"@expressive-code/plugin-line-numbers": "^0.41.7",
		"@lism-css/ui": "workspace:*",
		"@pagefind/default-ui": "^1.4.0",
		"@phosphor-icons/react": "^2.1.10",
		"astro": "^6.1.1",
		"astro-expressive-code": "^0.41.7",
		"lism-css": "workspace:*",
		"pagefind": "^1.4.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"rehype-external-links": "^3.0.0",
		"remark-directive": "^4.0.0",
		"satori": "^0.18.4",
		"sharp": "^0.34.5"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.8",
		"@types/hast": "^3.0.4",
		"@types/mdast": "^4.0.4",
		"@types/pngjs": "^6.0.5",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"autoprefixer": "^10.4.27",
		"eslint": "^9.39.4",
		"mdast-util-directive": "^3.1.0",
		"pixelmatch": "^7.1.0",
		"playwright": "^1.58.2",
		"pngjs": "^7.0.0",
		"prettier": "^3.8.1",
		"prettier-plugin-astro": "^0.14.1",
		"sass-embedded": "^1.98.0",
		"stylelint": "^17.4.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"unist-util-visit": "^5.1.0",
		"vitest": "^4.1.0"
	}
}
