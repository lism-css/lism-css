{
  "name": "lism-docs",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "format:mdx": "tsx scripts/format-mdx-codeblocks.ts",
    "dev": "astro dev",
    "build": "astro build && pagefind --site dist",
    "build:astro": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro sync && tsc --noEmit && astro check --tsconfig ./tsconfig.json",
    "generate:lastmod": "tsx scripts/generate-lastmod-map.ts",
    "screenshot:new": "pnpm build:astro && npx tsx scripts/generate-screenshots.ts",
    "screenshot:force": "pnpm build:astro && npx tsx scripts/generate-screenshots.ts --force",
    "screenshot:compare": "pnpm build:astro && npx tsx scripts/compare-screenshots.ts",
    "screenshot:update": "npx tsx scripts/update-screenshots.ts",
    "lint": "astro sync && pnpm lint:eslint",
    "lint:eslint": "eslint '**/*.{js,mjs,ts,tsx,astro,mdx}'",
    "test": "pnpm run typecheck"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.2",
    "@astrojs/sitemap": "^3.7.2",
    "@expressive-code/plugin-line-numbers": "^0.41.7",
    "@lism-css/ui": "workspace:*",
    "@pagefind/default-ui": "^1.4.0",
    "@phosphor-icons/react": "^2.1.10",
    "astro": "^6.1.1",
    "astro-expressive-code": "^0.41.7",
    "hast-util-select": "^6.0.4",
    "lism-css": "workspace:*",
    "lucide-react": "^0.577.0",
    "pagefind": "^1.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-external-links": "^3.0.0",
    "rehype-parse": "^9.0.1",
    "rehype-remark": "^10.0.1",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-stringify": "^11.0.0",
    "satori": "^0.18.4",
    "sharp": "^0.34.5",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "mdast-util-directive": "^3.1.0",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "sass-embedded": "^1.98.0",
    "stylelint": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "unist-util-visit": "^5.1.0",
    "vitest": "^4.1.0"
  }
}
